# Lets start by checking my inventory.
# Let's first set up operations for coal, iron ore, and copper ore resources
place_entity('burner-drill', direction=2, position=nearest('coal'));
# My apologies for the confusion. Let's instead use the "electric-mining-drill".
place_entity('electric-mining-drill', direction=2, position=nearest('coal'));
# I see. Let's craft an electric-mining-drill before placing it.
craft_item('electric-mining-drill', quantity=1);
place_entity('electric-mining-drill', direction=2, position=nearest('coal'));
# Now I have placed an electric-mining-drill near the coal resource.
# Let's do the same for iron ore and copper ore resources
craft_item('electric-mining-drill', quantity=2);
# In that case, let's first create a temporary setup for manually mining iron ore and then craft the electric-mining-drill.
move_to(nearest('iron_ore'));
harvest_resource((0,0), quantity=5);
craft_item('electric-mining-drill', quantity=1);
# Now that we have an electric-mining-drill, let's place it near iron ore and copper ore resources.
place_entity('electric-mining-drill', direction=2, position=nearest('iron_ore'));
# My apologies, it seems I made an error. Let's try to place the electric mining drill one meter away from the resource.
move_to(nearest('iron_ore'));
