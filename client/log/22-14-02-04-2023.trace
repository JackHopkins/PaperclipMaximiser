# First, gather some resources
goto(nearest('tree'));
harvest((-2, 0), count=5);
goto((-17, -14));
# Move to coal deposit
harvest((0, 0), count=10);
goto((22, -14));
# Move to iron ore deposit
harvest((0, 0), count=10);
goto((-17, 6));
# Move to stone deposit
harvest((0, 0), count=5);
goto((22, 6));
# Move to copper ore deposit
harvest((0, 0), count=5);
# Set up initial production chain for iron plates
craft('burner-mining-drill', count=1);
craft('stone-furnace', count=1);
goto((22, -14));
# Move back to iron ore deposit
place('burner-mining-drill', 2, (1, 0));
insert('coal', (1, 0), count=5);
rotate((1, 0), 2);
goto((30, -14));
# Move to output location
place('stone-furnace', 2, (1, 0));
insert('coal', (1, 0), count=5);
# Wait for the burner-mining-drill to produce iron ore and output it
wait(10);
extract('iron-ore', (1, 0), count=1);
# Wait for the mining drill to produce iron ore and try again
wait(10);
extract('iron-ore', (1, 0), count=1);
# Move the burner-mining-drill to a better position for extracting iron ore
pickup((1, 0));
goto((22, -14));
# Move back to iron ore deposit
place('burner-mining-drill', 2, (1, 1));
inventory();
# Craft another burner-mining-drill since the first one was not in the inventory
craft('burner-mining-drill', count=1);
goto((22, -14));
# Move back to iron ore deposit
place('burner-mining-drill', 2, (1, 1));
# Move to a suitable position and place the burner-mining-drill
goto((23, -12));
place('burner-mining-drill', 2, (1, 0));
# Find an empty spot near the iron ore deposit and place the burner-mining-drill
goto((24, -12));
place('burner-mining-drill', 2, (1, 0));
# Try another spot near the iron ore deposit to place the burner-mining-drill
goto((22, -11));
place('burner-mining-drill', 2, (1, 0));
# Attempt to find an open spot to place the burner-mining-drill near the deposit
goto((21, -11));
place('burner-mining-drill', 2, (1, 0));
# Move to another location and try placing the burner-mining-drill
goto((20, -11));
