# First, let's gather some basic resources to start our factory
goto(nearest('coal'));
harvest((-2, 0), count=10);
goto(nearest('iron_ore'));
harvest((-2, 0), count=20);
goto(nearest('copper_ore'));
harvest((-2, 0), count=10);
goto(nearest('stone'));
harvest((-2, 0), count=10);
# Now, let's smelt some iron and copper plates.
craft('furnace', count=2);
# My apologies, let's craft a stone furnace instead
craft('stone-furnace', count=2);
# Place the stone furnaces to smelt iron ore and copper ore
place('stone-furnace', 0, (2, 0));
place('stone-furnace', 0, (2, 2));
# Insert the coal and ores into the furnaces
insert('coal', (2, 0), count=5);
insert('coal', (2, 2), count=5);
insert('iron_ore', (2, 0), count=10);
insert('copper_ore', (2, 2), count=5);
# Wait for the smelting process to complete
wait(30);
# Collect the smelted iron and copper plates
extract('iron-plate', (2, 0), count=10);
extract('copper-plate', (2, 2), count=5);
# Now let's craft some assembling machines, electronic circuits, and inserters
craft('assembling-machine-1', count=2);
# I apologize for the mistake. Let's create a setup that can produce assembling machines.
craft('inserter', count=6);
# I apologize once again. We need to set up automating inserter production.
craft('electronic-circuit', count=30);
