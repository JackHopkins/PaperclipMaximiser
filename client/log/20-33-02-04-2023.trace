# My strategy will be to gather resources, make transport belts, assemble smelters, and create a basic factory
inventory();
goto(nearest('tree'));
harvest((-2, 0), count=5);
goto(nearest('coal'));
harvest((-2, 0), count=5);
goto(nearest('copper_ore'));
harvest((-2, 0), count=5);
goto(nearest('iron_ore'));
harvest((-2, 0), count=5);
goto(nearest('stone'));
harvest((-2, 0), count=5);
inventory();
# I will use the acquired resources to create more transport belts and start assembling some smelting furnaces
craft('transport-belt', count=10);
craft('stone-furnace', count=3);
inventory();
# I'll place furnaces for iron, copper, and a chest to store coal, while connecting them with transport belts
place('stone-furnace', 0, (1,0));
# Iron Furnace
place('stone-furnace', 0, (1,3));
# Copper Furnace
place('iron-chest', 0, (1,6));
# Chest for Coal Storage
insert('coal', (1, 0), count=5);
# inserts 5 coal into  Iron Furnace
insert('coal', (1, 3), count=5);
# inserts 5 coal into Copper Furnace
insert('coal', (1, 6), count=20);
# inserts  20 coal into the chest
insert('iron-ore', (1, 0), count=25);
insert('copper-ore', (1, 3), count=22);
craft('transport-belt', count=10);
# My mistake. Let's set up an assembling machine to craft transport belts
place('assembling-machine-1', 0, (1,9));
set_recipe((1,9), 'transport-belt');
