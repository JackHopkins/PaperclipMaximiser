# Let's start by gathering iron ores and crafting iron plates using a furnace.
# Move to the iron ore
goto((22, -14));
# Harvest 20 iron ores
harvest((0,0), count=20);
# Move to Coal
goto((-17, -14));
# Harvest a few coal for fuel
harvest((0,0), count=5);
# Move to a safe location to build a furnace and smelt the iron ores
goto((0, 0));
# Check what's in the inventory
inventory();
# Place the stone-furnace
place('stone-furnace', 0, (1, 0));
# Insert iron-ore into the stone-furnace
insert('iron-ore', (1, 0), count=15);
# Insert coal into the stone-furnace
insert('
# coal', (1, 0), count=5);
wait(60);
# Extract the iron-plates from the stone-furnace
extract('iron-plate', (1, 0), count=15);
# It seems like the furnace didn't have any fuel. Let's add fuel to the stone-furnace.
insert('coal', (1, 0), count=5);
# Wait for the iron ores to smelt into iron-plates
wait(45);
# Extract the iron-plates from the stone-furnace
extract('iron-plate', (1, 0), count=15);
# Now let's use some iron plates to craft more transport-belts
craft('transport-belt', count=30);
# Check the inventory
inventory();
# Place an assembling-machine to craft transport-belts since it cannot be crafted by hand
place('assembling-machine-1', 0, (2,0));
# Set the recipe for the assembling-machine
set_recipe((2, 0), 'transport-belt');
