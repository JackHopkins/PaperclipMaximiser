set_recipe((5, 1), 'transport-belt');
# Insert iron plates and copper plates into the assembling-machine-1
insert('iron_plate', (5, 1), count=10);
# It seems like there was an issue with inserting the items. Let's try again by placing the assembling-machine-1 closer to your position.
pickup((5,1));
place('assembling-machine-1', 0, (1,1));
