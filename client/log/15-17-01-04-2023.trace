#  Initialize the area
nature();
# Gather nearby resources starting with coal
goto(nearest('coal'));
harvest((-2, 0), count=5);
# Then get iron ore
goto(nearest('iron_ore'));
harvest((-2, 0), count=5);
# Move on to stone
goto(nearest('stone'));
harvest((-2, 0), count=5);
# Next, collect copper ore
goto(nearest('copper_ore'));
harvest((-2, 0), count=5);
# Craft and place a furnace for smelting iron and copper ore
craft('stone_furnace', count=2);
place('stone_furnace', 0, (1,1));
place('stone_furnace', 0, (2,2));
# My apologies. Let's place the other stone_furnace at a different location.
place('stone_furnace', 0, (3,1));
# Now, insert iron and copper ores into the furnaces
insert('iron_ore', (1, 1), count=5);
insert('copper_ore', (3, 1), count=5);
# Wait for the furnaces to smelt the ores and then extract the plates
wait(30);
# Great! Now that we have resources in our inventory, let's build additional infrastructure.

Place an assembling-machine-1 and set its recipe to craft transport-belt.
