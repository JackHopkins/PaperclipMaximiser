# 5);
goto(nearest('stone'));
harvest((-2, 0), count=5);
# Move to the nearest tree
goto(nearest('tree'));
harvest((-2, 0), count=5);
# Set up initial infrastructure
# Create a furnace to smelt ores
craft('stone-furnace', count=1);
place('stone-furnace', 0, (1, 1));
insert('coal', (0, 1), count=1);
# Remove the tree in the way
harvest((1, 1), count=1);
# Place the stone-furnace again
place('stone-furnace', 0, (1, 1));
# Insert coal into the furnace
insert('coal', (0, 1), count=
# 1);
insert('iron_ore', (0, 1), count=5);
wait(20);
# Wait for the iron to smelt
extract('iron-plate', (0, 1), count=5);
# Insert coal into the furnace
insert('coal', (0, 1), count=1);
# Wait for the iron to smelt
wait(20);
extract('iron-plate', (0, 1), count=5);
# Craft a transport-belt to move resources
craft('transport-belt', count=5);
# Craft inserters to automate resource moving
craft('inserter', count=2);
# Let's make an assembling-machine-1 to craft some inserters
