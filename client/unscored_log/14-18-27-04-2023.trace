comment("First, let's inspect the resources around us")
inspect_resources()
comment("We can see that we have some iron ore at position (-8, -6)")
ore = (-8, -6)
comment("Now, let's move to the location of the iron ore and place a burner mining drill to extract it")
move_to(ore)
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore)
comment("We have successfully placed the burner mining drill. Now, let's inspect the entities around us")
inspect_entities(5)
comment("It looks like we don't have a burner mining drill in our inventory. Let's craft one now.")
craft_item('burner-mining-drill', quantity=1)
comment("We also received a warning about the burner mining drill we already placed. It seems to be out of fuel")
comment("Let's use the insert_item() function to add some coal to it")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=15)
