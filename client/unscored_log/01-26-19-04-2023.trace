# First, I want to check my surroundings and available resources
inspect_resources()
# Alright, I can see that I have coal, iron ore, copper ore, stone and uranium ore nearby. I'll move to the nearest coal source and mine some
move_to(nearest('coal'))
harvest_resource(nearest('coal'), quantity=5) 
# Oops, it looks like there's no coal within reach. I'll just place a mining drill on the nearest coal deposit instead.
# I'll move to the nearest coal resource, and place a mining drill to extract coal
coal_pos = nearest('coal')
move_to(coal_pos)
entity_position = place_entity('burner-mining-drill', position=(coal_pos[0]-2, coal_pos[1]), direction=LEFT)
# Finally, I'll connect the mining drill to a furnace using an inserter, so the coal can be used to smelt iron ore
furnace_pos = nearest('stone-furnace')
connect_entities(source_position=(entity_position[0]-2, entity_position[1]), target_position=furnace_pos, connection_type='inserter') 
# Hmm, looks like there's no stone furnace nearby. I'll need to craft one first.
# I'll craft a stone furnace and place it near the mining drill and then connect it to the mining drill using an inserter
craft_item('stone-furnace', quantity=1)
pos_to_place = (coal_pos[0]-2, coal_pos[1]-2)
place_entity('stone-furnace', direction=UP, position=pos_to_place)
connect_entities(source_position=(entity_position[0]-2, entity_position[1]), target_position=pos_to_place, connection_type='inserter')
# Ah, I forgot to collect stone. I'll move to the nearest stone deposit, harvest 10 stone and craft the furnace before placing it down and connecting it to the mining drill
stone_pos = nearest('stone')
move_to(stone_pos)
harvest_resource(stone_pos, quantity=10)
craft_item('stone-furnace', quantity=1)
pos_to_place = (coal_pos[0]-2, coal_pos[1]-2)
place_entity('stone-furnace', direction=UP, position=pos_to_place)
connect_entities(source_position=(entity_position[0]-2, entity_position[1]), target_position=pos_to_place, connection_type='inserter')
# Seems like there's no stone deposit nearby. I'll try to find a way to get stone from somewhere else
# I'll check my inventory to see if I have any stone. If not, I'll look for stone in the entities in the area
inventory = check_inventory()
if 'stone' not in inventory:
    entities = inspect_entities(10)
    for entity in entities:
        if 'stone' in entity:
            pos = entity['position']
            pickup_entity('stone', pos)
            break
