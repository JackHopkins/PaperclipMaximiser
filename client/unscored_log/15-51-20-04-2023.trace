# First, let me inspect the resources around me
inspect_resources()
# Based on the inspection, let's focus on coal extraction first
# Move to the nearest coal resource and place a burner mining drill
move_to(nearest('coal'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
# Oops, let's try that again but add inspect_entities first to ensure we are close enough to place the burner mining drill.
inspect_entities(5)
move_to(nearest('coal'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
