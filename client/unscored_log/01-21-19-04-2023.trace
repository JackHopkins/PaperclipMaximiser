# Updating the inspect_resources method to include the 'entities' variable
def inspect_resources():
    resources = {}
    for entity in entities:
        if entity['type'] in ['resource']:
            resources.setdefault(entity['name'], []).append(entity['position'])
    return resources
# Using the updated inspect_resources method to get the nearest resource type and location
