# Oops, I keep making errors. The issue is on the inspect_resources() method, it should return resources only and not the object dictionary as well. Updating the function accordingly.
def inspect_resources():
    resources = {}
    for entity in entities:
        if entity['type'] in ['resource']:
            resources.setdefault(entity['name'], []).append(entity['position'])
    return resources
