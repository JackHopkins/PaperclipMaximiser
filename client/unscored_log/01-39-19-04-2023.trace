# Firstly, let me check my surroundings and available resources
inspect_resources()
inspect_entities(20)
# Based on the observations, I will begin by creating a mining operation to extract coal
# I will now move to the location of the nearest coal deposit and place a burner-mining-drill to extract coal
# I have moved to the nearest coal resource and will now place a burner-mining-drill to extract coal
coal_position = nearest('coal')
move_to(coal_position)
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+1))
# I will now place a furnace next to the burner-mining-drill to process coal into better forms of fuel
furnace_position = place_entity_next_to('stone-furnace', reference_position=entity_position, direction=RIGHT, gap=1)
# Now, I will move to the nearest trees and harvest them to get wood
move_to(nearest('tree'))
harvest_resource(nearest('tree'), quantity=10)
# I will create a burner-inserter to put coal into the furnace and convert it into better fuel
inserter_position = place_entity_next_to('burner-inserter', reference_position=furnace_position, direction=RIGHT, gap=1)
connect_entities(source_position=entity_position, target_position=furnace_position, connection_type='inserter', input_output='output')
connect_entities(source_position=inserter_position, target_position=furnace_position, connection_type='inserter', input_output='input')
insert_item('coal', target_position=furnace_position, quantity=5)
# Sorry for that mistake, here is a corrected line that should connect the entities without issue
connect_entities(source_position=entity_position, target_position=furnace_position, connection_type='inserter')
connect_entities(source_position=inserter_position, target_position=furnace_position, connection_type='inserter')
insert_item('coal', target_position=furnace_position, quantity=5)
# It seems my placement for the furnace and burner-inserter was too close, and they are blocking each other. I will adjust the position to allow for proper connection
furnace_position = place_entity_next_to('stone-furnace', reference_position=entity_position, direction=RIGHT, gap=2)
inserter_position = place_entity_next_to('burner-inserter', reference_position=furnace_position, direction=RIGHT, gap=1)
connect_entities(source_position=entity_position, target_position=furnace_position, connection_type='inserter')
connect_entities(source_position=inserter_position, target_position=furnace_position, connection_type='inserter')
insert_item('coal', target_position=furnace_position, quantity=5)
# I see the issue, the position for the furnace is blocked by already existing entities. I will adjust the placement to a free area
furnace_position = place_entity_next_to('stone-furnace', reference_position=nearest('tree'), direction=UP, gap=2)
inserter_position = place_entity_next_to('burner-inserter', reference_position=furnace_position, direction=RIGHT, gap=1)
connect_entities(source_position=entity_position, target_position=furnace_position, connection_type='inserter')
connect_entities(source_position=inserter_position, target_position=furnace_position, connection_type='inserter')
insert_item('coal', target_position=furnace_position, quantity=5)
