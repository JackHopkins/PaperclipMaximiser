# First, let's observe the surrounding resources and entities
inspect_resources()
inspect_entities(20)
# We have access to coal, let's start with setting up a small coal mining operation
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 2:
    # Place a burner-mining-drill facing down, onto the nearest coal resource
    place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
    # Place a stone furnace next to the drill for smelting
    place_entity('stone-furnace', direction=RIGHT, position=(nearest('coal')[0] + 1, nearest('coal')[1]))
else:
    # Ensure drill is mining coal and furnace is smelting iron
    drill_pos = nearest('burner-mining-drill', items=['coal']) 
    if drill_pos:
        insert_item('coal', target_position=(drill_pos[0] + 1, drill_pos[1]))
    furnace_pos = nearest('stone-furnace', items=['iron-ore'])
    if furnace_pos:
        insert_item('iron-ore', target_position=(furnace_pos[0], furnace_pos[1] + 1))
        set_entity_recipe(furnace_pos, recipe='iron-plate')
# Oops, we need to check if there is space to place the burner-mining-drill before attempting to place it
if count_drills < 2:
    drill_pos = nearest('coal', entity_type='burner-mining-drill', distance=2, invert=True)
    if drill_pos is None:
        print("No space to place burner-mining-drill, clearing trees...")
        # Clear some trees and try again
        tree_pos = nearest('tree')
        if tree_pos:
            move_to(tree_pos)
            harvest_resource(tree_pos, quantity=5)
            rotate_entity((0, 0), direction=LEFT)
        drill_pos = nearest('coal', entity_type='burner-mining-drill', distance=2, invert=True)
    place_entity('burner-mining-drill', direction=DOWN, position=drill_pos)
    
    # Place a stone furnace next to the drill for smelting
    furnace_pos = (drill_pos[0] + 1, drill_pos[1])
    place_entity('stone-furnace', direction=RIGHT, position=furnace_pos)
    
else:
    # Ensure drill is mining coal and furnace is smelting iron
