# Command 1: Automate mining and smelting of iron ore
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-2, iron_ore_position[1]))
move_to((iron_ore_position[0], iron_ore_position[1] + 2))
place_entity('stone-furnace', direction=UP)
# Command 1: Let's inspect the surroundings before placing the burner-mining-drill
inspect_entities(5)
# Command 1: There's a stone furnace nearby that needs fuel and input materials. Let's check our inventory and try again
check_inventory()
iron_ore = check_inventory()['iron-ore']
coal = check_inventory()['coal']
if iron_ore >= 5 and coal >= 5:
    iron_ore_position = nearest('iron-ore')
    move_to(iron_ore_position)
    place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-2, iron_ore_position[1]))
    move_to((iron_ore_position[0], iron_ore_position[1] + 2))
    place_entity('stone-furnace', direction=UP)
    insert_item('iron-ore', quantity=5, target_position=(0, 1))
    insert_item('coal', quantity=5, target_position=(0, 0))
else:
    move_to(nearest('coal'))
    harvest_resource(nearest('coal'), quantity=10)
