comment("Inspect surroundings for resources")
resources = inspect_resources()
comment("Inspect nearby entities")
nearby_entities = inspect_entities(radius=20)
comment("Go to the nearest coal resource")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill at the coal resource")
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=coal_position)
comment("Inspect inventory")
inventory = inspect_inventory()
comment("Place a stone furnace next to the burner-mining-drill")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=LEFT)
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=burner_drill_position, quantity=1)
insert_item('coal', target_position=burner_drill_position, quantity=1)
comment("Harvest the coal from the burner-mining-drill")
harvest_resource(burner_drill_position, quantity=5)
comment("Insert coal into the stone furnace for fuel")
insert_item('coal', target_position=stone_furnace_position, quantity=1)
comment("Insert iron plates into the stone furnace to smelt")
insert_item('iron-plate', target_position=stone_furnace_position, quantity=5)
insert_item('iron-plate', target_position=stone_furnace_position, quantity=5)
comment("Place a transport belt next to the burner-mining-drill to make space for output")
place_entity('transport-belt', direction=LEFT, exact=False, position=(burner_drill_position[0]-2, burner_drill_position[1]))
move_to(burner_drill_position)
transport_belt_position = place_entity('transport-belt', direction=RIGHT, exact=True, position=(-7.5, -3.5))
comment("Check to ensure that transport-belt has been placed")
inspect_entities(5)
comment("Confirm burner-mining-drill is now operational since the transport-belt has been placed")
inspect_entities(5)
comment("Rotate the burner-mining-drill to connect it to the transport-belt")
rotate_entity(burner_drill_position, direction=RIGHT)
comment("Check if the burner-mining-drill is now operational")
inspect_entities(5)
comment("Correct orientation of transport belt to ensure smooth flow")
rotate_entity(transport_belt_position, direction=LEFT)
comment("Check if the transport-belt is no longer blocked and moving items")
