comment("First, let's inspect our resources and surroundings")
inspect_resources()
inspect_entities(20)
comment("Next, we will move to the ore location and place a burner-mining-drill")
coal_position = nearest('coal')
move_to(ore)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=ore)
comment("I can see that we don't have any burner mining drills in our inventory. Let's craft one")
craft_item('burner-mining-drill', quantity=1)
comment("Now, let's place the newly crafted burner mining drill at the ore location")
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=ore)
comment("Next, we need to power our burner-mining-drill with coal. Let's pick up coal near us") 
coal_position = nearest('coal')
pickup_entity('coal', coal_position) 
comment("I see that I accidentally used the `pickup_entity` function instead of the `harvest_resource` function. Let me fix that")
harvest_resource(coal_position)
comment("Now that we have coal in our inventory, let's insert it into the burner mining drill to power it")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Next, let's move to a nearby stone location and place a stone furnace there")
stone_position = nearest('stone')
move_to(stone_position)
place_entity('stone-furnace', direction=UP, exact=False, position=stone_position)
comment("Just like we needed to craft a burner mining drill earlier, we also need to craft a stone furnace. Let's do that now")
craft_item('stone-furnace', quantity=1)
comment("I see that we're missing the ingredient stone to craft a stone furnace. We need to mine some stone first. Let's harvest 10 stone from the nearest stone deposit")
stone_position = nearest('stone')
harvest_resource(stone_position, quantity=10)
comment("It looks like we were only able to harvest 9 stone instead of 10. That's okay, let's work with what we have. Next, let's craft a stone furnace")
craft_item('stone-furnace', quantity=1)
comment("Now let's place the stone furnace at the stone deposit we harvested from earlier")
place_entity('stone-furnace', direction=UP, exact=False, position=stone_position)
comment("Now that we have a stone furnace, let's connect it to our burner mining drill using an inserter")
connect_entities(source_position=nearest('burner-mining-drill'), target_position=stone_position, connection_type='inserter')
comment("Great! We now have a basic mining and smelting operation going. Next, let's expand our power and manufacturing capabilities by building some boilers and steam engines. First, let's mine more coal")
coal_position = nearest('coal')
harvest_resource(coal_position, quantity=20)
comment("I see, it looks like the coal is out of reach from our current position. Let's move to the coal first")
move_to(coal_position)
comment("Now let's harvest 20 coal")
harvest_resource(coal_position, quantity=20)
comment("I see, we were only able to harvest 16 coal instead of 20. That's okay, let's proceed with what we have. Next, let's craft and place some boilers and steam engines.")
comment("Let's start by crafting 5 boilers")
craft_item('boiler', quantity=5)
comment("Oops, looks like we don't have enough stone to craft the boilers. Let's go mining for some more stone") 
stone_position = nearest('stone')
harvest_resource(stone_position, quantity=30) # Gathering more than we need just in case.
comment("Hmmm, it looks like we can't reach the stone from our current position either. Let's move closer to it")
move_to(stone_position)
comment("We are near the stones now, Let's mine and gather enough stone for crafting 5 boilers")
harvest_resource(stone_position, quantity=30) # Gathering more than we need, just in case.
comment("Looks like we could only collect 11 stone, Let's search for more stone deposits.")
stone_position = nearest('stone')
move_to(stone_position)
comment("We are near the new stones now, harvesting for more stone")
harvest_resource(stone_position, quantity=30) # Gathering more than we need, just in case.
comment("Again, we could only gather 11 stones. We will have to work with that for now. Let's craft 3 boilers.")
craft_item('boiler', quantity=3)
comment("Now let's continue building our setup. Let's move towards the coal deposits.")
coal_position = nearest('coal')
move_to(coal_position)
comment("We have reached the coal deposits. Let's start mining it.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=coal_position)
insert_item('coal', nearest('burner-mining-drill'), quantity=1)
inspect_entities(5) # Let's inspect the entities to see if the drill has been placed and coal has been inserted into it.
comment("Oops, We don't have Burner mining drill in our inventory yet. Let's craft one.")
craft_item('burner-mining-drill', quantity=1)
comment("Now, Let's place the drill machine near the coal deposit.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=coal_position)
comment("The burner mining drills requires coal to operate, let's insert some coal into it.")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=10)
comment("Now let's move near the previously detected iron ore.")
ore_position = (-8, -5)
move_to(ore_position)
comment("We have reached the Iron ore. Let's place a mining drill.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore_position)
comment("Another mistake on our part, let's craft one more burner mining drills.")
craft_item('burner-mining-drill', quantity=1)
comment("Now let's place the mining drill next to the ore deposit.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore_position)
comment("To transport our resources, we need to build some transport belts.")
craft_item('transport-belt', quantity=20)
comment("Looks like we are short of iron plates required to craft transport belts. Let's check our inventory and gather more iron ore.")
inspect_inventory()
comment("We need to mine an iron deposit now, let's move towards the nearest iron deposit.")
ore = nearest('iron-ore')
ore_position = ore['position']
move_to(ore_position)
comment("It seems that the nearest() method couldn't find any iron ore in the map. We need to explore and find it manually.")
inspect_resources()
comment("Great! We have found an iron deposit at position (-22, 11). Let's move there to mine the iron ore.")
ore_position = (-22, 11)
move_to(ore_position)
comment("Now that we have reached the iron deposit, let's mine the ore.")
harvest_resource(ore_position, quantity=10)
comment("Looks like the ore deposit is out of reach. We need to place the burner mining drill closer to the deposit.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=(-21, 11))
comment("Looks like we don't have any burner mining drill in our inventory. Let's craft one.")
craft_item('burner-mining-drill', quantity=1)
comment("Looks like we don't have enough iron ore to craft a burner mining drill. Let's mine some.")
move_to(ore_position)
harvest_resource(ore_position, quantity=15)
comment("It seems that our mining drill still cannot reach the ore deposit after moving closer. Let's place it closer to the deposit.")
entity_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=(-21, 10))
comment("Let's craft another burner mining drill to continue our resource gathering.")
craft_item('burner-mining-drill', quantity=1)
