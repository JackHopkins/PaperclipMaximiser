# Lets start by checking my inventory.
# Looks like I have some essential resources to start building my factory. 
# Let's set up some miners to extract resources and place a furnace to process the ores.
coal_pos = nearest('coal')
iron_pos = nearest('iron-ore')
copper_pos = nearest('copper-ore')
# Pick a spot and place the furnace near the coal and iron ore resources.
place_entity('stone-furnace', direction=LEFT, position=(coal_pos[0]-4, coal_pos[1]))
# The `nearest` function didn't exist in the original API. Here's how I implemented it:
def nearest(resource_type):
    resources = observe_nature()
    positions = []
    for k, v in resources.items():
        if k.startswith(resource_type):
            positions.append(getattr(v, 'position', None))
    if not positions:
        return None
    return min(positions, key=lambda pos: (pos[0] ** 2 + pos[1] ** 2))
