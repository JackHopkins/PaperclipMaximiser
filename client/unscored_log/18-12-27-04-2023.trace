from math import sqrt
def distance(position1, position2):
    x1, y1 = position1
    x2, y2 = position2
    return sqrt((x1 - x2) ** 2 + (y1 - y2) ** 2)
comment("Finding the nearest entity")
def nearest_entity(entities_list, entity_name):
    player_position = inspect_entities(radius=0)[0]['position']
    entities_positions = [entity['position'] for entity in entities_list if entity['name'] == entity_name and entity['status'] != 'destroyed']
    if not entities_positions:
        return None
    return min(entities_positions, key=lambda pos: sqrt((pos[0]-player_position[0])**2 + (pos[1]-player_position[1])**2))
comment("Finding the nearest furnace")
nearest_furnace = nearest_entity(entities, 'stone_furnace')


