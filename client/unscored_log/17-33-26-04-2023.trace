comment("Observe and describe the natural resources and landscape around me")
resources = inspect_resources()
comment("Scan the environment for valuable resources to mine")
coal = nearest('coal')
iron_ore = nearest('iron_ore')
stone = nearest('stone')
copper_ore = nearest('copper_ore')
comment("Move to the coal resource, place a burner-mining-drill and provide it with fuel")
move_to(coal)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal)
pickup_entity('coal', coal)
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Check inventory for the resources required to craft a burner-mining-drill")
inventory = inspect_inventory()
comment("Craft a burner-mining-drill using available resources in the inventory")
craft_item('burner-mining-drill', quantity=1)
comment("Place the newly crafted burner-mining-drill at the coal resource")
move_to(coal)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal)
comment("Insert coal from the inventory into the burner-mining-drill for fuel")
insert_item('coal', target_position=nearest('burner-mining-drill'),  quantity=1)
comment("Set up a stone-furnace to smelt iron ore")
comment("Move to the iron_ore resource, place a burner-mining-drill and provide it with fuel")
move_to(iron_ore)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=iron_ore)
insert_item('coal', target_position=nearest('burner-mining-drill'),  quantity=1)
comment("Craft another burner-mining-drill for the iron_ore resource")
craft_item('burner-mining-drill', quantity=1)
comment("Harvest stone resource to acquire the missing ingredient")
move_to(stone)
harvest_resource(stone, quantity=5)
comment("Craft burner-mining-drill after acquiring the missing ingredient")
craft_item('burner-mining-drill', quantity=1)
comment("Place the newly crafted burner-mining-drill at the iron_ore resource")
move_to(iron_ore)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=iron_ore)
comment("Insert coal from the inventory into the burner-mining-drill for fuel")
insert_item('coal', target_position=nearest('burner-mining-drill'),  quantity=1)
comment("Place a stone-furnace adjacent to the burner-mining-drill at the iron_ore resource")
burner_drill_position = nearest('burner-mining-drill')
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=RIGHT, gap=1)
comment("Place a burner-mining-drill and a stone-furnace farther from each other. Change the direction to RIGHT.")
move_to(iron_ore)
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=iron_ore)
burner_drill_position = nearest('burner-mining-drill')
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=RIGHT, gap=1)
comment("Craft another burner-mining-drill")
move_to(stone)
harvest_resource(stone, quantity=5)
craft_item('burner-mining-drill', quantity=1)
comment("Place the newly crafted burner-mining-drill at the iron_ore resource again")
move_to(iron_ore)
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=iron_ore)
comment("Place a stone-furnace adjacent to the burner-mining-drill at the iron_ore resource")
burner_drill_position = nearest('burner-mining-drill')
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=RIGHT, gap=1)
comment("Try placing the stone-furnace farther to the right")
stone_furnace_position = place_entity('stone-furnace', direction=UP, position=(24, -5))
comment("Craft another stone-furnace")
move_to(stone)
harvest_resource(stone, quantity=5)
craft_item('stone-furnace', quantity=1)
comment("Place the newly crafted stone-furnace at (24, -5)")
stone_furnace_position = place_entity('stone-furnace', direction=UP, position=(24, -5))
comment("Load coal in the burner-mining-drill for fuel")
insert_item('coal', target_position=burner_drill_position, quantity=1)
coal_position = nearest('coal')
comment("Load coal in the stone-furnace for fuel")
insert_item('coal', target_position=stone_furnace_position, quantity=1)
comment("Move to coal_position and mine some more coal")
move_to(coal_position)
harvest_resource(coal_position, quantity=10)
inspect_inventory()
comment("Place the assembling-machine-1")
assembling_machine_1_position = place_entity('assembling-machine-1', direction=UP, position=(20, -3))
comment("Set the assembling-machine-1 to craft transport-belts")
set_entity_recipe(assembling_machine_1_position, recipe='transport-belt')
comment("Load iron plates into the assembling-machine-1")
insert_item('iron-plate', target_position=assembling_machine_1_position, quantity=10)
comment("Inspect inventory to check available iron plates")
inspect_inventory()
comment("Harvest nearby trees and collect more resources for the inventory")
tree_position = nearest('tree')
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
inspect_inventory()
comment("Move closer to the tree and try harvesting again")
move_to((tree_position[0]-3, tree_position[1]))
harvest_resource((tree_position[0]-3, tree_position[1]), quantity=5)
comment("Move to the nearest iron-ore patch")
iron_ore_position = nearest("iron-ore")
move_to(iron_ore_position)
comment("Place a burner-mining-drill at the iron-ore patch")
burner_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position, exact=False)
comment("Inspect inventory to check available resources for crafting a burner-mining-drill")
inspect_inventory()
comment("Craft a burner-mining-drill using available resources in the inventory")
craft_item('burner-mining-drill', quantity=1)
