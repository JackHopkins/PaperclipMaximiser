def pickup_entity(entity_type, position, quantity):
  for entity in inspect_entities(1):
    if entity.get("type") == entity_type and entity.get("position") == position:
      target_entity = entity
      break
    else: target_entity = None
      
  if target_entity:
    entity_inventory = target_entity.get("contents", {})
    items_in_inventory = sum(entity_inventory.values())
    if items_in_inventory >= quantity:
      carried_items = inspect_inventory()
      for item, count in entity_inventory.items():
        if count > 0:
          taking_items = min(count, quantity - items_in_inventory)
          global.actions.pickup_item(item, taking_items, target_entity.get("position"))
          if item in carried_items and carried_items[item] >= quantity:
            break
    else: 
      warn("Could not pickup. Desired quantity exceeds quantity available")
