# Start by inspecting the resources available and planning the next steps
inspect_resources()
# Great, we have coal, iron ore, copper ore, and stone. Now let's start with the mining operations to extract these resources.
# First, let's extract coal using a burner mining drill and load it into a furnace.
# Find the nearest coal resource
coal_resource_position = nearest('coal')
# Move to the coal resource and place a burner mining drill to extract coal
move_to(coal_resource_position)
burner_drill_position = place_entity("burner-mining-drill", direction=DOWN, position=(coal_resource_position[0], coal_resource_position[1] + 1))
# Let's build a simple set up to smelt the iron ore we mine using a stone furnace
# Find the nearest iron ore resource
iron_ore_position = nearest('iron-ore')
# Move to the iron ore resource, mine it and pick up the ore
move_to(iron_ore_position)
harvest_resource(iron_ore_position, quantity=5)
pickup_entity('iron-ore', iron_ore_position)
# My apologies. Let's harvest the iron ore instead
move_to(iron_ore_position)
harvest_resource(iron_ore_position, quantity=5)
pickup_entity('iron-ore', iron_ore_position)
# Move back to the burner drill to smelt the collected iron ore
move_to(burner_drill_position)
# Check if there is power available at burner drill to start smelting process
entities = inspect_entities(5)
if entities['burner-mining-drill']['energy'] > 0:
    # If power is available, insert the collected iron ore into the burner drill
    insert_item('iron-ore', target_position=burner_drill_position, quantity=5)
    # Wait 5 seconds for the burner drill to smelt the iron ore
    wait_time(5)
    # Extract the smelted iron plates from the burner drill to your inventory
    extract_item('iron-plate', source_position=burner_drill_position, quantity=5)
else:
    # Wait for power to become available
    wait_time(2)
