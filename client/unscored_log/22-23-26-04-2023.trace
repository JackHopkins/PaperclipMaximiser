insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Now let's move to our stone furnace with some coal and iron ores to smelt our iron plate.")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
harvest_resource(iron_ore_position, quantity=10)
comment("Ok, let's insert some coal into our miner drills and start our iron plate smelting.")
coal = inventory['coal']
if coal > 0:
    for entity in inspect_entities():
        if 'burner-mining-drill' in entity['name']:
            insert_item('coal', entity['position'], quantity=1)
    move_to(stone_position)
    craft_item('stone-furnace', quantity=1)
    furnace_position = place_entity_next_to('stone-furnace', furnace_position, DOWN, gap=1)
    connect_entities(source_position=nearest('burner-mining-drill'), target_position=furnace_position, connection_type='inserter')
    connect_entities(source_position=furnace_position, target_position=nearest('transport-belt'), connection_type='transport-belt')
    insert_item('iron-ore', furnace_position, quantity=10)
    entity_recipe = set_entity_recipe(furnace_position, recipe='iron-plate')

