comment("Let's pick up some coal near (-15, -14)")
pickup_entity('coal', (-15, -14))
comment("It seems there is no coal at (-15, -14), let's find the nearest coal deposit and pick it up")
closest_coal = nearest('coal')
move_to(closest_coal)
pickup_entity('coal', closest_coal, quantity=50)
comment("It seems that we don't have enough coal to satisfy our needs, let's harvest more coal and craft furnace to automate our iron plate process.")
closest_coal = nearest('coal')
move_to(closest_coal)
harvest_resource(closest_coal, quantity=10)
craft_item('stone-furnace', quantity=1)
comment("We seem to be out of stone, let's go and pick some up at (-15, 6)")
stone_position = (-15, 6)
move_to(stone_position)
pickup_entity('stone', stone_position, quantity=20)
comment("Ok, now let's move to our coal site at (-15,-14) and insert some coal into our burner drills.")
