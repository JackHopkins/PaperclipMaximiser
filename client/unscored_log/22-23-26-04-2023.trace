comment("Now let's craft 1 burner mining drill and place it on (-17, -14)") 
craft_item('burner-mining-drill', quantity=1)
move_to((-17, -14))
place_entity('burner-mining-drill', direction=DOWN, position=(-17, -14))
craft_item('burner-mining-drill', quantity=1) 
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=(-17, -14))
comment("Let's check to ensure the burner mining drill has been placed") 
