comment("Great! We have placed the stone furnace. Now let's connect the mining drill to the stone furnace using an inserter")
connect_entities(source_position=(-13,-15), target_position=(-16,-14), connection_type='inserter')
comment("My mistake. Let's first check if mining drill has been placed near (-13, -15) and is operational")
inspect_entities(5)
comment("Okay. So the drill is out of fuel, let's insert some coal from the inventory") 
comment("Insert 1 coal from your inventory into the nearest mining drill for fuel")
inventory = inspect_inventory()
if 'coal' in inventory and inventory['coal'] >= 1:
    coal_position = nearest('coal')
    move_to(coal_position)
    pickup_entity('coal', coal_position)
    target_position = nearest('burner-mining-drill')
    insert_item('coal', target_position=target_position, quantity=1)
else:
    comment("Sorry we do not have any coal in our inventory to refuel the burner-mining-drill.")
comment("Let me fix my previous error by using 'harvest_resource()' instead of 'pickup_entity()'.")
harvest_resource(coal_position, quantity=1)
comment("Now that we have coal, we will insert it into the mining drill ")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Now that our burner-mining-drill has fuel, let's check its status")
inspect_entities(5)
comment("Let's set the furnace and mining drill to mine and smelt iron ore from position (22, -12)")
comment("But before that we need to insert fuel to our furnace to start smelting")
