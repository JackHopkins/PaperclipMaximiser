comment("Let's harvest 5 iron ore using the burner-mining-drill at position (22,-12) after moving to that position")
harvest_resource(ore, quantity=5)
move_to(ore)
harvest_resource(ore, quantity=5)
comment("Now that we have 5 iron ore, let's craft 1 iron plate")
