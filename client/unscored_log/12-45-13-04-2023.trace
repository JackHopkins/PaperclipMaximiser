# Lets start by checking my inventory.
# Start by placing some drills and furnaces at the resources
coal_position = nearest('coal')
iron_position = nearest('iron_ore')
stone_position = nearest('stone')
copper_position = nearest('copper_ore')
uranium_position = nearest('uranium_ore')
place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', direction=2, position=(coal_position[0]+2, coal_position[1]))
insert_item('coal', target_position=coal_position, quantity=25)
# Forgot to craft the burner-mining-drill before placing it
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', direction=2, position=(coal_position[0]+2, coal_position[1]))
insert_item('coal', target_position=coal_position, quantity=25)
# I will try placing the burner-mining-drill and stone-furnace adjacent to the respective resources
place_entity('burner-mining-drill', direction=2, position=(coal_position[0]-1, coal_position[1]))
place_entity('stone-furnace', direction=2, position=(coal_position[0]+1, coal_position[1]))
insert_item('coal', target_position=(coal_position[0]-1, coal_position[1]), quantity=25)
