comment("Inspect the natural resources around me")
resources = inspect_resources()
comment("Find the nearest coal resource and move to its position")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Ensure the burner-mining-drill has been placed")
inspect_entities(5)
comment("Inspect the entities around me before placing the burner-mining-drill")
inspect_entities(5)
comment("Move to a valid position for placing the burner-mining-drill")
move_to((coal_position[0]+2, coal_position[1]))
comment("Place the burner-mining-drill on the coal resource again")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Ensure the burner-mining-drill has been placed")
inspect_entities(5)
comment("Inspect the entities around me again before placing the burner-mining-drill")
inspect_entities(5)
comment("Move closer to the coal resource before placing the burner-mining-drill")
move_to(coal_position)
comment("Place the burner-mining-drill on the coal resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+1, coal_position[1]))
comment("Ensure the burner-mining-drill has been placed")
inspect_entities(5)
comment("Place a stone furnace next to the burner-mining-drill to receive and smelt the coal")
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]+2, coal_position[1]))
comment("Inspect the entities in my surroundings before placing the stone-furnace")
inspect_entities(5)
comment("Since the environment is already inspected, move one step closer to the burner-mining-drill and attempt to place the stone-furnace again")
move_to((-7,-5))
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]+2, coal_position[1]))
comment("Ensure the stone-furnace has been placed")
inspect_entities(5)
comment("Move closer to the burner-mining-drill and inspect the environment again")
move_to((-6, -5))
inspect_entities(5)
comment("Now that I am closer, attempt to place the stone-furnace again")
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]+3, coal_position[1]))
comment("Ensure the stone-furnace has been placed")
inspect_entities(5)
comment("Place an inserter between the burner-mining-drill and the stone-furnace")
place_entity('inserter', direction=DOWN, position=(coal_position[0]+1, coal_position[1]))
comment("Ensure the inserter has been placed")
inspect_entities(5)
comment("Craft an inserter and place it between the burner-mining-drill and the stone-furnace")
craft_item('inserter', quantity=1)
place_entity('inserter', direction=DOWN, position=(coal_position[0]+1, coal_position[1]))
comment("Ensure the inserter has been placed")
inspect_entities(5)
comment("Inspect surroundings before placing the inserter")
inspect_entities(5)
comment("Place the inserter between the burner-mining-drill and the stone-furnace now that surroundings are inspected")
place_entity('inserter', direction=DOWN, position=(coal_position[0]+1, coal_position[1]))
comment("Ensure the inserter has been placed")
inspect_entities(5)
