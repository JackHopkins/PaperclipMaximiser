comment("Find coal and start with automating coal mining")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner mining drill on the coal patch, output facing right")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]-2, coal_position[1]))
comment("My apologies for the error. Let's try placing the burner-mining-drill again.")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal patch, output facing left")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("My apologies for the error. Let's try finding the nearest buildable position and placing the burner-mining-drill there.")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the nearest buildable position on the coal patch, output facing left")
drill_position = place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))

