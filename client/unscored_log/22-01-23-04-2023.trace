comment("First, let's inspect the resources and landscape to decide where to establish our base")
resources = inspect_resources()
comment("We need to start gathering resources, I'll look for the nearest coal resource")
coal_position = nearest('coal')
comment("Move to the coal position and place a burner-mining-drill to start gathering coal")
move_to(coal_position)
comment("Place the burner-mining-drill facing left")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Now let's find nearest iron resource")
iron_position = nearest('iron')
comment("Move to the iron position and place a burner-mining-drill to start gathering iron")
move_to(iron_position)
comment("Place the burner-mining-drill facing the right side")
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
comment("It seems there is no iron around. Let's find the nearest copper resource instead")
copper_position = nearest('copper')
comment("Move to the copper position and place a burner-mining-drill to start gathering copper")
move_to(copper_position)
comment("Place the burner-mining-drill facing the right side")
place_entity('burner-mining-drill', direction=RIGHT, position=(copper_position[0]+2, copper_position[1]))
comment("It seems there are no copper or iron resources nearby. Let's try to find the nearest stone resource instead")
stone_position = nearest('stone')
comment("Move to the stone position and place a burner-mining-drill to start gathering stone")
move_to(stone_position)
comment("Place the burner-mining-drill facing the right side")
place_entity('burner-mining-drill', direction=RIGHT, position=(stone_position[0]+2, stone_position[1]))
comment("It seems I don't have a burner-mining-drill in my inventory.")
comment("Let's check the inventory to see what items we have")
inventory = inspect_inventory()
comment("I'll start by setting up a coal generation system with coal-fired boilers and steam engines since we need power to automate resource extraction.")
comment("First let's craft a coal-fired boiler.")
comment("Craft a stone furnace, needed for the coal-fired boiler")
craft_item('stone-furnace', quantity=1)
comment("We don't have enough stone to craft a stone furnace.")
comment("Let's mine some stone manually before automating this process")
comment("Move the character to the nearest stone resource and harvest 5 units of stone")
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
comment("It seems there is no more stone to mine at this position.")
comment("Let's find another stone resource nearby")
nearest_stone = nearest('stone')
comment("Move to the new stone position")
move_to(nearest_stone)
comment("Now that we are at the new stone position, let's harvest 5 units of stone")
harvest_resource(nearest_stone, quantity=5)
comment("It seems there is no more stone to mine at this position either.")
comment("Let's try again with another stone resource nearby")
nearest_stone2 = nearest('stone', ignore_positions=[nearest_stone])
comment("Move to the new location")
move_to(nearest_stone2)
