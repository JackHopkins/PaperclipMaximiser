comment("Observe and describe the natural resources and landscape around me")
resources = inspect_resources()
comment("Inspect entities within a 20-meter radius around me")
entities = inspect_entities(20)
comment("Examine the items currently in my inventory")
inventory = inspect_inventory()
comment("Set up a coal mining operation")
coal_position = nearest('coal')
move_to(coal_position)
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
coal_ore_extracted = extract_item('coal', source_position=coal_drill_position, quantity=10)
insert_item('coal', target_position=coal_drill_position, quantity=1)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Set up a coal mining operation again")
coal_position = nearest('coal')
move_to(coal_position)
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
comment("Place a stone furnace for smelting iron")
iron_ore_position = nearest('iron_ore')
move_to(iron_ore_position)
furnace_position = place_entity('stone-furnace', exact=False, position=iron_ore_position)
comment("Craft a stone furnace")
craft_item('stone-furnace', quantity=1)
comment("Move to the position of the nearest stone")
move_to(nearest('stone'))
comment("Harvest 5 stones")
harvest_resource(here(), quantity=5)
