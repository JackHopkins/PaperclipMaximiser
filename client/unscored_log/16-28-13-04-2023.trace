# Lets start by checking my inventory.
# It seems we have some resources to start building our factory.
# First, let's place a few burner mining drills to extract the resources
# We will place 10 burner mining drills on each resource and some transport belts to connect them to our inventory
# Starting with coal
coal_positions = [(-16, -13), (-15, -13), (-14, -13), (-13, -13), (-12, -13), (-17, -12), (-16, -12), (-15, -12), (-14, -12), (-13, -12)]
for pos in coal_positions:
    place_entity('burner-mining-drill', position=pos, direction=4)
    move_to(pos, laying='transport-belt')
