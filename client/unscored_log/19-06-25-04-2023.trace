comment("First, let's inspect the resources and entities around us")
inspect_resources()
inspect_entities(20)
comment("Now let's start with a simple mining operation")
coal_position = nearest('coal')
iron_ore_position = nearest('iron-ore')
comment("Let's move to the nearest coal position and place a burner mining drill facing downwards")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("Next we will place a furnace near the coal deposit and smelt the coal")
furnace_position = place_entity_next_to('stone-furnace', reference_position=coal_position, direction=DOWN, gap=1)
comment("Now, let's add coal to the burner mining drill for fuel using the insert_item() method")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("We will now extract coal from the burner mining drill and insert it into the furnace for smelting using the connect_entities() method")
connect_entities(source_position=(coal_position[0]-2, coal_position[1]), target_position=furnace_position, connection_type='inserter')
