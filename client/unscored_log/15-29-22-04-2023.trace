# Inspect resources around me
resources = inspect_resources()
# Observe the landscape around me
landscape = inspect_resources()
# Inspect entities within a 20-meter radius around me
entities = inspect_entities(20)
# Inspect my inventory
inventory = inspect_inventory()
# Find the nearest coal resource
coal_position = nearest('coal')
# Move to the nearest coal resource to prepare for mining
move_to(coal_position)
# Place a burner-mining-drill to extract the coal
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
# Observe the surroundings before placing the burner-mining-drill
resources = inspect_resources()
# Place a burner-mining-drill to extract the coal
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
