comment("Place the stone furnace two tiles to the right of the coal mining drill")
furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_mining_drill_position, direction=RIGHT, gap=2)
comment("Find a new suitable location for the coal mining setup. Start by finding nearest coal deposit")
