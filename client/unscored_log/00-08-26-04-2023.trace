move_to(coal_position)
burner_mining_drill_position = place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', 1)
comment("Place a burner-mining-drill to mine coal")
move_to(coal_position)
burner_mining_drill_position = place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
