comment("Craft a new burner mining drill for the new coal operation")
craft_item('burner-mining-drill', 1)
comment("Place the burner mining drill on the new location and set up the coal operation again")
move_to(new_coal_position)
new_burner_mining_drill_position = place_entity('burner-mining-drill', direction=LEFT, exact=False, position=new_coal_position)
comment("Move back to the ore deposit")
move_to(ore)
comment("Place stone-furnace near the new coal mining setup")
furnace_position = place_entity_next_to('stone-furnace', reference_position=new_burner_mining_drill_position, direction=RIGHT, gap=2)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=new_burner_mining_drill_position, target_position=furnace_position, connection_type='inserter')
