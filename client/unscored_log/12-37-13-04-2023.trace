# Lets start by checking my inventory.
# Let's start by placing a burner-mining-drill at each resource location.
resources = [('coal', (-17, -14), (-8, -5)), ('iron_ore', (22, -14), (31, -5)), ('stone', (-17, 6), (-8, 15)), ('copper_ore', (22, 6), (31, 15)), ('uranium_ore', (22, 26), (31, 35))]
# Now let's build a basic production line for each resource.
for resource, position_1, position_2 in resources:
    # Place a burner-mining-drill
    drill_position = nearest(resource)
    place_entity('burner-mining-drill', direction=2, position=drill_position)
    
    # Move near to resource and lay transport-belt
    move_to((drill_position[0]-1, drill_position[1]), laying='transport-belt')
    
    # Place a stone-furnace next to the transport belt
    if resource in ['coal', 'iron_ore', 'copper_ore']:
        furnace_position = (drill_position[0]-2, drill_position[1])
        place_entity('stone-furnace', direction=2, position=furnace_position)
        # Insert coal into the furnace
        insert_item('coal', target_position=furnace_position, quantity=1)
# I need to craft burner-mining-drills for the resources
