# First, let's gather resources.
goto(nearest('tree'));
harvest((-2, 0), count=5);
goto((0, 10));
# Move to the resource area.
goto((22, -14));
# Move to the iron ore area
goto(nearest('iron_ore'));
harvest((-1, 0), count=5);
# Now, let's gather some coal
goto(nearest('coal'));
harvest((-1, 0), count=5);
# Now, let's gather some copper ore
goto(nearest('copper_ore'));
harvest((-1, 0), count=4);
# Let's gather stone
goto(nearest('stone'));
harvest((-1, 0), count=4);
# Now it's time to set up a production area.
goto((-50,0));
# Moving to a clear area for setting up productions.
place('stone-furnace', 0, (1,0));
insert('coal', (1, 0), count=1);
# insert('iron_ore',
# (1, 0), count=5); # insert the harvested iron ore
wait(30);
# wait 30 seconds for the furnace to smelt the iron ore
extract('iron-plate', (1, 0), count=5);
# pick up the produced iron-plates
# I realized I made a mistake by not inserting the iron ore into the stone furnace. Let me fix that.
insert('iron_ore', (1, 0), count=5);
wait(30);
# Extract the iron-plates after smelting
extract('iron-plate', (1, 
# 0), count=5);
craft('assembling-machine-1', count=1);
# Place the assembling machine 1
place('assembling-machine-1', 0, (3, 0));
# Set the recipe to craft iron gears

set_recipe((3, 0), 'iron-gear-wheel');
