# I want to start by inspecting the available resources
inspect_resources()
# There are various resources available, I want to begin extracting coal
coal_position = nearest('coal')
# Now that I have found the nearest coal, I can move to it and place a burner-mining-drill
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
# Let's try breaking up the command into separate parts
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
inspect_entities(5)
# Looks like we don't have any burner mining drills in our inventory, let's check
check_inventory()
# Let's craft a few burner mining drills
craft_item('burner-mining-drill', quantity=3)
# It looks like we need some stone to craft the burners, let's find some and try crafting again
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
# It seems we are not close enough to the stone resource. Let's move closer and try again
move_to((stone_position[0]-1, stone_position[1]))
harvest_resource((stone_position[0]-1, stone_position[1]), quantity=5)
# Now that we have stone, let's craft the burner mining drills
craft_item('burner-mining-drill', quantity=3)
# Let's set up our mining operation
coal_position = nearest('coal')
move_to(coal_position)
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1] + 2))
entity_position = place_entity_next_to('stone-furnace', reference_position=entity_position, direction=DOWN, gap=1)
connect_entities(source_position=(entity_position[0]-1, entity_position[1]), target_position=entity_position, connection_type='inserter')
# Let's inspect our surroundings before placing the burner-mining-drill
inspect_entities(10)
# It looks like there is already a burner mining drill placed at (-8, -12). Let's move there and inspect the setup.
move_to((-8, -12))
inspect_entities(5)
# Let's check our inventory before setting up our coal-powered system
check_inventory()
# Let's set up our coal-powered system
coal_position = nearest('coal')
move_to(coal_position)
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1] + 2))
entity_position = place_entity_next_to('stone-furnace', reference_position=entity_position, direction=DOWN, gap=1)
connect_entities(source_position=(entity_position[0]-1, entity_position[1]), target_position=entity_position, connection_type='inserter')
entity_position = place_entity_next_to('boiler', reference_position=(coal_position[0], coal_position[1] + 4), direction=UP, gap=1)
connect_entities(source_position=(entity_position[0], entity_position[1]-1), target_position=(entity_position[0]+1, entity_position[1]-1), connection_type='pipe')
connect_entities(source_position=(entity_position[0]+1, entity_position[1]), target_position=(entity_position[0]+1, entity_position[1]-1), connection_type='pipe')
entity_position = place_entity_next_to('steam-engine', reference_position=entity_position, direction=UP, gap=1)
connect_entities(source_position=entity_position, target_position=(entity_position[0], entity_position[1]-2), connection_type='inserter')
connect_entities(source_position=(entity_position[0], entity_position[1]-1), target_position=(entity_position[0]+1, entity_position[1]-1), connection_type='pipe')
