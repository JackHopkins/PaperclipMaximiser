# Lets start by checking my inventory.
# Great, I have some basic items that I can start with. I will set up a coal-powered factory to keep producing iron-gear-wheels.
# Finding the coal deposit nearest to current position
coal_position = nearest('coal')
# Checking my surroundings and resources
observe_nature()
# Inspecting the area around the coal deposit
inspect_radius(10)
# Since there are no obstructions or entity in the area, I will start setting up a coal-powered factory to produce iron-gear-wheels extensively
# Placing the mining drill on the coal deposit
place_entity('burner-mining-drill', direction=LEFT, position=coal_position)
# There seems to be an obstruction. I will inspect the position where the mining drill was supposed to be placed
inspect_radius(1)
# Since there are no entities within 1 meter radius, I will reduce the proximity to 0.5 meters instead, before retrying to place the mining drill
inspect_radius(0.5)
# Since there are no obstructions, I will try placing the mining drill again
place_entity('burner-mining-drill', direction=LEFT, position=coal_position)
# I will use a `while` loop to keep checking for any changes in the environment before retarting the mining drill placement process
while True:
    observe = observe_nature()
    if 'an obstruction' in observe:
        print('Waiting for obstruction to clear')
        continue
    place_entity('burner-mining-drill', direction=LEFT, position=coal_position)
    break
# It appears there is still an obstruction, so I will check the surroundings again
inspect_radius(1)
# Since there are no immediate obstructions, I will try again, but this time I will place the drill one tile down and retry laying the transport belts.
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0], coal_position[1]+1))
move_to((coal_position[0]-1, coal_position[0]+1), laying='transport-belt')
inspect_radius(20)
# It seems that we cannot place the mining drill because there is uranium ore in the way. We will need to mine the uranium ore first, and since we don't have the required technology yet, we will have to look for another coal source. I will move to the tree nearest to our current location, with the hope of finding coal on the way.
move_to(nearest('tree'))
inspect_radius(5)
# There seem to be no coal in the immediate vicinity. I will move to another direction to search for coal.
move_to((20, 0))
# It looks like I made a mistake in the previous move. Let's try moving to the same coordinates again.
move_to((20, 0))
inspect_radius(2)
