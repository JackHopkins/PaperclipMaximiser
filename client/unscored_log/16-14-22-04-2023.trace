comment("Identify nearby natural resources")
resources = inspect_resources()
comment("Locate closest coal resource")
coal_position = nearest('coal')
comment("Place a burner-mining-drill on the coal resource")
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Inspect the resources around me")
resources = inspect_resources()
comment("Find the nearest coal resource and move to its location")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill near coal resource")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Find the nearest stone resource and move to its location")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill near stone resource")
place_entity('burner-mining-drill', direction=LEFT, position=(stone_position[0]-2, stone_position[1]))
comment("Harvest some trees for wood to create more burner-mining-drills")
tree_position = nearest('tree')
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
comment("Find a location with more trees to harvest")
tree_position2 = move_to(nearest('tree', exclude_positions=[tree_position]))
harvest_resource(tree_position2, quantity=5)
comment("Find more trees to harvest in another way")
trees = inspect_entities(20, entity_type='tree')
move_to(trees[1]['position'])
harvest_resource(trees[1]['position'], quantity=5)
