# Investigate resources and surroundings
resources = inspect_resources()
entities = inspect_entities(20)
# Locate coal deposit
coal_position = nearest('coal')
# Move to the coal deposit and place a burner-mining-drill
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Check to ensure that the burner-mining-drill has been placed
inspect_entities(5)
# Move to the burner-mining-drill and insert some coal from inventory
move_to((-2, 0))
insert_item('coal', target_position=(-2, 0), quantity=1)
# Move to the nearest iron deposit and place a burner-mining-drill
iron_position = nearest('iron')
move_to(iron_position)
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
# Inspect the resources present on the map
inspect_resources()
# Move to the iron ore deposit and place a burner-mining-drill
iron_position = (22, -14)
move_to(iron_position)
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
# Check the inventory for materials required to craft a burner-mining-drill
inspect_inventory()
# Craft a burner-mining-drill using the available iron plates
craft_item('burner-mining-drill', quantity=1)
# Place the crafted burner-mining-drill at the iron ore deposit
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
# Move to the stone deposit and place a stone-furnace
stone_position = (-17, 6)
move_to(stone_position)
furnace_position = (stone_position[0]+2, stone_position[1])
place_entity('stone-furnace', position=furnace_position)

# Check inventory for stone furnace and stone
inspect_inventory()
# Craft a stone furnace from the available resources
craft_item('stone-furnace', quantity=1)
# Move to the nearest stone resource to mine it
move_to(nearest('stone'))
# Harvest 10 stones from the current location
harvest_resource(nearest('stone'), quantity=10)
# Craft a stone furnace from the stone collected
craft_item('stone-furnace', quantity=1)
# Move to the nearest coal resource to set up the mining drill
move_to(nearest('coal'))
# Place a burner-mining-drill on the nearest coal resource
place_entity('burner-mining-drill', direction=RIGHT, position=nearest('coal'))
# Find the nearest iron resource
move_to(nearest('iron-ore'))
# Harvest 5 iron ore from the current location
harvest_resource(nearest('iron-ore'), quantity=5)
# Craft a burner-mining-drill from harvested iron ore
craft_item('burner-mining-drill', quantity=1)
# Move to the nearest coal resource again
move_to(nearest('coal'))
# Place the crafted burner-mining-drill on the nearest coal resource
place_entity('burner-mining-drill', direction=RIGHT, position=nearest('coal'))
# Check available resources and entities around me
inspect_resources()
inspect_entities(20)
# Move to the second burner-mining-drill to place it correctly
move_to((32, -9))
# Place the crafted burner-mining-drill on the nearest coal resource
place_entity('burner-mining-drill', direction=RIGHT, position=nearest('coal'))
# Move to the nearest stone resource
move_to(nearest('stone'))
# Mine stone to create stone furnaces later
harvest_resource(nearest('stone'), quantity=10)
# Check inventory for harvested stone
inspect_inventory()
# Move to the nearest iron ore resource
move_to(nearest('iron-ore'))
# Place a burner-mining-drill on the nearest iron ore resource
place_entity('burner-mining-drill', direction=DOWN, position=nearest('iron-ore'))
# Craft a burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
# Place a burner-mining-drill on the nearest iron ore resource
place_entity('burner-mining-drill', direction=DOWN, position=nearest('iron-ore'))
# Insert coal into the burner-mining-drill to fuel it
insert_item('coal', target_position=(22, -5), quantity=1)
# Place a stone furnace near the burner-mining-drill
furnace_position = (22, -3)
place_entity('stone-furnace', position=furnace_position)
# Craft a stone furnace
craft_item('stone-furnace', quantity=1)
# Place the stone furnace near the burner-mining-drill
furnace_position = (22, -3)
place_entity('stone-furnace', position=furnace_position)
# Connect the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=(20, -5), target_position=furnace_position, connection_type='inserter')
# Inspect entities to find the correct position of the burner-mining-drill
inspect_entities(5)
# Connect the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=(-2.3984375, 0), target_position=furnace_position, connection_type='inserter')
# Move to the position of the burner-mining-drill
move_to((-2.3984375, 0))
# Connect the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=(-2.3984375, 0), target_position=furnace_position, connection_type='inserter')
# Inspect entities around me to get the furnace's position
inspect_entities(5)
# Update the furnace_position variable
furnace_position = (25, -3)
# Connect the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=(-2.3984375, 0), target_position=furnace_position, connection_type='inserter')
# Inspect entities within a 20-meter radius
inspect_entities(20)
# Find the correct position for the source entity (burner mining drill)
burner_drill_position = (-5, -9)
# Connect the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=burner_drill_position, target_position=furnace_position, connection_type='inserter')
# Inspect entities within a 5-meter radius around the burner-mining-drill
inspect_entities(5)
# Move closer to the burner-mining-drill's position
move_to(burner_drill_position)
# Retry connecting the burner-mining-drill's output to the stone-furnace's input using an inserter
connect_entities(source_position=burner_drill_position, target_position=furnace_position, connection_type='inserter')
# Check if the furnace_position is valid
print(furnace_position)
