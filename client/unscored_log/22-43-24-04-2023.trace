comment("Check available natural resources and landscape")
resources = inspect_resources()
print(resources)
comment("Locate coal, iron ore and trees")
coal_position = nearest('coal')
iron_ore_position = nearest('iron-ore')
tree_position = nearest('tree')
print(f"Coal: {coal_position}, Iron Ore: {iron_ore_position}, Tree: {tree_position}")
comment("Set up basic coal extraction")
move_to(coal_position)
comment("Place burner mining drill for coal")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Find stone resource")
stone_position = nearest('stone')
comment("Move to stone position")
move_to(stone_position)
comment("Mine some stone")
harvest_resource(stone_position, quantity=5)
comment("Check inventory")
inventory = inspect_inventory()
print(inventory)
