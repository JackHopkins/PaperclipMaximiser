# Inspect resources and landscape
resources = inspect_resources()
# Find the nearest coal deposit
coal_position = nearest('coal')
# Move to the coal deposit and place a burner-mining-drill
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]-2))
# Inspect entities around me to find the burner-mining-drill and ensure it's placed correctly
entities = inspect_entities(5)
# Find the nearest stone resource
stone_position = nearest('stone')
# Move to the stone resource and place a burner-mining-drill
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, position=(stone_position[0], stone_position[1]-2))
# Harvest stone and craft a burner-mining-drill
harvest_resource(stone_position, quantity=9)
craft_item('burner-mining-drill', quantity=1)
# Move to the stone resource and place the crafted burner-mining-drill
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, position=(stone_position[0], stone_position[1]-2))
# Inspect entities around me to ensure the surroundings are clear
entities = inspect_entities(5)
# Move to the stone resource and place the crafted burner-mining-drill after inspecting surroundings
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, position=(stone_position[0], stone_position[1]-2))
# Move to the coal resource and place a burner-mining-drill
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Pick up coal from the mined coal and insert it into the placed burner-mining-drill
pickup_entity('coal', (coal_position[0] - 2, coal_position[1]))
insert_item('coal', target_position=(coal_position[0] - 2, coal_position[1]), quantity=1)
# Harvest coal from the mined coal and insert it into the placed burner-mining-drill
harvest_resource((coal_position[0] - 2, coal_position[1]), quantity=1)
insert_item('coal', target_position=(coal_position[0] - 2, coal_position[1]), quantity=1)
# Move to the closest iron resource location and place a burner-mining-drill
iron_position = nearest('iron')
move_to(iron_position)
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0] + 2, iron_position[1]))
