# First, let's inspect the resources and entities around us
inspect_resources()
inspect_entities(20)
# Let's start by automating coal mining and power generation
# First, let's place a burner mining drill on the coal resource
move_to(nearest('coal'))
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
# Next, let's connect the burner mining drill to the nearby stone furnace using an inserter
connect_entities(source_position=entity_position, target_position=nearest('stone-furnace'), connection_type='inserter')
# Let's first get the position of the stone furnace and try again
inspect_entities(20)
furnace_position = nearest('stone-furnace')
connect_entities(source_position=entity_position, target_position=furnace_position, connection_type='inserter')
