comment("First, let's inspect our surroundings to see what resources are available to us")
inspect_resources()
comment("According to the map, we have an ore patch available at (-8, -5)")
ore = (-8, -5)
comment("Next, let's move to the ore patch, mine the ore, and put it in a nearby chest")
move_to(ore)
harvest_resource(ore, quantity=50)
move_to((ore[0]-2, ore[1]))
entity_position = place_entity('iron-chest', direction=UP, position=(ore[0]-2, ore[1]))
insert_item('iron-ore', target_position=entity_position, quantity=50)
comment("Okay, so we can only harvest 13 ore. Let's move to the nearest buildable position and place a burner-mining-drill there")
nearest_position = nearest_buildable_position(ore, item="burner-mining-drill")
entity_position = place_entity("burner-mining-drill", direction=UP, exact=False, position=nearest_position)


comment("Sorry, I made a mistake! Let's build the mining drill at -5,-5 because there's a coal patch there")
move_to((-5,-5))
place_entity('burner-mining-drill', direction=UP, position=(-5,-5))
comment("The drill is out of fuel now, let's refuel it")
nearest_entity = nearest_entity_type('coal', position=(-5,-5))
move_to(nearest_entity["position"])
extract_item('coal', nearest_entity["position"], quantity=50)
move_to((-5,-5))
insert_item('coal', nearest_entity["position"], quantity=10)
comment("Oops, looks like we don't have any burner mining drills in our inventory. Let's craft one and place it at -5,-5")
craft_item('burner-mining-drill',quantity=1)
move_to((-5,-5))
drill_position = place_entity('burner-mining-drill',direction=DOWN)
comment("Great! Now the mining drill has been placed.")
comment("Let's insert coal into the mining drill for fuel")
insert_item('coal', target_position=drill_position, quantity=1)
from random import randint
coal_position = nearest('coal')
if not coal_position:
    comment("Cannot find any coal nearby...")
else:
    move_to(coal_position)
    pickup_entity('coal', coal_position)
    coal_quantity = inspect_inventory().get('coal', 0)
    if coal_quantity:
        insert_item('coal', target_position=drill_position, quantity=1)
    else:
        comment("Couldn't find any coal to insert into the drill. Maybe we should prospect for more coal?")
