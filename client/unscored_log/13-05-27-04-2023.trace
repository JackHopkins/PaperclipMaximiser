    comment("Placing transport-belt")
    # Check if there is a direct path to the new position
    if direct_path(entity['position'], target_position):
        # Move to the target position
        move_to(target_position)
        # Place the transport-belt
        place_entity('transport-belt', position=target_position)
        # Update the inventory
        inventory['transport-belt'] -= 1
        entities = inspect_entities()
        for entity in entities:
            if entity['name'] == 'transport-belt' and entity['position'] == target_position:
                entity['quantity'] += 1
                break
    # If there is no direct path, lay transport-belts along a longer route
    else:
        lay_transport_belts(entity['position'], target_position)
else:
    warning("Target position is not free, cannot place transport-belt")


