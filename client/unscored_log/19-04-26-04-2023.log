def is_buildable(position):
    """
    This function checks if a tile at a given 'position' is buildable or not.
    A tile is buildable if there's no water, trees, rocks or entities blocking it.
    """
    x, y = position
    if has_entity(position):
      return False
    for obj in inspect_entities_within_radius_of_position(position, 1):
        if obj['type'] in ['tree', 'rock', 'fish'] or obj['name'] == 'water':
            return False
    return True
