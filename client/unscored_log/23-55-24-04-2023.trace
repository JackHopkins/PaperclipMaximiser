comment("Inspect the resources around me")
resources = inspect_resources()
comment("Find the nearest coal resource")
coal_position = nearest('coal')
comment("Move to the coal resource")
move_to(coal_position)
comment("Place a burner-mining-drill facing LEFT for coal extraction")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Move to the provided coordinates (-10, -5)")
move_to((-10, -5))
comment("Inspect the entities around me")
entities = inspect_entities(20)
