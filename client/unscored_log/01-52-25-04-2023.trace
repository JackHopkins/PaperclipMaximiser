comment("It seems there's no building at location (0, 0). Let's search the area for any assembling machine")
assembling_machine_position = None
entities = inspect_entities(10)
for entity in entities:
    if entity['name'] == 'assembling-machine-1':
        assembling_machine_position = entity['position']
        break
        
if assembling_machine_position:
    comment(f"Found an assembling machine at {assembling_machine_position}. Let's set its recipe to boiler")
    set_entity_recipe(assembling_machine_position, recipe='boiler')
else:
    comment("Oh no, we couldn't find any assembling machine to craft the boiler. Let's craft it manually")
    craft_item('boiler', quantity=1)
comment("Let's move towards the water source first")
