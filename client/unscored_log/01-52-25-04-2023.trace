comment("Now we need to place a boiler at the water source, facing right")
move_to(water_position)
boiler_position = place_entity('boiler', direction=RIGHT, position=nearest_buildable('boiler'))
comment("Next, we need to place a steam engine to the right of the boiler, facing right")
steam_engine_position = place_entity_next_to('steam-engine', reference_position=boiler_position, direction=RIGHT, gap=1)
comment("Finally, we need to connect the boiler and steam engine using pipes and inserters")
connect_entities(source_position=boiler_position, target_position=steam_engine_position, connection_type='pipe')
connect_entities(source_position=boiler_position, target_position=steam_engine_position, connection_type='inserter')

