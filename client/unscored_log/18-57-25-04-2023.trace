comment("First, let's inspect our surroundings and available resources")
inspect_resources()
inspect_entities(20)
comment("Next, let's start with a simple mining operation. We need some coal to start with.")
comment("Move to the nearest coal resource and pick up 10 coal")
coal_position = nearest('coal')
move_to(coal_position)
harvest_resource(coal_position, quantity=10)
comment("Now that we have some coal, let's place a burner-mining-drill on the coal resource.")
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Next, let's inspect our inventory and make sure we have coal.")
inspect_inventory()
comment("Great, we have some coal now. Let's place a stone furnace and smelt our coal into iron plates.")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
place_entity('stone-furnace', direction=LEFT, position=nearest_buildable('stone-furnace'))
comment("Let's check if the furnace is complete and in the inventory")
inspect_inventory()
comment("Now we harvest some iron ore and have the furnace smelt it into iron plates.")
harvest_resource(iron_ore_position, quantity=5)
insert_item('iron-ore', target_position=nearest('stone-furnace'), quantity=5)
set_entity_recipe(nearest('stone-furnace'), recipe='iron-plate')
