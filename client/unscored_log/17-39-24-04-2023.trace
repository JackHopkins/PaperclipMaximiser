comment("Observe and describe the natural resources around")
resources = inspect_resources()
comment("Inspect the current inventory")
inventory = inspect_inventory()
comment("Create coal fired boilers and steam engines for power generation")
comment("Place a burner-mining-drill on coal")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0] - 2, coal_position[1]))
comment("Find and move to the nearest stone resource")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill on stone and output into chest")
place_entity('burner-mining-drill', direction=UP, position=(stone_position[0], stone_position[1] - 2))
place_entity('wooden-chest', direction=UP, position=(stone_position[0], stone_position[1] - 1))
comment("Craft a burner-mining-drill and a wooden chest")
craft_item('burner-mining-drill', quantity=1)
craft_item('wooden-chest', quantity=1)
comment("Find nearest tree, harvest 5 wood, and craft a wooden chest")
tree_position = nearest('tree')
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
craft_item('wooden-chest', quantity=1)
comment("Find another tree, harvest 5 wood, and craft a wooden chest")
tree_position = nearest('tree', exclude_positions=[tree_position])
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
craft_item('wooden-chest', quantity=1)
comment("Find another tree, harvest 1 wood, and craft a wooden chest")
tree_position = nearest('tree', exclude_positions=[tree_position])
move_to(tree_position)
harvest_resource(tree_position, quantity=1)
craft_item('wooden-chest', quantity=1)
comment("Place a burner-mining-drill on stone and output into chest")
place_entity('burner-mining-drill', direction=UP, position=(stone_position[0], stone_position[1] - 2))
place_entity('wooden-chest', direction=UP, position=(stone_position[0], stone_position[1] - 1))
comment("Inspect surroundings and entities before placing burner-mining-drill and wooden chest")
inspect_resources()
inspect_entities(10)
stone_position = nearest('stone')
move_to(stone_position)
place_entity('burner-mining-drill', direction=UP, position=(stone_position[0], stone_position[1] - 2))
place_entity('wooden-chest', direction=UP, position=(stone_position[0], stone_position[1] -1))
comment("Refine positioning of burner-mining-drill and wooden chest output")
stone_position = (-17, 13)
move_to(stone_position)
place_entity('burner-mining-drill', direction=UP, position=(stone_position[0], stone_position[1] - 1))
place_entity('wooden-chest', direction=UP, position=(stone_position[0], stone_position[1] + 1))
comment("Craft a burner-mining-drill and rerun the previous action")
craft_item('burner-mining-drill', quantity=1)
comment("Harvest 5 stone to craft a burner-mining-drill")
harvest_resource(stone_position, quantity=5)
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=UP, position=(stone_position[0], stone_position[1] - 1))
place_entity('wooden-chest', direction=UP, position=(stone_position[0], stone_position[1] + 1))
comment("Retrieve stone from inventory")
extract_item('stone', source_position=nearest('stone'), quantity=5)
comment("Find nearest coal and setup a burner-drill and wooden chest")
inspect_resources()
inspect_entities(20)
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=UP, position=(coal_position[0], coal_position[1] - 2))
place_entity('wooden-chest', direction=UP, position=(coal_position[0], coal_position[1] - 1))
comment("Craft a burner-mining-drill and wooden chest")
craft_item('burner-mining-drill', quantity=1)
craft_item('wooden-chest', quantity=1)
comment("Place the crafted burner-mining-drill and wooden chest near the coal")
place_entity('burner-mining-drill', direction=UP, position=(coal_position[0], coal_position[1] - 2))
place_entity('wooden-chest', direction=UP, position=(coal_position[0], coal_position[1] - 1))
comment("Inspect surroundings and try placing wooden chest again")
inspect_entities(5)
place_entity('wooden-chest', direction=RIGHT, position=(coal_position[0] + 1, coal_position[1]))
comment("Insert coal into newly placed burner-drill to start mining")
inspect_inventory()
pickup_entity('coal', coal_position)
insert_item('coal', target_position=(-17, -7), quantity=1)
comment("Harvest coal and insert it into the newly placed burner-drill")
harvest_resource(coal_position, quantity=5)
insert_item('coal', target_position=(-17, -7), quantity=1)
comment("Move closer to coal, harvest, and insert into the burner-drill")
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
insert_item('coal', target_position=(-17, -7), quantity=1)
comment("Extract coal from another mining drill and insert it into the newly placed burner-drill")
extract_item('coal', source_position=(-17, 13), quantity=1)
insert_item('coal', target_position=(-17, -7), quantity=1)
comment("Place a wooden chest next to the coal drill to store output")
place_entity('wooden-chest', direction=RIGHT, position=(coal_position[0] + 2, coal_position[1]))
comment("Craft a wooden chest")
craft_item('wooden-chest', quantity=1)
comment("Place the crafted wooden chest next to the coal drill to store output")
place_entity('wooden-chest', direction=RIGHT, position=(coal_position[0] + 2, coal_position[1]))
