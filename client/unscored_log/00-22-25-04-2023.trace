move_to(nearest_iron_ore_position)
comment("Try placing the burner-mining-drill in various directions again")
successful_placement = False
for direction in directions:
    try:
        place_entity('burner-mining-drill', direction=direction, position=nearest_iron_ore_position)
        successful_placement = True
        break
    except ValueError:
        continue

if not successful_placement:
