# Let's start by setting up mining for coal, iron ore, stone, and copper ore.
goto((10, -10));
# Move near the coal patch
place('burner-drill', 2, (0, 1));
# Apologies for the error. Let me try again.
goto((-10, -10));
# Move near the coal patch
place('burner-mining-drill', 2, (0, 1));
# We need to craft a burner-mining-drill first
craft('burner-mining-drill', count=1);
inventory();
# Great, we have a burner-mining-drill in our inventory. Let's place it near the coal patch now.
goto((-10, -10));
place('burner-mining-drill', 2, (0, 1));
# -
insert('coal', (0, 1), count=1);
# Inserts 1 coal into the burner-mining-drill
craft('iron-chest', count=1);
# My apologies, we need to craft an iron chest later when we have the necessary items. Let's continue setting up the burner-mining-drill.
place('iron-chest', 2, (2, 1));
# Place the iron-chest to store the coal
extract('coal', (0, 1), count=5);
# Let's wait a bit for the burner-mining-drill to mine coal.
wait(10);
extract('coal', (0, 1), count=5);
# Let's wait a bit longer for the burner-mining-drill to mine coal.
wait(30);
# It seems like the burner-mining-drill isn't mining coal as expected. Let's make sure it's properly placed and has fuel.
goto((-10, -10));
place('burner-mining-drill', 2, (0, 1));
# It appears we need to craft another burner-mining-drill.
craft('burner-mining-drill', count=1);
# We seem to be missing the necessary materials. Let's try to find and mine some nearby resources.
craft('iron-axe', count=1);
# I apologize for the confusion. We will have to manually mine resources for now.
goto(nearest('coal'));
harvest((-2, 0), count=10);
goto(nearest('stone'));
harvest((-2, 0), count=10);
goto(nearest('iron_ore'));
harvest((-2, 0), count=10);
inventory();
# Now that we have some coal, stone, and iron ore, let's try to craft the burner-mining-drill again.
craft('burner-mining-drill', count=1);
inventory();
# Great, we have a burner-mining-drill in our inventory. Let's place it near the coal patch now.
goto((-10, -10));
place('burner-mining-drill', 2, (0, 1));
# My apologies, it seems there's already a burner-mining-drill in that location. Let's fuel it and wait for coal.
insert('coal', (0, 1), count=1);
wait(30);
extract('coal', (0, 1), count=5);
place('iron-chest', 2, (2, 1));
# My apologies, let's craft an iron chest first and then place it.
craft('iron-chest', count=1);
place('iron-chest', 2, (2, 1));
craft('iron-chest', count=1);
place('iron-chest', 2, (2, 1));
# I apologize for the mistake. Let's try placing another iron chest in a different location.
craft('iron-chest', count=1);
place('iron-chest', 2, (2, 2));
# Let's put the coal in the chest and work on refining iron ore.
insert('coal', (0, 1), count=5);
place('burner-mining-drill', 2, nearest('iron_ore'));
# Let's find another suitable location for the burner-mining-drill near iron ore.
goto(nearest('iron_ore', exclude=(0, 1)));
# I apologize for the confusion. Let's try manually adjusting our location near the iron ore patch.
goto((40, 25));
