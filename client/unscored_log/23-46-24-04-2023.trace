comment("Find and move to the nearest coal deposit")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill, facing down")
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1] - 2))
comment("Pick up coal near (-8, -7)")
pickup_entity('coal', (-8, -7))
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(coal_position[0], coal_position[1] - 2), quantity=1)
comment("Harvest 5 coal from the coal deposit at (-8, -7)")
harvest_resource((-8, -7), quantity=5)
comment("Insert 1 coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(coal_position[0], coal_position[1] - 2), quantity=1)
comment("Find and move to the nearest iron ore deposit")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
comment("Place a burner-mining-drill facing down to extract the iron ore")
place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_position[0], iron_ore_position[1] - 2))
comment("Place a stone furnace below the burner-mining-drill")
stone_furnace_position = (iron_ore_position[0], iron_ore_position[1] - 4)
place_entity('stone-furnace', position=stone_furnace_position)
comment("Check current inventory")
inventory = inspect_inventory()
comment("Check the number of burner-mining-drill in inventory")
burner_drill_count = inventory.get('burner-mining-drill', 0)
comment("Check the number of burner-mining-drill in inventory")
burner_drill_count = inventory.get('burner-mining-drill', 0)
burner_drill_count
comment("Check the number of burner-mining-drill in inventory")
burner_drill_count = inventory.get('burner-mining-drill', 0)
comment("Craft a burner-mining-drill if there are none in the inventory")
if burner_drill_count == 0:
    craft_item('burner-mining-drill', quantity=1)
comment("Check the number of burner-mining-drill in inventory")
burner_drill_count = inventory['burner-mining-drill']
comment("Craft a burner-mining-drill if there are none in the inventory")
if burner_drill_count == 0:
    craft_item('burner-mining-drill', quantity=1)
comment("Retry placing a burner-mining-drill facing down to extract the iron ore")
place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_position[0], iron_ore_position[1] - 2))
comment("Place a stone furnace below the burner-mining-drill")
stone_furnace_position = (iron_ore_position[0], iron_ore_position[1] - 4)
place_entity('stone-furnace', position=stone_furnace_position)
comment("Check the number of stone-furnace in inventory")
stone_furnace_count = inventory.get('stone-furnace', 0)
comment("Craft a stone-furnace if there are none in the inventory")
if stone_furnace_count == 0:
    craft_item('stone-furnace', quantity=1)
comment("Retry placing a stone furnace below the burner-mining-drill")
