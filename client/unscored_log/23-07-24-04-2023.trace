comment("Check the surrounding resources and landscape")
resources = inspect_resources()
comment("Find the nearest coal deposit")
coal_position = nearest('coal')
comment("Move to the coal_deposit and place a burner-mining-drill facing LEFT")
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Find the nearest iron ore deposit")
iron_ore_position = nearest('iron-ore')
comment("Move to the iron ore deposit and place a burner-mining-drill facing LEFT")
move_to(iron_ore_position)
iron_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-2, iron_ore_position[1]))
comment("Craft a burner-mining-drill to place at the iron ore deposit")
craft_item('burner-mining-drill', quantity=1)
comment("Move to the iron ore deposit and place the burner-mining-drill facing LEFT")
move_to(iron_ore_position)
iron_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-2, iron_ore_position[1]))
comment("Find another suitable buildable position to place the burner-mining-drill at the iron ore deposit")
iron_drill_position = nearest_buildable('burner-mining-drill', position=iron_ore_position)
comment("Move to the buildable position and place the burner-mining-drill facing LEFT")
move_to(iron_drill_position)
iron_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=iron_drill_position)
comment("Try placing the burner-mining-drill on the iron ore deposit directly")
move_to(iron_ore_position)
iron_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_position)
comment("Refuel the burner-mining-drills for coal and iron")
pickup_entity('coal', coal_position, quantity=2)
insert_item('coal', target_position=burner_drill_position, quantity=1)
insert_item('coal', target_position=iron_drill_position, quantity=1)
comment("Craft a stone furnace to smelt iron ore")
craft_item('stone-furnace', quantity=1)
comment("Place the stone furnace near the iron drill output")
furnace_position = (iron_drill_position[0]-2, iron_drill_position[1])
place_entity('stone-furnace', direction=DOWN, position=furnace_position)
comment("Connect the iron drill output to stone furnace input using an inserter")
insert_position = (iron_drill_position[0]-2, iron_drill_position[1])
place_entity('inserter', direction=DOWN, position=insert_position)
