comment("Observe and describe the resources and landscape around me")
resources = inspect_resources()
comment("Check my inventory")
inventory = inspect_inventory()
comment("Locate the nearest coal deposit")
coal_position = nearest('coal')
comment("Move to the coal deposit")
move_to(coal_position)
comment("Place a burner-mining-drill on the coal deposit")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Check to ensure that burner-mining-drill has been placed")
inspect_entities(5)
comment("Find the nearest buildable position for the burner-mining-drill")
buildable_position = nearest_buildable('burner-mining-drill', target_resource='coal')
comment("Move to the buildable position")
move_to(buildable_position)
comment("Place the burner-mining-drill on the buildable position")
place_entity('burner-mining-drill', direction=RIGHT, position=buildable_position)
comment("Check to ensure that the burner-mining-drill has been placed")
inspect_entities(5)
comment("Pick up some coal")
pickup_entity('coal', (-4+len(inventory), -4))
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(-8, -4), quantity=1)
comment("Inspect entities to check burner-mining-drill status")
inspect_entities(5)
comment("Harvest some coal")
harvest_resource((-4+len(inventory), -4), quantity=5)
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(-8, -4), quantity=1)
comment("Inspect entities to check burner-mining-drill status")
inspect_entities(5)
comment("Find a coal position to harvest")
coal_harvest_position = nearest_harvestable('coal')
comment("Move to the coal position to harvest")
move_to(coal_harvest_position)
comment("Harvest some coal")
harvest_resource(coal_harvest_position, quantity=5)
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(-8, -4), quantity=1)
comment("Inspect entities to check burner-mining-drill status")
inspect_entities(5)
comment("Find a coal position to harvest using the nearest function")
coal_harvest_position = nearest('coal')
comment("Move to the coal position to harvest")
move_to(coal_harvest_position)
comment("Harvest some coal")
harvest_resource(coal_harvest_position, quantity=5)
comment("Insert coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=(-8, -4), quantity=1)
comment("Inspect entities to check burner-mining-drill status")
inspect_entities(5)
comment("Find the nearest buildable position for a stone furnace")
buildable_position_furnace = nearest_buildable('stone-furnace')
comment("Move to the buildable position for the stone furnace")
move_to(buildable_position_furnace)
comment("Place the stone furnace")
place_entity('stone-furnace', position=buildable_position_furnace)
comment("Check to ensure that the stone furnace has been placed")
inspect_entities(5)
