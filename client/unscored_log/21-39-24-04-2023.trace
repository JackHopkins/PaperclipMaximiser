comment("Inspect natural resources around")
resources = inspect_resources()
print(resources)
comment("Locate the nearest 'coal' resource")
coal_position = nearest('coal')
print(coal_position)
comment("Move to the coal position and place a burner-mining-drill directed to the left")
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Check the inventory for available items")
inventory = inspect_inventory()
print(inventory)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Place the crafted burner-mining-drill at the coal position")
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Locate the nearest wood resource")
wood_position = nearest('wood')
print(wood_position)
comment("Locate the nearest tree resource")
tree_position = nearest('tree')
print(tree_position)
comment("Move to the tree and harvest 5 wood")
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
inventory = inspect_inventory()
print(inventory)
comment("Find another tree and try harvesting wood again")
tree_position = nearest('tree', exclude=tree_position)
move_to(tree_position)
harvest_resource(tree_position, quantity=5)
inventory = inspect_inventory()
print(inventory)
comment("I will now set up a basic power generating system using coal-fired boilers and steam engines.")
comment("Locate the nearest coal resource")
coal_position = nearest('coal')
print(coal_position)
comment("Move to the coal resource and place a burner-mining-drill facing down")
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]))
print(burner_drill_position)
comment("Craft 1 burner-mining-drill and place it on the coal resource")
craft_item('burner-mining-drill', quantity=1)
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]))
print(burner_drill_position)
comment("Find nearest stone resource and mine 5 stones")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
comment("Craft 1 burner-mining-drill and place it on the coal resource now that we have enough stones")
craft_item('burner-mining-drill', quantity=1)
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]))
print(burner_drill_position)
comment("Pick up 2 coals to fuel the burner-mining-drill")
harvest_resource(coal_position, quantity=2)
comment("Insert 1 coal into the burner-mining-drill")
insert_item('coal', target_position=burner_drill_position, quantity=1)
comment("Find nearest iron resource and mine 15 iron")
iron_position = nearest('iron')
move_to(iron_position)
harvest_resource(iron_position, quantity=15)
comment("Craft a stone furnace and place it near iron resource to process the smelting")
craft_item('stone-furnace', quantity=1)
stone_furnace_position = place_entity('stone-furnace', direction=LEFT, position=(iron_position[0] - 2, iron_position[1]))
comment("Find nearest stone resource and mine 10 stones")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=10)
comment("Craft a stone furnace with the harvested stone")
craft_item('stone-furnace', quantity=1)

comment("Place stone furnace near the iron resource to process the smelting")
stone_furnace_position = place_entity('stone-furnace', direction=LEFT, position=(iron_position[0] - 2, iron_position[1]))
comment("Place a burner-mining-drill next to the stone furnace to extract from the iron resource and insert into the furnace")
burner_drill_position = place_entity_next_to("burner-mining-drill", reference_position=stone_furnace_position, direction=LEFT, gap=1)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(burner_drill_position[0]-1, burner_drill_position[1]), target_position=stone_furnace_position, connection_type='inserter')

comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(burner_drill_position[0]-1, burner_drill_position[1]), target_position=stone_furnace_position, connection_type='inserter')
comment("Retry connecting the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(burner_drill_position[0]-1, burner_drill_position[1]), target_position=stone_furnace_position, connection_type='inserter')
comment("Assuming the inserter connection was successful, let's build a basic power setup.")
comment("Find the nearest water source")
water_position = nearest('water')
comment("Move to the water source and place an offshore pump")
move_to(water_position)
offshore_pump_position = place_entity("offshore-pump", direction=UP, position=(water_position[0], water_position[1]))
comment("Craft an offshore pump")
craft_item("offshore-pump", quantity=1)
comment("Place the crafted offshore pump near water")
move_to(water_position)
offshore_pump_position = place_entity("offshore-pump", direction=UP, position=(water_position[0], water_position[1]))
comment("Inspect surroundings near water source")
water_surroundings = inspect_resources()
water_surroundings
comment("Find a suitable position near the water source to place offshore pump")
suitable_position = (water_position[0] + 2, water_position[1])
comment("Place the offshore pump at the suitable position")
move_to(suitable_position)
offshore_pump_position = place_entity("offshore-pump", direction=UP, position=(suitable_position[0], suitable_position[1]))
comment("Inspect nearby entities before placing offshore pump")
nearby_entities = inspect_entities(5)
nearby_entities
comment("Move closer to the water and try placing the offshore pump again")
closer_position = (suitable_position[0], suitable_position[1] - 1)
move_to(closer_position)
offshore_pump_position = place_entity("offshore-pump", direction=UP, position=(closer_position[0], closer_position[1]))
