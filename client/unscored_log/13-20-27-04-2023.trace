comment("First, let's inspect our surroundings and available resources")
inspect_resources()
inspect_entities()
comment("We also need to define the position of the mining deposit we want to utilize for this automation")
ore = (-8, -5)
comment("Our first task is to set up a mining drill to extract ore")
move_to(ore)
place_entity('burner-mining-drill', direction=DOWN, position=ore)
comment("Now, let's connect the drill to a stone furnace so the ore can be smelted into iron plates")
furnace = nearest('stone-furnace')
connect_entities(source_position=(ore[0], ore[1]+2), target_position=furnace, connection_type='inserter')
comment("Next, we need a chest to store the iron plates")
chest_position = (ore[0], ore[1]-2)
place_entity('iron-chest', direction=UP, position=chest_position)
comment("Now we can insert the smelted iron plates from the furnace to the chest")
connect_entities(source_position=furnace, target_position=chest_position, connection_type='inserter')
comment("Oops, it looks like we don't have any burner-mining-drills in our inventory. Let's craft some.")
craft_item('burner-mining-drill')
comment("Now, let's set up our mining drill")
move_to(ore)
place_entity('burner-mining-drill', direction=DOWN, position=ore)
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=5)
Coal = nearest('coal')
move_to(Coal)
pickup_entity('coal', Coal)
move_to(ore)
place_entity('burner-mining-drill', direction=DOWN, position=ore)
comment("It seems like there is no coal entity nearby. Let's check available entities first")
entities = inspect_entities()
print(entities)
comment("From the entities list, we can identify the position of available coal deposits around the player character. Let's use the nearest function")
Coal = nearest('coal')
move_to(Coal)
pickup_entity('coal', Coal)
comment("It looks like we have a full output for the burner mining drill. We need to create some space. Let's place an iron chest that we can later use to transport our resources")
iron_chest_position = move_to((Coal[0], Coal[1]+2))
place_entity('iron-chest', position=iron_chest_position)
comment("It seems like the positioning of the player was at fault, let's correct it before we proceed")
move_to((Coal[0], Coal[1]+10))
comment("We can connect the output of the mining drill to the iron chest placed earlier")
position = nearest('burner-mining-drill')
connect_entities(source_position=(position[0]+1, position[1]), target_position=iron_chest_position, connection_type='inserter')
comment("It looks like the iron_chest is not within the range of the source_position. Let's move the chest closer first")
iron_chest_position = move_to((position[0]+1, position[1]))
place_entity('iron-chest', position=iron_chest_position)
connect_entities(source_position=(position[0]+1, position[1]), target_position=iron_chest_position, connection_type='inserter')
comment("Let's craft and place a burner inserter to move the mining drill output into the chest.")
craft_item('burner-inserter', 1)
position_inserter = nearest('burner-mining-drill')
place_entity('burner-inserter', position=position_inserter, direction=RIGHT)
output_position = (position_inserter[0]+1, position_inserter[1])
input_position = (iron_chest_position[0]+0.5, iron_chest_position[1]+0.5)
connect_entities(source_position=output_position, target_position=input_position, connection_type='inserter')
comment("We also need to keep the fuel supply of burner-inserter to keep it running. Let's extract coal from the chest and provide it to the burner-inserter")
extract_item('coal',source_position=iron_chest_position,quantity=1)
insert_item('coal',target_position=position_inserter,quantity=1)
comment("Next, place a coal powered steam engine to keep things running")
steam_engine_position = move_to((-10,-6))
place_entity('steam-engine', position=steam_engine_position)
comment("Let's inspect our inventory first to determine if we have the necessary resources")
inspect_inventory()
comment("Also, let's check our environment.")
inspect_resources()
comment("Seems like we need to gather more iron ore. Let's move to the nearest iron ore deposit and harvest it.")
move_to(nearest('iron-ore'))
harvest_resource(nearest('iron-ore'), quantity=50)
comment("Let's go back and empty our inventory at the iron chest.")
move_to(iron_chest_position)
insert_item('iron-ore', target_position=iron_chest_position, quantity=inventory()['iron-ore'])
insert_item('coal', target_position=iron_chest_position, quantity=inventory()['coal'])
comment("My apologies, let's try to check our inventory again.")
inspect_inventory()
comment("Let us check inventory once again.")
inspect_inventory()
comment("Our inventory is full. Let's go back to base and put our resources into an iron chest.")
move_to(iron_chest_position)
insert_item('iron-ore', target_position=iron_chest_position, quantity=50)
insert_item('copper-ore', target_position=iron_chest_position, quantity=50)
comment("It seems we have not yet assigned the variable `iron_chest_position` to the position of the iron chest. Let's find it and assign it a variable.")
chest_entity = [entity for entity in inspect_entities() if entity['name'] == 'iron-chest'][0]
iron_chest_position = chest_entity['position']
comment("Now that we have located the iron chest at {}.".format(iron_chest_position))
comment("Let's go back to base and put our resources into an iron chest.")
move_to(iron_chest_position)
insert_item('iron-ore', target_position=iron_chest_position, quantity=50)
comment("Let us inspect the entities around the burner-mining-drill at (-6, -9) to find out why it is blocking. ")
entities = inspect_entities(2)
for entity in entities:
    if entity['position'] in [(-8.5,-4.5),(-9.5,-4.5)]:
        if entity['name'] in ['transport-belt', 'stone-furnace']:
            continue
        else:
            # remove entity if it is not a belt or furnace
            remove_entity(entity['position'])
    elif entity['position'] == (-6,-9):
        if entity['name'] != 'burner-mining-drill':
            # remove entity if it is blocking the burner-mining-drill
            remove_entity(entity['position'])
entities = inspect_entities(radius=1)
for entity in entities:
    if entity['position'] == (-6, -9):
        print(entity)
    elif entity['position'] == (-8.5, -4.5):
        print(entity)
comment("It looks like the output of the burner-mining-drill at (-6, -9) is blocked because the output is full. We need to unblock it by placing a transport-belt or furnace at (-8.5, -4.5).")
comment("Let's place a transport-belt at position (-8.5,-4.5) to unblock the output of the burner-mining-drill at (-6, -9).")
place_entity('transport-belt', position=(-8.5, -4.5))
comment("Looks like we encountered an error. Let's inspect the entities at (-8.5,-4.5) to see why we could not place the transport-belt.")
entities = inspect_entities(radius=1, position=(-8.5, -4.5))
for entity in entities:
    print(entity)
comment("Let's check our backpack to see what items we have available to place the transport-belt")
inventory = inspect_inventory()
print(inventory)
comment("We have 49 transport-belts in our inventory. Let's place one at (-8, -5).")
place_entity('transport-belt', (-8, -5))
comment("Our burner-mining-drill at (-6,-9) is out of fuel. Let's insert a coal manually.")
inventory = inspect_inventory()
if "coal" in inventory and inventory["coal"] > 0:
    insert_item('coal', target_position=(-6, -9), quantity=1)
else:
    comment("We don't have enough coal to refuel the burner-mining-drill.")
comment("Let's place a burner inserter to refuel the burner mining drill at (-6,-9).")
place_entity('burner-inserter', position=(-5, -9), direction=LEFT)
comment("We don't have burner-inserter in our inventory. Let's craft one using the recipe in our backpack and place it near the burner mining drill.")
craft_item("burner-inserter", quantity=1)
inventory = inspect_inventory()
if "burner-inserter" in inventory and inventory["burner-inserter"] > 0:
    entity_position = place_entity('burner-inserter', position=(-5, -9), direction=LEFT)
else:
    comment("We don't have enough resources to craft a burner-inserter.")
comment("Let's place a chest and insert 5 coal into it, so the burner-inserters near both the burner-mining-drill and the stone furnace can use it to fuel the machine.")
place_entity('iron-chest', position=(-7, -5))
inventory = inspect_inventory()
if "coal" in inventory and inventory["coal"] > 0:
    insert_item('coal', target_position=(-7, -5), quantity=5)
else:
    comment("We don't have enough coal to insert into the chest.")
comment("Let's place a chest and insert 5 coal into it, so the burner-inserters near both the burner-mining-drill and the stone furnace can use it to fuel the machine.")
place_entity("wooden-chest", position=(-6, -5))
insert_item('coal', target_position=nearest('wooden-chest'), quantity=5)
comment("We don't have wooden chest in our inventory. Let's craft a wooden chest using the recipe in our backpack and place it at (-6, -5).")
craft_item("wooden-chest", quantity=1)
inventory = inspect_inventory()
if "wooden-chest" in inventory and inventory["wooden-chest"] > 0:
    place_entity("wooden-chest", position=(-6, -5))
    inventory = inspect_inventory()
    insert_item("coal", target_position=nearest('wooden-chest'), quantity=5)
comment("We don't have wood in our inventory. Let's move to the nearest tree and harvest it.")
move_to(nearest('tree'))
harvest_resource(source_position=nearest('tree'),quantity=5)
comment("We need to specify the position where we want to place wooden chest. Let's craft a wooden chest and place it at (-6, -5).")
craft_item("wooden-chest", quantity=1)
place_entity("wooden-chest", position=(-6, -5))
comment("We need to gather wood first.")
move_to(nearest('tree'))
harvest_resource(source_position=nearest('tree'),quantity=5)
comment("We need to specify the position of the tree that we want to chop down. Let's chop down the nearest tree to get wood.")
tree_position = nearest('tree')
move_to(tree_position)
harvest_resource(source_position=tree_position, quantity=5)
comment("Now that we have gathered some wood, let's craft a wooden chest and place it at (-6, -5).")
craft_item("wooden-chest", quantity=1)
place_entity('wooden-chest', position=(-6, -5))
comment("Let's craft some wooden boards.")
move_to(nearest('tree'))
craft_item('wood', quantity=10)
comment("We have to first craft some wooden boards from wood. Let's obtain some wood first.")
wood_position = nearest('tree')
move_to(wood_position)
harvest_resource(source_position=wood_position, quantity=10)
comment("Now that we have some wooden boards, let's craft a wooden chest and place it at (-6, -5).")
craft_item("wooden-chest", quantity=1)
move_to((-6,-5))
place_entity('wooden-chest', position=(-6,-5))
comment("Let's craft some wooden boards from the wood in our inventory.")
craft_item('wood', quantity=10)
comment("Oh, I see we don't have the recipe for crafting wood into wooden boards. Let's fix that first.")
comment("Place an assembling machine at (-6,-5) and set its recipe to 'wood' to craft wooden boards.")
assembling_machine_position = place_entity('assembling-machine-1', direction=LEFT, position=(-6, -5))
set_entity_recipe(assembling_machine_position, recipe='wood')
comment("Now that we can craft wooden boards, let's craft a wooden chest and place it at (-6, -5).")
craft_item("wooden-chest", quantity=1)
chest_position = (-6, -5)
place_entity('wooden-chest', direction=LEFT, position=chest_position)
comment("Let's gather some more wood first.")
wood_position = nearest('tree')
move_to(wood_position)
harvest_resource(wood_position, quantity=10)
comment("We only managed to gather 3 wood. Let's pick some wood that's already on the ground instead.")
wood_position = nearest('wood', exact=False)
move_to(wood_position)
pickup_entity('wood', wood_position, quantity=10)
comment("Let's check our inventory to see if we have some wood.")
inventory = inspect_inventory()
if inventory.get('wood', 0) >= 5:
    comment("We have enough wood in our inventory, let's craft a wooden chest.")
    craft_item('wooden-chest', quantity=1)
    
    comment("Place the wooden chest at (-6, -5) using a burner-inserter.")
    chest_position = (-6, -5)
    entity_position = place_entity('burner-inserter', direction=LEFT, position=assembling_machine_position)
    
    comment("Insert one wooden chest into the burner-inserter.")
    insert_item('wooden-chest', target_position=entity_position, quantity=1)
    
    comment("Connect the output of the burner-inserter to the wooden chest using another burner-inserter.")
    output_position = (chest_position[0] - 1, chest_position[1])
comment("We don't have any burner inserters in inventory. Let's craft one first.")
craft_item('burner-inserter',quantity=1)
comment("Now that we have a burner inserter, we can use it to refuel the other entities and get them working again.")
inventory = inspect_inventory()
if inventory.get('coal', 0) > 0:
    for entity in inspect_entities():
        if entity['type'] == 'burner-mining-drill' or entity['type'] == 'burner-inserter':
            insert_item('coal', quantity=10, target_position=entity['position'])
elif inventory.get('wood', 0) > 0:
    for entity in inspect_entities():
        if entity['type'] == 'burner-mining-drill' or entity['type'] == 'burner-inserter':
            insert_item('wood', quantity=10, target_position=entity['position'])
comment("We are out of coal. Let's go mining some.")
mine_position = nearest('coal', exact=False)
move_to(mine_position)
harvest_resource(mine_position,quantity=10)
comment("Now that we have coal in the inventory, let's use it to refuel the entities.")
inventory = inspect_inventory()
if inventory.get('coal', 0) > 0:
    for entity in inspect_entities():
        if entity['name'] == 'burner-mining-drill':
            insert_item('coal', target_position=entity['position'], quantity=1)
        elif entity['name'] == 'burner-inserter':
            insert_item('coal', target_position=entity['position'], quantity=1)            
    comment("Entities refueled")
comment("Let's move to the burner mining drill and insert some coal to refuel it.") 
