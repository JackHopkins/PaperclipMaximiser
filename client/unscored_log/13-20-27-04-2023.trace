connect_entities(source_position=steam_engine1_position, target_position=(0,0), connection_type='electric_pole')
connect_entities(source_position=steam_engine2_position, target_position=(0,0), connection_type='electric_pole')
comment("I made a mistake, the source for the connection should be electric pole, Let's place one near the steam engines and connect them")
place_entity('medium-electric-pole', position=(1, 2))
connect_entities(source_position=(1, 2), target_position=(0, 0), connection_type='electric_pole')
comment("I don't have the medium electric pole in my inventory, let's craft one")
craft_item('medium-electric-pole', quantity=1)
comment("Looks like I am out of coal again, let's pick some from the nearest coal.")
pickup_entity('coal', nearest('coal'), quantity=20)
comment("My mistake, the pickup_entity() function doesn't have quantity parameter. Let's pick up as much coal as we can.")
pickup_entity('coal', nearest('coal'))
comment("Oops, I used the wrong function, I should use the harvest_resource() function instead since it's a resource and not an entity to be picked up")
harvest_resource(nearest('coal'), quantity=20)
comment("Let's refuel the nearby inserter first.")
insert_item('coal',target_position=(nearest('burner-inserter')), quantity=5)
Comment("Now that the inserter is refueled, let's fix the electricity issue. I will place down another steam engine to help generate more power.")
