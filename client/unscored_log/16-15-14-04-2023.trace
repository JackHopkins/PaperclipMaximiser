# Lets start by checking my inventory.
# Setting variables for the resources position
coal_position = (-17, -14)
iron_ore_position = (22, -14)
stone_position = (-17, 6)
copper_ore_position = (22, 6)
uranium_ore_position = (22, 26)
# Place a burner mining drill on the coal patch and fill it with coal
place_entity('burner-mining-drill', direction=RIGHT, position=coal_position)
insert_item('coal', target_position=coal_position, quantity=1)
# Now, place a stone furnace next to the iron ore patch and fill it with coal
place_entity('stone-furnace', direction=UP, position=(iron_ore_position[0], iron_ore_position[1] - 1))
insert_item('coal', target_position=(iron_ore_position[0], iron_ore_position[1] - 1), quantity=1)
# Place a burner mining drill on the iron ore patch and fill it with coal
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position)
insert_item('coal', target_position=iron_ore_position, quantity=1)
# It seems there was an error due to lack of a burner-mining-drill in the inventory.
# Let's move to the coal and mine some to make a burner-mining-drill.
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
# Now that we have mined additional coal, let's craft a burner-mining-drill and place it on the iron ore patch.
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position)
insert_item('coal', target_position=iron_ore_position, quantity=1)
# It looks like I need more stone to craft the burner-mining-drill.
# Let's move to the stone patch and mine 5 stone.
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
# Now with the required resources, let's craft a burner-mining-drill and place it on the iron ore patch.
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position)
insert_item('coal', target_position=iron_ore_position, quantity=1)
# Let's recalculate the position of the burner-mining-drill and place it again.
iron_ore_drill_position = (iron_ore_position[0] - 1, iron_ore_position[1])
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_drill_position)
insert_item('coal', target_position=iron_ore_drill_position, quantity=1)
# Let's move the existing stone furnace and try again.
pickup_entity((iron_ore_position[0], iron_ore_position[1] - 1))
iron_ore_drill_position = (iron_ore_position[0] - 1, iron_ore_position[1])
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_drill_position)
insert_item('coal', target_position=iron_ore_drill_position, quantity=1)
# I must have misunderstood the position of the existing stone furnace.
# Let's try to clear a spot near the iron ore for the burner-mining-drill.
move_to((iron_ore_position[0] - 2, iron_ore_position[1]))
pickup_entity((iron_ore_position[0], iron_ore_position[1] - 1))
iron_ore_drill_position = (iron_ore_position[0] - 1, iron_ore_position[1])
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_drill_position)
insert_item('coal', target_position=iron_ore_drill_position, quantity=1)
place_entity('stone-furnace', direction=UP, position=(iron_ore_position[0] - 1, iron_ore_position[1] - 2))
insert_item('coal', target_position=(iron_ore_position[0] - 1, iron_ore_position[1] - 2), quantity=1)
# We must reevaluate the positioning again.
# Before proceeding, let's observe our current surroundings.
inspect_radius(20)
# Based on the inspections of the surroundings, let's correct the positions and place the burner-mining-drill near the iron ore patch.
iron_ore_drill_position = (-37, 0)
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_drill_position)
insert_item('coal', target_position=iron_ore_drill_position, quantity=1)
place_entity('stone-furnace', direction=UP, position=(2, -1))
insert_item('coal', target_position=(2, -1), quantity=1)
# It seems the burner-mining-drill and stone-furnace were already placed correctly.
# Let's proceed with inserting iron ore into the stone-furnace and crafting iron-gear-wheels.
# Move to the iron ore drill, extract iron ore, and insert it into the stone furnace
move_to(iron_ore_drill_position)
extract_item('iron-ore', source_position=iron_ore_drill_position, quantity=1)
insert_item('iron-ore', target_position=(2, -1), quantity=1)
