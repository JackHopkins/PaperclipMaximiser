comment("Create function to move to entities assigning name according to their position")
def move_to_position(position):
    move_to(position)
    entity = inspect_entities()
    position_entity = entity[0]["position"] 
    while position_entity != position:
        move_to(position) 
        entity = inspect_entities()
        position_entity = entity[0]["position"]
    return
def move_to_entity(name):
    position_entity = None
    for entity in inspect_entities():
        if entity['name'] == name:
            position_entity = entity['position']
            break
    print(f"Moving to {name} at {position_entity}")
    move_to(position_entity)
comment("Move to stone furnace")
move_to_entity('stone-furnace')
comment("Refuel furnace with coal from inventory")
for entity in inspect_entities():
    if entity['name'] == 'stone-furnace':
        furnace_position = entity['position']
        break
else:
    print("Error: Furnace not found")
    furnace_position = None
