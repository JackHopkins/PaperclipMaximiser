for resource, details in resources.items():
    comment(f"Found {resource} at {details['min_coordinates']}")
    if resource == 'coal':
        quantity = details['size']
        pickup_entity(resource, details['min_coordinates'])
    elif resource == 'iron_ore':
        ore = details['min_coordinates']
        harvest_resource(ore, quantity=10)
comment("We used the wrong variable name when accessing the resource details. Let's fix it.")
