comment("First, let's inspect our surroundings and inventory")
inspect_resources()
inspect_inventory()
comment("Now let's start our mining operation. We'll begin by placing a burner mining drill on top of a coal resource.")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("Next, we will set up a simple smelting setup near our coal deposit using two stone furnaces.")
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('stone-furnace', direction=RIGHT, position=nearest_buildable('stone-furnace'))
stone_furnace_position = entity_position
place_entity_next_to('stone-furnace', reference_position=stone_furnace_position, direction=RIGHT, gap=1)
move_item('stone', source_position=iron_position, target_position=stone_furnace_position, quantity=5)
set_entity_recipe(stone_furnace_position, recipe='iron-plate')
