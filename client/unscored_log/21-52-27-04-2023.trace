            insert_item('coal', target_position=drill['position'], quantity=1)
            print(f"Inserting fuel into {drill['name']} at {drill['position']}")
        elif drill['items']['output'] == drill['size']['output']:
            print(f"Warning: {drill['name']} at {drill['position']}: waiting for space in destination as the output is full. Place a transport-belt or furnace at (22.5, -3.5) to unblock.")
