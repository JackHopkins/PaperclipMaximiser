for drill in active_mining_drills:
    name = drill['name']
    if name == 'burner_mining_drill':
        if 'iron-ore' in drill['contents']:
            iron_ore_position = drill['position']
            num_iron_ore = drill['contents']['iron-ore'] # retrieving the number of items mined from the drill
            comment("The number of iron ore resources mined so far is", num_iron_ore)
        break
for drill in active_mining_drills:
    if drill['name'] == 'burner_mining_drill':
        contents = drill.get('contents')
        if contents:
            for item, count in contents.items():
                if item == 'iron-ore':
                    comment(f"The mining drill at position {drill['position']} has {count} {item}. I'll extract it using `extract_item` method") 
                    extract_item(item, source_position=drill['position'], quantity=count)
                    break
        else:
            comment(f"The mining drill at position {drill['position']} doesn't have any iron-ore. I'll move to the next one") 
            continue
        break
if drill['name'] == 'burner-mining-drill':
        contents = drill['contents']
        count = contents.get('iron-ore', 0)
        if count > 0:
            comment(f"Got {count} iron ore from the active burner mining drill.")
            break
    else:
        comment("No active miner  mining iron ore. ")


comment("I now have a mining drill, let me use `inspect_entities` to see the number of items that have been mined")
