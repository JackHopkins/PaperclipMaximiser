for belt_position in belts_positions:
    place_entity('transport-belt', UP, belt_position)
comment("Now, I will connect the drills with the furnace using `connect_entities()`")
for entity in entities:
    if entity['name'] == 'burner-mining-drill' and entity['contents'] and list(entity['contents'].keys())[0] == 'iron-ore':
        connect_entities(source_position=entity['position'], target_position=(22.5,-3.5), connection_type='transport-belt')
comment("I will create some more drills and place them next to the existing drills with a gap of 1 tile using `place_entity_next_to()`")
