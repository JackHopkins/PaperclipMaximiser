comment("Let me check the `active_mining_drills` list to see if there are any burners mining iron ore") 
for drill in active_mining_drills:
    if drill['name'] == 'burner-mining-drill' and 'iron-ore' in drill.get('contents', {}):
        extract_item('iron-ore', source_position=drill['position'], quantity=5) # Extract 5 iron ore from the burners. 
        break
else:
    comment("No active burners mining iron ore found")
for drill in active_mining_drills:
    name = drill['name']
    if name == 'burner_mining_drill':
        if 'iron-ore' in drill['contents']:
            iron_ore_position = drill['position']
            harvest_resource(iron_ore_position) 
            break
        else:
            comment("No active miner currently mining iron ore. I'll have to place a new burner mining drill by using `place_entity` method")
            break
comment("I'll place a new burner mining drill on the nearest iron ore deposit using the `place_entity_next_to` method") 
iron_ore_position = nearest('iron-ore')
direction = UP if iron_ore_position[1] > -4 else DOWN # I want the mining drill to face up if the deposit is below the surface and down if it's above ground
new_drill_position = place_entity_next_to('burner-mining-drill', reference_position=iron_ore_position, direction=direction, gap=1)
comment("The new burner mining drill has been placed at position", new_drill_position)
