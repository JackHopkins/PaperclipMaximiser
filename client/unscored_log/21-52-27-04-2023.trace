comment("I will now use inspect_entities() to check if any of my mining drills are waiting for space for its output")
for drill in active_mining_drills:
    if drill['name'] == 'burner-mining-drill' and 'waiting for space' in drill['text']:
        comment(f"Warning: {drill['name']} at {drill['position']}: waiting for space in destination as the output is full. Place a transport-belt or furnace at (22.5, -3.5) to unblock.")
