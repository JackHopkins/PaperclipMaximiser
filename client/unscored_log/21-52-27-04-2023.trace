comment("Plan: Start with a basic mining operation for iron ore and copper ore, smelting setup with stone furnaces, and power generating using coal-fired boilers and steam engines.")
comment("First, let's find the nearest iron ore patch and copper ore patch")
iron_position = nearest('iron-ore')
copper_position = nearest('copper-ore')
comment("Now, let's place a Burner Mining Drill on top of the iron ore patch and the copper ore patch")
place_entity('burner-mining-drill', direction=DOWN, position=iron_position)
place_entity('burner-mining-drill', direction=DOWN, position=copper_position)

comment("Let's pick up some coal and insert it in the Burner Mining Drill to start the mining operation for both copper and iron ore.")
move_to(navigate.pickup('coal', state="on_ground", position=copper_position))
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=5)
move_to(navigate.pickup('coal', state="on_ground", position=iron_position))
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=5)

comment("Seems like we need to pick up a lot of coal. Let's harvest some nearby trees and use them as fuel.")
move_to(navigate.pickup('tree', state="on_ground"))
harvest_resource(nearest('tree'), quantity=10)
insert_item('wood', target_position=nearest('stone-furnace'), quantity=10)
insert_item('wood', target_position=nearest('burner-mining-drill'), quantity=10)

comment("Let's craft a Stone Furnace and insert some coal to start smelting iron and copper ore.")
craft_item('stone-furnace', quantity=1)
move_to((iron_position[0] + 2, iron_position[1]))
place_entity('stone-furnace')
insert_item(item='coal', target_position=nearest('stone-furnace'), quantity=10)
comment("It looks like we need to harvest some stone for crafting the stone furnace. Let's find some stone nearby.")
