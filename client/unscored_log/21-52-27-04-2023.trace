for entity in entities:
    if entity['name'] == 'burner-mining-drill' and 'out of fuel' in entity['warning']:
        insert_item('coal', target_position=entity['position'], quantity=1)    
    elif entity['name'] == 'boiler' and 'out of fuel' in entity['warning']:
        insert_item('coal', target_position=entity['position'], quantity=10)
comment("I will craft some transport belts using `craft_item()`")
