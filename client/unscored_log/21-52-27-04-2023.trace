gap = 1
for i in range(5):
    direction = DOWN if i%2==0 else UP
    entity_position = place_entity_next_to('burner-mining-drill', reference_position, direction, gap)
    reference_position = entity_position
    if entity_position:
        connect_entities(source_position=entity_position, target_position=(22.5,-3.5), connection_type='transport-belt')
    else:
        break

