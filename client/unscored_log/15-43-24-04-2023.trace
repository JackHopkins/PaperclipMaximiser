comment("First, check the resources and landscape around me")
resources = inspect_resources()
comment("Now that I know the resources, I will find coal and setup a mining operation")
coal_position = nearest("coal")
move_to(coal_position)
comment("Place the burner-mining-drill at the coal position")
place_entity("burner-mining-drill", direction=UP, position=(coal_position[0], coal_position[1]))
comment("Check to ensure that the burner-mining-drill has been placed")
inspect_entities(5)
