# Lets start by checking my inventory.
# Now that we know what we have, let's start by creating a coal mining operation, and smelting iron.
# First, let us create a spot for our mining operation by placing a burner mining drill over the nearest coal mine.
coal_position = nearest('coal')
place_entity('burner-mining-drill', direction=LEFT, position=coal_position)
move_to((coal_position[0]-1, coal_position[1]))
move_to(nearest('stone-furnace'), laying='transport-belts')
# Oops, looks like we don't have a stone-furnace nearby. Let's create one first.
stone_position = (coal_position[0]-5, coal_position[1]-5)
place_entity('stone-furnace', direction=UP, position=stone_position)
# Now that we have a stone furnace, let's start creating iron plates using the coal we mined earlier and the nearby iron resource. 
# Place a burner-mining drill at the nearest iron resource:
iron_position = nearest('iron-ore')
place_entity('burner-mining-drill', direction=LEFT, position=iron_position)
move_to((iron_position[0]-1, iron_position[1]))
move_to((stone_position[0]+1, stone_position[1]), laying='transport-belts')
# Oops, looks like we haven't crafted the burner mining drill yet. Let's craft them first.
craft_item('burner-mining-drill')
# I forgot to check my inventory before crafting. Looks like we are missing stone. Let's mine some stone first.
stone_position = nearest('stone')
harvest_resource(stone_position,quantity=5)
move_to((stone_position[0]-1,stone_position[1]))
craft_item('burner-mining-drill')
# Oh no! We don't have any nearby stone. Let's go find some.
move_to(nearest('stone'))
harvest_resource(nearest('stone'),quantity=5)
move_to((stone_position[0]-1,stone_position[1]))
craft_item('burner-mining-drill')
# Great! Now let's set up the burner mining drill at the iron mine and create a path of transport belts back to the furnace.
iron_position = nearest('iron-ore')
place_entity('burner-mining-drill', direction=LEFT, position=iron_position)
move_to((iron_position[0]-1, iron_position[1]))
move_to((stone_position[0]+1, stone_position[1]), laying='transport-belts')
set_entity_recipe(iron_position, recipe='iron-plate')
# Oops! Looks like we need an assembling machine to automate the production of iron plates. Let's craft one.
craft_item('assembling-machine-1')  # Craft one assembling machine
# Place the assembling machine near the furnace
assembling_position = (stone_position[0]+3, stone_position[1])
place_entity('assembling-machine-1', direction=UP, position=assembling_position)
move_to((stone_position[0]+2, stone_position[1]), laying='transport-belts')
# Let's pick up the transport belts and try again
pickup_entity('transport-belt', (stone_position[0]+2, stone_position[1]))
move_to((stone_position[0]+2, stone_position[1]), laying='transport-belts')
# My mistake, let's move the assembling machine one step further to make space for the transport belt
assembling_position = (stone_position[0]+4, stone_position[1])
place_entity('assembling-machine-1', direction=UP, position=assembling_position)
move_to((stone_position[0]+3, stone_position[1]), laying='transport-belts')
# Right, let's try placing the assembling machine on the other side of the transport belts instead
assembling_position = (stone_position[0]+2, stone_position[1])
place_entity('assembling-machine-1', direction=UP, position=assembling_position)
move_to((stone_position[0]+3, stone_position[1]), laying='transport-belts')
# Looks like there's still not enough space. Let's try moving the transport belts one step further
pickup_entity('transport-belt', (stone_position[0]+2, stone_position[1]))
place_entity('transport-belt', position=(stone_position[0]+3, stone_position[1]))
place_entity('assembling-machine-1', direction=UP, position=(stone_position[0]+2, stone_position[1]))
move_to((stone_position[0]+3, stone_position[1]), laying='transport-belts')
