comment("Plan:")


comment("First, we need to mine some iron ore and then smelt it in the furnace to obtain iron plates. We can then use those iron plates to craft more advanced items.")
move_to(ore)
harvest_resource(ore, quantity=10)
stone_furnace_pos = nearest('stone-furnace')
move_to(stone_furnace_pos)
insert_item('iron-ore',target_position=stone_furnace_pos,quantity=10)
craft_item('iron-plate',quantity=10)
comment("We need to check our inventory first to see if we have any iron ore.")
inventory = inspect_inventory()
comment("Now, let's insert the iron ore into the furnace to smelt it.")
if inventory.get('iron-ore', 0) > 0:
    move_to(stone_furnace_pos)
    insert_item('iron-ore', target_position=stone_furnace_pos, quantity=10) 
else:
    comment("No iron-ore in inventory")
comment("Now, we need to make sure the furnace has fuel, and wait for it to finish smelting.")
inventory = inspect_inventory()
if inventory.get('coal', 0) > 0:
    if inspect_entities(radius=2).get('stone-furnace', {}).get('energy_usage', 0) < 100:
        insert_item('coal', target_position=nearest('stone-furnace'), quantity=1)
else:
    comment("No coal in inventory to refuel furnace")
