# Collect resources, setup and start production
inventory();
# Move to the nearest resource
goto(nearest('iron_ore'));
# Harvest iron ore
harvest((-2, 0), count=10);
# Move to a location with at least 2 meters distance from the resource to place the stone-furnace
goto((1, 1));
place('stone-furnace', 0, (0, 0));
insert('coal', (0, 0), count=1);
