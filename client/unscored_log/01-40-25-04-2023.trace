comment("First, let's inspect resources around the area")
resources = inspect_resources()
comment("First, let's inspect resources around the area")
resources = inspect_resources()
comment("Set up a simple mining operation, smelting setup, and basic power box")
comment("Find coal and place a burner-mining-drill")
coal_position = nearest('coal')
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill'))
comment("Create a stone furnace for smelting")
move_to((burner_drill_position[0], burner_drill_position[1] - 2))
stone_furnace_position = place_entity('stone-furnace', direction=None, position=nearest_buildable('stone-furnace'))
comment("Place an inserter to transfer ores from the mining drill to the stone furnace")
inserter_position = place_entity_next_to('inserter', reference_position=burner_drill_position, direction=DOWN, gap=1)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Move to a better position for placing inserter")
move_to((burner_drill_position[0], burner_drill_position[1] - 1))
comment("Place an inserter to transfer ores from the mining drill to the stone furnace")
inserter_position = place_entity_next_to('inserter', reference_position=burner_drill_position, direction=DOWN, gap=1)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Check surroundings for any obstacles and remove them")
entities = inspect_entities(5)
for entity in entities:
    if entity['type'] != 'player_character' and entity['position'] == (burner_drill_position[0], burner_drill_position[1] - 1):
        pickup_entity(entity['type'], entity['position'])
        break
