comment("Step 1: Basic resource gathering and processing")
comment("Move to nearest coal patch and set up mining operation")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner mining drill at nearest buildable position to start mining coal")
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Verify that the drill is working and producing coal")
inspect_entities(5)
comment("Step 2: Smelting")
comment("Move to nearest iron patch and set up mining operation")
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Step 2: Smelting - Obtain resources for smelting")
comment("Pick up coal near starting position")
pickup_entity('coal', (-8, -5))
