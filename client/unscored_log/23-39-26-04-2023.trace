comment("Sorry about that. Here's a helper function to check inventory space before inserting items.")
def check_inventory_space(entity_pos, item_name):
    inv = inspect_entity(entity_pos)['inventory']
    if item_name in inv and inv[item_name] < 50:
        return True
    elif item_name not in inv:
        return True
    else:
        return False
```
def check_inventory_space(item_name, quantity=1):
    inventory = inspect_inventory()
    if item_name in inventory.keys():
        if inventory[item_name] < inventory_size():
            return True
        else:
            return False
    else:
        if inventory_size() - len(inventory.keys()) >= 1:
            return True
        else:
            return False
```

