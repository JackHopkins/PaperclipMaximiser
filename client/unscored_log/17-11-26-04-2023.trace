comment("First, let's inspect the resources, entities and inventory around us to plan our base.")
resources = inspect_resources()
entities = inspect_entities(20)
inventory = inspect_inventory()
comment("Next, we will move to the nearest coal patch and place a burner mining drill to extract coal.")
coal_position = nearest("coal")
move_to(coal_position)
coal_drill_position = place_entity("burner-mining-drill", direction=DOWN, exact=False, position=coal_position)
comment("We don't have a burner mining drill in our inventory. Let's craft one and try placing it again.")
craft_item("burner-mining-drill", quantity=1)
coal_drill_position = place_entity("burner-mining-drill", direction=DOWN, exact=False, position=coal_position)
comment("Now, we need to set up a stone furnace to smelt the iron ore. We will move to the iron ore patch and place the stone furnace.")
iron_ore_position = nearest("iron_ore")
move_to(iron_ore_position)
stone_furnace_position = place_entity("stone-furnace", direction=UP, exact=False, position=iron_ore_position)
comment("We need to craft a stone furnace since there's none in our inventory.")
craft_item("stone-furnace", quantity=1)
stone_furnace_position = place_entity("stone-furnace", direction=UP, exact=False, position=iron_ore_position)
comment("We lack the necessary ingredients to craft a stone furnace. Let's find a stone patch, mine some stone and then craft it.")
stone_position = nearest("stone")
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
craft_item("stone-furnace", quantity=1)
comment("With the stone furnace crafted, let's set it up at the iron ore patch.")
move_to(iron_ore_position)
stone_furnace_position = place_entity("stone-furnace", direction=UP, exact=False, position=iron_ore_position)
