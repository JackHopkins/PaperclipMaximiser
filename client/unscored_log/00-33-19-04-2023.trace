# My apologies, the 'closest_position' function is not part of the API, and I forgot to define it. I will define it to find the closest position from a given position and a list of entity types.
def closest_position(position, entity_types, radius):
    entities = inspect_entities(radius)['entities']
    distances = {}
    for entity in entities:
        if entity['type'] in entity_types:
            distance = ((position[0]-entity['position'][0])**2 + (position[1]-entity['position'][1])**2)**0.5
            distances[distance] = entity['position']
    if len(distances) > 0:
        return distances[min(distances.keys())] 
    else:
        return None
