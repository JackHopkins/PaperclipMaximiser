comment("Initial setup")
comment("Start by inspecting the resources around the player")
resource_info = inspect_resources()
print(resource_info)
comment("Let's start by extracting coal")
comment("Move to the coal deposit")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner mining drill and a furnace")
comment("Place the burner mining drill on the coal deposit, facing right")
place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', entity='coal'), direction=RIGHT)
comment("Place the furnace to the right of the mining drill, facing right")
furnace_position = place_entity_next_to('stone-furnace', coal_position, direction=RIGHT, gap=1)
comment("Connect the output of the mining drill to the input of the furnace using an inserter")
connect_entities(source_position=coal_position, target_position=furnace_position, connection_type='inserter')
