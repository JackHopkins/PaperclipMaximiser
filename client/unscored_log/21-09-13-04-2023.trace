# Lets start by checking my inventory.
# Great, I have enough items to start building the factory. Let's start with coal production.
coal_position = nearest('coal')
place_entity('burner-mining-drill', direction=RIGHT, position=coal_position)
# Now let's place a stone furnace next to the drill.
furnace_position = (coal_position[0] + 1, coal_position[1])
place_entity('stone-furnace', position=furnace_position)
# My apologies, let's move the stone furnace to the appropriate position.
furnace_position = (coal_position[0] + 2, coal_position[1])
place_entity('stone-furnace', position=furnace_position)
# Now, let's fuel the burner-mining-drill and stone-furnace.
insert_item('coal', target_position=coal_position, quantity=5)
insert_item('coal', target_position=furnace_position, quantity=5)
# Great, now let's set up iron ore production.
iron_ore_position = nearest('iron_ore')
place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_position)
# I apologize for the mistake. Let's craft a new burner-mining-drill.
craft_item('burner-mining-drill', quantity=1)
# Now let's try placing it again.
place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_position)
# It seems I need stone to craft the burner-mining-drill. Let's mine some and then craft it.
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
craft_item('burner-mining-drill', quantity=1)
# Now that we've crafted a new burner-mining-drill, let's set up the iron ore production.
place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_position)
# Let's place a stone furnace next to the iron ore burner-mining-drill.
iron_furnace_position = (iron_ore_position[0] - 1, iron_ore_position[1])
place_entity('stone-furnace', position=iron_furnace_position)
# My apologies again, let's craft a new stone-furnace.
craft_item('stone-furnace', quantity=1)
# Now let's try placing it again.
place_entity('stone-furnace', position=iron_furnace_position)
# My bad, let's move the stone furnace to the appropriate position.
iron_furnace_position = (iron_ore_position[0] - 2, iron_ore_position[1])
place_entity('stone-furnace', position=iron_furnace_position)
# Now, let's fuel the iron ore burner-mining-drill and stone-furnace.
insert_item('coal', target_position=iron_ore_position, quantity=5)
insert_item('coal', target_position=iron_furnace_position, quantity=5)
# Let's start with copper ore production.
copper_ore_position = nearest('copper_ore')
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=LEFT, position=copper_ore_position)
# Now let's place a stone furnace next to the copper ore burner-mining-drill.
copper_furnace_position = (copper_ore_position[0] - 1, copper_ore_position[1])
craft_item('stone-furnace', quantity=1)
place_entity('stone-furnace', position=copper_furnace_position)
# Let's correct the stone furnace position for the copper ore production.
copper_furnace_position = (copper_ore_position[0] - 2, copper_ore_position[1])
place_entity('stone-furnace', position=copper_furnace_position)
# Now, let's fuel the copper ore burner-mining-drill and stone-furnace.
insert_item('coal', target_position=copper_ore_position, quantity=5)
insert_item('coal', target_position=copper_furnace_position, quantity=5)
# Now, let's set up coal production.
coal_position = nearest('coal')
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=LEFT, position=coal_position)
# I apologize for the mistake. Let's find an available position for the coal production.
available_positions = [
    (coal_position[0] - 1, coal_position[1]),
    (coal_position[0] + 1, coal_position[1]),
    (coal_position[0], coal_position[1] - 1),
    (coal_position[0], coal_position[1] + 1)
]
# Now let's place the burner-mining-drill at the first available position.
for pos in available_positions:
    if place_entity('burner-mining-drill', direction=LEFT, position=pos) == True:
        coal_production_position = pos
        break
# Let's fuel the coal burner-mining-drill.
insert_item('coal', target_position=coal_production_position, quantity=5)
# Now that we have set up production for iron ore, copper ore, and coal, let's extract the resources.
# Extract iron plates from the stone furnace
extract_item('iron-plate', source_position=iron_furnace_position, quantity=5)
# Let's wait for the iron plates to be smelted and then extract them.
wait_duration(20)
extract_item('iron-plate', source_position=iron_furnace_position, quantity=5)
