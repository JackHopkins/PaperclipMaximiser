# Inspect the surrounding resources and entities
inspect_resources()
inspect_entities(20)
# Check my inventory
check_inventory()
# Pick up coal near me
pickup_entity('coal', player_character) 
# Move to the nearest coal
move_to(nearest('coal')) 
# Place a burner-mining-drill
