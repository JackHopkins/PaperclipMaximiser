# Place a burner-mining-drill near a coal resource
coal_position = nearest('coal')
direction_to_face = 'right' if coal_position[0] < 0 else 'left'
place_entity('burner-mining-drill', direction=direction_to_face, position=(coal_position[0]+(1 if direction_to_face == 'left' else -2), coal_position[1]))
# Extract coal from the burner-mining-drill and insert into the entity at (0, 0)
coal_position = nearest('coal')
direction_to_face = 'right' if coal_position[0] < 0 else 'left'
drill_position = (coal_position[0]+(1 if direction_to_face == 'left' else -2), coal_position[1])
insert_position = (0, 0)
extract_item('coal', source_position=drill_position, quantity=1)
insert_item('coal', target_position=insert_position, quantity=1)
