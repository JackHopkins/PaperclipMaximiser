# Lets start by checking my inventory.
# I will now create a loop to mine as much iron ore as possible
# I will travel to each iron ore deposit and place a burner mining drill followed by transport belts to my inventory 
for i in range(10):
    ore_position = nearest('iron-ore')
    place_entity('burner-mining-drill', direction=LEFT, position=ore_position)
    move_to((ore_position[0]-1, ore_position[1]))
    move_to(nearest('stone-furnace'), laying='transport-belts')
    observe_nature()
    check_inventory() 
# Oops! I made a mistake, there is no stone furnace in my inventory. 
