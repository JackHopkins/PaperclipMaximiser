# Crafting a Stone Furnace
craft_item('stone-furnace', quantity=1)
# Sorry about that. Let's try restarting our API and check the inventory.
craft_item('iron-gear-wheel', 1)
check_inventory()
# Great, it looks like we were successful in crafting an iron gear wheel. 
# Now let's reuse the code to mine as much iron as possible while also making as many iron gear wheels as possible.
# We will follow the same process to mine coal, copper, and uranium which are required to make iron gear wheels.
# Mining iron ore and making iron gear wheels.
# We will iterate over the iron ore patches, place a burner mining drill, move to a stone furnace, and craft iron gear wheels.
# We will do this until we can no longer make any gear wheels.
while True:
    # Mining iron ore
    for i in range(10): # Iterate over iron patches
        ore_position = nearest('iron-ore')
        if ore_position is None:
            break
        place_entity('burner-mining-drill', direction=LEFT, position=ore_position)
        move_to((ore_position[0]-1, ore_position[1]))
        move_to(nearest('stone-furnace'), laying='transport-belts')
    # Crafting iron gear wheels
    crafting_possible = True
    while crafting_possible:
        check_inventory()
        if 'iron-plate' in check_inventory() and 'iron-gear-wheel' in check_inventory():
            insert_item('iron-plate', target_position=nearest('assembling-machine-1'), quantity=2)
            extract_item('iron-gear-wheel', source_position=nearest('assembling-machine-1'), quantity=1)
        else:
            crafting_possible = False
    # Mining coal, copper, and uranium
    for i in range(10): # Iterate over coal, copper, and uranium patches
        ores = ['coal', 'copper-ore', 'uranium-ore']
        for ore in ores:
            ore_position = nearest(ore)
            if ore_position is None:
                break
            place_entity('burner-mining-drill', direction=LEFT, position=ore_position)
            move_to((ore_position[0]-1, ore_position[1]))
            move_to(nearest('stone-furnace'), laying='transport-belts')
    check_inventory() # Check inventory before resuming the loop.
# Oops! It looks like we forgot to add burner mining drills to our inventory before running the loop.
# Let's add some drills before resuming the loop.
