# Lets start by checking my inventory.
# I have a good amount of resources to start with. Let's make some iron-gear-wheels
# We need iron-plates to craft iron-gear-wheels. So, we need to get some iron-ores to smelt into iron-plates.
# Move towards the nearest iron ore and extract 40 iron ore
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
harvest_resource(iron_ore_position, 40)
# Check inventory to see if we have enough iron-ore
check_inventory()
# We have enough iron-ore. Let's smelt it into iron-plates
# Move towards the nearest stone-furnace and place it beside it.
# Then insert 40 iron-ore into the furnace and wait for it to be smelted into 40 iron-plates
stone_furnace_position = nearest('stone-furnace')
move_to(stone_furnace_position)
place_entity('stone-furnace', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]+1))
craft_item('iron-plate', quantity=40)
wait(5)  # Wait for 5 seconds to let the iron-plates get smelted.
# It looks like there is no stone-furnace on the map, so let's create one.
# Move towards the nearest iron-ore and place a burner-mining-drill.
# Then move towards the nearest stone, mine 30 stones and create a stone-furnace.
# Finally, place the stone-furnace and the burner-mining-drill next to each other, facing the same direction, and insert 40 iron-ore into the furnace.
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-1, iron_ore_position[1]))
move_to(nearest('stone'), laying='transport-belt')
harvest_resource(nearest('stone'), 30)
craft_item('stone-furnace', quantity=1)
stone_furnace_position = nearest('stone-furnace')
place_entity('stone-furnace', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]+1))
place_entity('burner-mining-drill', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]-1))
insert_item('iron-ore', target_position=(stone_furnace_position[0], stone_furnace_position[1]+1), quantity=40)
# Oops, I made a mistake. There is no stone-furnace on the map.
# Let's start again by moving towards the nearest stone, mine 30 stones and create a stone-furnace.
# Then move towards the nearest iron-ore and put a burner-mining-drill beside it,
# Put the stone-furnace and the burner-mining-drill next to each other, facing the same direction,
# and finally insert 40 iron-ore into the furnace.
move_to(nearest('stone'), laying='transport-belt')
harvest_resource(nearest('stone'), 30)
craft_item('stone-furnace', quantity=1)
stone_furnace_position = nearest('stone-furnace')
move_to(nearest('iron-ore'))
place_entity('burner-mining-drill', direction=LEFT, position=(nearest('iron-ore')[0]-1, nearest('iron-ore')[1]))
place_entity('stone-furnace', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]+1))
place_entity('burner-mining-drill', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]-1))
insert_item('iron-ore', target_position=(stone_furnace_position[0], stone_furnace_position[1]+1), quantity=40)
# There seems to be no stone-furnace on the map. Let's create one.
# Move towards the nearest iron-ore and put a burner-mining-drill beside it
# Then move towards the nearest stone, mine 30 stones and create a stone-furnace
# Finally, place the stone-furnace and the burner-mining-drill next to each other, facing the same direction, and insert 40 iron-ore into the furnace.
move_to(nearest('iron-ore'))
place_entity('burner-mining-drill', direction=LEFT, position=(nearest('iron-ore')[0]-1, nearest('iron-ore')[1]))
move_to(nearest('stone'), laying='transport-belt')
harvest_resource(nearest('stone'), 30)
craft_item('stone-furnace', quantity=1)
stone_furnace_position = nearest('stone-furnace')
place_entity('stone-furnace', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]+1))
place_entity('burner-mining-drill', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]-1))
insert_item('iron-ore', target_position=(stone_furnace_position[0], stone_furnace_position[1]+1), quantity=40)
# Looks like there's still no stone-furnace on the map. Let's backtrack a bit and start fresh.
# Move towards the nearest stone, mine 30 stones, and create a stone-furnace.
# Move towards the nearest iron-ore and put a burner-mining-drill beside it.
# Then place the stone-furnace and the burner-mining-drill next to each other, facing the same direction, 
# and insert 40 iron-ore into the furnace.
move_to(nearest('stone'), laying='transport-belt')
harvest_resource(nearest('stone'), 30)
craft_item('stone-furnace', quantity=1)
stone_furnace_position = nearest('stone-furnace')
move_to(nearest('iron-ore'))
place_entity('burner-mining-drill', direction=LEFT, position=(nearest('iron-ore')[0]-1, nearest('iron-ore')[1]))
place_entity('stone-furnace', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]+1))
place_entity('burner-mining-drill', direction=UP, position=(stone_furnace_position[0], stone_furnace_position[1]-1))
insert_item('iron-ore', target_position=(stone_furnace_position[0], stone_furnace_position[1]+1), quantity=40)
