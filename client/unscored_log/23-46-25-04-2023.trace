comment("Inspect available resources around")
resources = inspect_resources()
print(resources)
comment("set up a simple mining operation")
coal_patch = resources['coal'][0]
coal_middle = (int((coal_patch['min_coordinates'][0] + coal_patch['max_coordinates'][0]) / 2), int((coal_patch['min_coordinates'][1] + coal_patch['max_coordinates'][1]) / 2))
comment("Move to the coal_middle position")
move_to(coal_middle)
comment("Place a burner mining drill facing RIGHT")
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_middle)
comment("Inspect entities within a 5-meter radius")
entities = inspect_entities(5)
print(entities)
comment("Pick up coal near the mining drill")
pickup_entity('coal', (coal_middle[0]-1, coal_middle[1]))
comment("Harvest 5 coal from the coal patch")
harvest_resource(coal_middle, quantity=5)
comment("Inspect inventory")
inventory = inspect_inventory()
print(inventory)
comment("Insert 1 coal into the mining drill for fuel")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Place a stone furnace near the burner-mining-drill")
stone_furnace_position = (coal_middle[0]+2, coal_middle[1])
place_entity('stone-furnace', position=stone_furnace_position)
comment("Place a burner-mining-drill facing LEFT, near the stone-furnace")
new_burner_position = (stone_furnace_position[0]-2, stone_furnace_position[1])
place_entity('burner-mining-drill', direction=LEFT, position=new_burner_position)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Find the nearest stone")
stone_position = nearest('stone')
move_to(stone_position)
comment("Harvest 5 stone from the nearest position")
harvest_resource(stone_position, quantity=5)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Find the nearest patch of coal")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill facing the right direction on the coal patch")
burner_drill_position = place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
comment("Harvest 1 piece of coal")
harvest_resource(coal_position, quantity=1)
comment("Insert 1 coal into the burner-mining-drill for fuel")
insert_item('coal', target_position=burner_drill_position, quantity=1)
comment("Craft a stone furnace")
craft_item('stone-furnace', quantity=1)
comment("Mine 5 stone to craft a stone furnace")
harvest_resource(stone_position, quantity=5)
comment("Move closer to the stone resource")
move_to(stone_position)
comment("Mine 5 stone to craft a stone furnace")
harvest_resource(stone_position, quantity=5)
comment("Craft a stone-furnace")
craft_item("stone-furnace", quantity=1)
comment("Place the stone-furnace at stone_furnace_position")
place_entity("stone-furnace", direction=UP, exact=True, position=stone_furnace_position)
place_entity("stone-furnace", direction=UP, position=stone_furnace_position)
