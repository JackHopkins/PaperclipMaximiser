# I received an error because I was trying to insert items into a non-existent entity position. I will check if the entity exists before inserting the items.
while max_gear_wheels < 2000:
    inventory = check_inventory()
    if inventory.get('iron-gear-wheel', 0) >= 5 and inventory.get('iron-plate', 0) >= 1:
        craft_item('assembling-machine-1', quantity=1)
        insert_item('iron-plate', quantity=1)
        place_entity('assembling-machine-1', position=(5,5), direction=DOWN)
        
    if inventory.get('iron-gear-wheel', 0) >= 1 and inventory.get('copper-plate', 0) >= 1:
        craft_item('inserter', quantity=1)
        insert_item('iron-plate', quantity=1)
        place_entity('inserter', position=(6,6), direction=DOWN)
        
    if inventory.get('iron-plate', 0) >= 1 and inventory.get('copper-plate', 0) >= 1:
        # Set the recipe of the assembling machine to create iron-gear-wheels
        set_entity_recipe((5,5), recipe='iron-gear-wheel') 
        
        # Insert the required materials into the assembling machine to start the production
        insert_item('iron-plate', quantity=1, target_position=(5,5))
        
        copper_nearest_position = nearest('copper-plate')
        if copper_nearest_position:
            insert_item('copper-plate', quantity=1, target_position=copper_nearest_position)
        
        # Wait until the production is complete
        while inventory.get('iron-gear-wheel', 0) < 10:
            check_inventory()
        
        # Extract the produced iron-gear-wheels from the assembling machine
        extract_item('iron-gear-wheel', source_position=(5,5), quantity=10)
        
        max_gear_wheels += 10
        
