# It seems like I have run out of resources to mine. I will start building the assembling machine and inserters for automated production
while max_gear_wheels < 2000:
    copper_ore_pos = nearest('copper-ore')
    move_to(copper_ore_pos)
    pickup_entity('copper-ore', copper_ore_pos)
    
    iron_ore_pos = nearest('iron-ore')
    move_to(iron_ore_pos)
    while check_inventory().get('iron-ore', 0) < 100:
        if "burner-mining-drill" not in observe_nature():
            place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_pos)
            break
        
        harvest_resource(iron_ore_pos, quantity=25)
    
    coal_pos = nearest('coal')
    move_to(coal_pos)
    while check_inventory().get('coal', 0) < 100:
        if "burner-mining-drill" not in observe_nature():
            place_entity('burner-mining-drill', direction=LEFT, position=coal_pos)
            break
        
        coal_nearest_position = nearest('coal')
        pickup_entity('coal', coal_nearest_position)
    
    if check_inventory().get('iron-ore', 0) >= 100 and check_inventory().get('copper-ore', 0) >= 100 and check_inventory().get('coal', 0) >= 100:
        craft_item('iron-gear-wheel', quantity=10)
        max_gear_wheels += 10
        
        # Use the gear-wheels and iron-plates in the inventory to create assembling machines and inserters
        inventory = check_inventory()
        if inventory.get('iron-gear-wheel', 0) >= 5 and inventory.get('iron-plate', 0) >= 1:
            craft_item('assembling-machine-1', quantity=1)
            insert_item('iron-plate', quantity=1)
# I received an error because there are no resources left to mine. I will use the automated production to create the remaining gear-wheels
while max_gear_wheels < 2000:
    inventory = check_inventory()
    if inventory.get('iron-gear-wheel', 0) >= 5 and inventory.get('iron-plate', 0) >= 1:
        craft_item('assembling-machine-1', quantity=1)
        insert_item('iron-plate', quantity=1)
        place_entity('assembling-machine-1', position=(5,5), direction=DOWN)
        
    if inventory.get('iron-gear-wheel', 0) >= 1 and inventory.get('copper-plate', 0) >= 1:
        craft_item('inserter', quantity=1)
        insert_item('iron-plate', quantity=1)
        place_entity('inserter', position=(6,6), direction=DOWN)
        
    if inventory.get('iron-plate', 0) >= 1 and inventory.get('copper-plate', 0) >= 1:
        # Set the recipe of the assembling machine to create iron-gear-wheels
        set_entity_recipe((5,5), recipe='iron-gear-wheel') 
        
        # Insert the required materials into the assembling machine to start the production
        insert_item('iron-plate', quantity=1, target_position=(5,5))
        insert_item('copper-plate', quantity=1, target_position=(5,5))
        
        # Wait until the production is complete
        while inventory.get('iron-gear-wheel', 0) < 10:
            check_inventory()
        
        # Extract the produced iron-gear-wheels from the assembling machine
        extract_item('iron-gear-wheel', source_position=(5,5), quantity=10)
        
        max_gear_wheels += 10
        
# I have gathered enough resources and created gear-wheels, I will output the number of gear-wheels I have created
print(f"Gear-wheels created: {max_gear_wheels}")
