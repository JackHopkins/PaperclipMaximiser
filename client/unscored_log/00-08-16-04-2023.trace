# Initialize the game
move_to((0, 0))
place_entity('burner-mining-drill', direction=DOWN, position=(0, 2))
place_entity('stone-furnace', direction=LEFT, position=(0, -2))
place_entity('coal', direction=RIGHT, position=(0, -5))
place_entity('boiler', direction=UP, position=(5, -5))
place_entity('steam-engine', direction=UP, position=(5, -7))
# Inspect the surroundings to see what is around
inspect_entities(10)
# It seems like we need to supply fuel to the furnace
coal_position = nearest('coal')
move_to(coal_position)
pickup_entity('coal', coal_position)
insert_item('coal', target_position=(0, -2), quantity=10)
# It seems like there is no coal nearby. Let's use wood instead
wood_position = nearest('tree')
harvest_resource(wood_position, quantity=5)
craft_item('wood', quantity=5)
insert_item('wood', target_position=(0, -2), quantity=5)
# Let's try to place the burner mining drill to harvest coal first
place_entity('burner-mining-drill', direction=DOWN, position=(0, 2))
coal_position = nearest('coal')
move_to(coal_position)
place_entity('transport-belt', direction=LEFT, position=(coal_position[0]-1, coal_position[1]))
inspect_entities(10)
# Since we have found coal, let's increase our fuel production by placing more burners
place_entity('burner-mining-drill', direction=DOWN, position=(0, 4))
coal_position2 = nearest('coal')
move_to(coal_position2)
place_entity('transport-belt', direction=LEFT, position=(coal_position2[0]-1, coal_position2[1]))
inspect_entities(10)
# Let's place the burner mining drill little further from furnace
place_entity('burner-mining-drill', direction=DOWN, position=(0, 8))
coal_position2 = nearest('coal')
move_to(coal_position2)
place_entity('transport-belt', direction=LEFT, position=(coal_position2[0]-1, coal_position2[1]))
inspect_entities(10)
# Let's rotate the furnace for more space
rotate_entity((0, 3), direction=LEFT)
# Let's try placing the entities again
place_entity('burner-mining-drill', direction=DOWN, position=(0, 8))
coal_position2 = nearest('coal')
move_to(coal_position2)
place_entity('transport-belt', direction=LEFT, position=(coal_position2[0]-1, coal_position2[1]))
inspect_entities(10)
# Let's move closer to the coal position to place the entities
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
place_entity('transport-belt', direction=LEFT, position=(coal_position[0]-3, coal_position[1]))
# Let's move slightly away from the furnace and try to place entities again
move_to((0,-5))
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1])) 
place_entity('transport-belt', direction=LEFT, position=(coal_position[0]-3, coal_position[1])) 
inspect_entities(10)
# Let's move further back and try again
move_to((0, -10))
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
place_entity('transport-belt', direction=DOWN, position=(coal_position[0], coal_position[1]+3))
inspect_entities(10)
# Let's see why the drill could not be placed
inspect_entities(20)
# Let's move to the other side of the coal position
move_to((0, 10))
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+2))
place_entity('transport-belt', direction=DOWN, position=(coal_position[0], coal_position[1]+3)) 
inspect_entities(20)
# Let's check again for available positions
inspect_entities(20)
move_to((0, 20))
inspect_entities(20)
