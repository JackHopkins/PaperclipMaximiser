comment("It seems we cannot harvest the resources at the given coordinates. We should make sure that they are within our reach.")
comment("Let's check the nearby entities and see if there are any miner drills or burner drills that we can use to extract resources.")
entities = inspect_entities(20)
for entity in entities:
    if entity["name"] in ["miner", "burner-mining-drill"]:
        move_to(entity["position"])
        extract_item(entity["name"].replace("-mining-drill", ""), source_position=entity["position"], quantity=10)
        break
inspect_inventory()
