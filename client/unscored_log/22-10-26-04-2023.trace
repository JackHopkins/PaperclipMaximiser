harvest_resource(ore_position, quantity=50)
move_to(nearest('stone'), laying='transport-belt')
harvest_resource(nearest('stone'), quantity=50)
comment("Plan:")
comment("Let's smelt the 3 ore to make iron plates. We need a total of 5 iron plates to craft the stone furnace we need.") 
insert_item('iron-ore', target_position=furnace_position, quantity=3)
set_entity_recipe(furnace_position, recipe='iron-plate')
time_passed = 0
while time_passed < 5 :
    inspect_entities(radius=10)
    time_passed += 1
comment("Plan:")
comment("We need to find some iron-ore to begin the smelting process. Let's search the surroundings for it.") 
resources = inspect_resources()
iron_ore_positions = [pos for pos, res in resources.items() if res == "iron-ore"]
if len(iron_ore_positions) > 0:
    ore_position = iron_ore_positions[0]
    ore = resources[ore_position]
    comment(f"Found {ore} at {ore_position}")
    move_to((ore_position[0], ore_position[1]), laying='transport-belt')
    harvest_resource(ore_position, quantity=10)
    insert_item('iron-ore', target_position=furnace_position, quantity=3)
else:
    comment("Could not find any iron ore in the surroundings.")
