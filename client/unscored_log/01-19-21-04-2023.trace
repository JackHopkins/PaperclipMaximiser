# First, I will inspect the resources and entities around to see what I have around me
inspect_resources()
inspect_entities(20)
# Okay, I have a good amount of resources around me. I will start by placing a mine on the coal near me.
coal_position = nearest('coal')
move_to(coal_position) 
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1])) 
# Oops, I forgot to craft a burner mining drill first. I will do that now, then retry placing it.
craft_item('burner-mining-drill', quantity=1)
coal_position = nearest('coal')
move_to(coal_position) 
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
