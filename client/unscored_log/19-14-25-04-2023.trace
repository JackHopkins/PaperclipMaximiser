comment("Finding nearest coal mine")
def nearest_resource(resource):
    resources = inspect_resources()
    nearest = None
    for r in resources[resource]:
        pos = ((r['min_coordinates'][0] + r['max_coordinates'][0])/2, (r['min_coordinates'][1] + r['max_coordinates'][1])/2)
        if not nearest or distance(pos, player_character_position()) < distance(nearest, player_character_position()):
            nearest = pos
    return {'position':nearest}
comment("Finding nearest coal mine")
coal_pos = nearest_resource('coal')['position']
