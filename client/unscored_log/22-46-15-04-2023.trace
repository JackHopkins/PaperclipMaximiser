# First, let's observe the nature around us and plan our initial resource gathering.
# Observe and plan
observe_nature()
# Based on what we observed, let's start with a simple resource gathering operation near the coal resource at (-17, -14)
# Check our inventory to see what we have
check_inventory()
# We have a basic setup to begin with, let's start by mining coal
# Move to the coal resource nearest to us
coal_position = nearest('coal')
move_to(coal_position)
# Now that we are at the coal resource, let's place the burner mining drill and insert coal into it
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0]-2, coal_position[1]))
# Now we need to insert coal into the mining drill to power it
insert_item('coal', target_position=(coal_position[0]-2, coal_position[1]), quantity=5)
# Check if we successfully inserted the coal into the mining drill
inspect_radius(5)
# The mining drill is running and has mined coal, let's extract it and move it to a chest
extract_item('coal', source_position=(coal_position[0]-2, coal_position[1]), quantity=5)
chest_position = (coal_position[0]-5, coal_position[1]-2)
move_to(chest_position)
place_entity('iron-chest', position=chest_position)
insert_item('coal', target_position=chest_position, quantity=5)
# Now we have coal stored in a chest, let's move to the iron ore resource, mine it and smelt it to iron plate
iron_position = nearest('iron-ore')
move_to(iron_position)
# Let's inspect the resources around us to determine if we have reached the iron ore resource
inspect_radius(5)
# Looks like we haven't found the iron ore resource yet, let's keep moving
move_to(iron_position)
# Let's check our surroundings again to check if we have reached the iron ore resource
inspect_radius(5)
# Let's keep moving towards the iron ore resource
move_to(iron_position)
