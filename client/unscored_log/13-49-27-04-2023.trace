comment("First, let's start by inspecting our surroundings and resources")
inspect_resources()
inspect_entities()
comment("Let's move to the location of the ore and harvest it")
move_to((-8, -5))
harvest_resource((-8, -5), quantity=5)
comment("Now, let's place a burner-mining-drill on the ore deposit to automate the extraction process")
move_to((-8, -5))
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=(-8, -5))
inspect_entities(radius=5)
comment("We need to fuel the burner-mining-drill with coal. Let's see if we have any coal in our inventory already.")
inspect_inventory()
comment("Looks like we don't have any coal in our inventory yet. Let's pick some up from the nearby coal deposit.")
pickup_entity('coal', nearest((-8, -5)))
comment("My apologies. Let's update the code so that it picks up coal from the resource deposit directly.")
pickup_entity('coal', (-8, -5))
comment("It looks like we still need to put coal into the mining drill. Let's do that now.")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Now let's automate the transportation of ore to a furnace for smelting.")
comment("We'll first set up a furnace at (-8, -3).")
place_entity('stone-furnace', UP, (-8, -3))
comment("It seems that we don't have enough coal to keep the burner mining drill going. Let's pick up more coal.")
pickup_entity('coal', nearest((-8, -5)))
comment("My apologies. Try running `pickup_entity('coal', (-8, -5))` instead.")
