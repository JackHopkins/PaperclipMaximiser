# First, let's inspect the resources and surroundings
inspect_resources()
# Okay, we have coal, iron ore, copper ore, stone and uranium ore resources available. Let's now inspect the entities
inspect_entities(20)
# It appears that there is only one entity and it is the player. Let's move the player to near the coal resource
coal_position = nearest('coal')
move_to(coal_position)
# Let's place a burner mining drill on the coal resource
place_entity('burner-mining-drill', direction=DOWN, position=coal_position)
# Looks like we have placed the burner mining drill on the coal resource. Let's inspect again to confirm
inspect_entities(20)
# Yes, the burner mining drill has been placed. Now, let's harvest coal using the mining drill
harvest_resource(coal_position, quantity=5)
# That should give us 5 coal. Let's check the inventory if we have the coal or not
inspect_inventory()
# My apologies. Let me fix the mistake
# Let's see if we have the coal in our inventory or not
inventory = inspect_inventory()
coal_quantity = inventory['coal']
print(f"We have {coal_quantity} coal in our inventory")
