# Lets start by checking my inventory.
# I want to automate the process of mining iron ores, smelting them into iron plates, and crafting them into iron gears. 
# For that, I need to find a good spot to set up my base. 
# I think I will head 21km northeast to check out the iron ores there. 
move_to((21000, -21000))
# I'll break the command into smaller steps to avoid timeout errors
move_to((10000, -10000))
move_to((20000, -20000))
# If that's the case, I'll try finding iron and coal resources at the current location.
# First, let me check if there is any iron_ore or coal that I can harvest 
iron_ore_position = nearest('iron-ore')
coal_position = nearest('coal')
# Now that I have found the nearest iron and coal, I will place a burner-mining-drill on them and create a trail of transport-belts leading to the nearest stone-furnace.
place_entity('burner-mining-drill', direction=LEFT, position=iron_ore_position)
move_to((iron_ore_position[0]-1, iron_ore_position[1]))
move_to((coal_position[0]-1, coal_position[1]), laying='transport-belt')
move_to(nearest('stone-furnace'), laying='transport-belt')
inspect_radius(20) # Check to ensure that the entity placement and belts have been laid properly.
