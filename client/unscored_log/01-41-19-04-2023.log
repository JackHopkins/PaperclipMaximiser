[94m# My apologies again, it seems we need to make another modification to our inventory-moving function
def move_items_between_entities(source_position, target_position, from_inventory=False, item_name=None):
    entities = inspect_entities(5)
    source_chest_inventory = None
    target_chest_inventory = None
    for entity in entities['entities']:
        if entity['type'] == 'wooden-chest' or entity['type'] == 'iron-chest':  # Update function to recognize wooden-chests too
            if entity['position'] == source_position:
                if from_inventory:
                    source_chest_inventory = check_inventory()
                else:
                    source_chest_inventory = entity
            elif entity['position'] == target_position:
                target_chest_inventory = entity
                
    if item_name is not None and source_chest_inventory is not None and target_chest_inventory is not None:
        for item, quantity in source_chest_inventory.copy().items():
            if item == item_name and quantity > 0:
                if item in target_chest_inventory:
                    target_chest_inventory[item] += quantity
                else:
                    target_chest_inventory[item] = quantity
                source_chest_inventory[item] -= quantity
                if source_chest_inventory[item] == 0:
                    del source_chest_inventory[item]
                    
    return (source_chest_inventory, target_chest_inventory)
