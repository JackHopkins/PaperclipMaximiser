comment("Inspect available resources")
resources = inspect_resources()
print(resources)
comment("Find the nearest coal and iron deposits")
coal_position = nearest('coal')
iron_position = nearest('iron-ore')
print(f"Coal position: {coal_position}")
print(f"Iron position: {iron_position}")
comment("Move to coal deposit and place a burner-mining-drill")
move_to(coal_position)
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Move to iron deposit and place a burner-mining-drill")
move_to(iron_position)
iron_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
comment("Add fuel to the burner-mining-drill for iron")
harvest_resource(coal_position, quantity=2)
insert_item('coal', target_position=iron_drill_position, quantity=1)
comment("Go back to coal deposit, place drill, and add fuel")
move_to(coal_position)
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
pickup_entity('coal', coal_position)
insert_item('coal', target_position=coal_drill_position, quantity=1)
comment("Craft a burner-mining-drill and place it")
craft_item('burner-mining-drill', quantity=1)
move_to(coal_position)
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
pickup_entity('coal', coal_position)
insert_item('coal', target_position=coal_drill_position, quantity=1)
