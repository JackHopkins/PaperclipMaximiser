entity_position = place_entity("burner-mining-drill", position=ore_position)  # place a mining drill at the coal deposit
belt_position = (ore_position[0] - 1.5, ore_position[1] - 0.5)  # calculate the position for the transport belt
move_to(belt_position)  # move to the position of the transport belt
place_entity("transport-belt", position=belt_position)  # place a transport belt
connect_entities(source_position=entity_position, target_position=belt_position, connection_type='transport-belt')  # connect the mining drill to the transport belt using an inserter.
comment("We need to connect the transport belt to the mining drill to get coal into the furnace.")
connect_entities(source_position=ore_position, target_position=entity_position, connection_type="transport-belt")  # connect the mining drill to the transport belt
comment("Let's make sure that coal is being fed into the furnace.")
connect_entities(source_position=belt_position, target_position=entity_position, connection_type="inserter")  # connect the transport belt to the furnace
comment("Oh, it looks like I made a mistake on line 6. Here we should use 'inserter' as the connection type.")
disconnect_entities(source_position=ore_position, target_position=entity_position, connection_type="transport-belt") # disconnect the mining drill from the transport belt
connect_entities(source_position=ore_position, target_position=entity_position, connection_type="inserter") # correct connection: connect the mining drill to the transport belt with an inserter instead of a transport belt
