[94m# Let's add a function to find the nearest entity from a list of entities.
def nearest_entity(entity_list):
    min_distance = float('inf')
    nearest_entity = None
    for entity in entity_list:
        distance = ((entity[0]-0)**2 + (entity[1]-0)**2)**0.5
        if distance < min_distance:
            min_distance = distance
            nearest_entity = entity
    return nearest_entity
