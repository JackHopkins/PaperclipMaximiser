comment("First let's observe the resources and landscape around us")
resources = inspect_resources()
comment("Now let's create a simple mining operation")
coal_position = nearest("coal")
move_to(coal_position)
place_entity("burner-mining-drill", direction=LEFT, exact=False, position=coal_position)
comment("I don't have any burner-mining-drill in my inventory, let's craft one")
craft_item("burner-mining-drill", quantity=1)
comment("Now that we've crafted a burner-mining-drill, let's place it")
move_to(coal_position)
place_entity("burner-mining-drill", direction=LEFT, exact=False, position=coal_position)
comment("Let's fuel the miner with coal and observe our inventory")
pickup_entity("coal", coal_position)
insert_item("coal", target_position=nearest("burner-mining-drill"), quantity=1)
inventory = inspect_inventory()
comment("I meant to harvest the coal instead of picking it up")
harvest_resource(coal_position, quantity=1)
comment("Now that we've harvested some coal, let's fuel the miner")
insert_item("coal", target_position=nearest("burner-mining-drill"), quantity=1)
comment("Now let's create a smelting setup")
stone_furnace_position = place_entity("stone-furnace", direction=LEFT, exact=False, position=(coal_position[0] - 2, coal_position[1]))
comment("Place a wooden chest to temporarily store the coal we mined")
wooden_chest_position = place_entity("wooden-chest", direction=LEFT, exact=False, position=(coal_position[0] + 2, coal_position[1]))
comment("I don't have any wooden-chests in my inventory, let's craft one")
craft_item("wooden-chest", quantity=1)
comment("I need wood to craft a wooden chest, let's find and harvest the nearest tree")
move_to(nearest("tree"))
harvest_resource(nearest("tree"), quantity=5)
