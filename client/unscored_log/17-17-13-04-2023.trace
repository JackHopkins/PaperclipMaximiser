place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', position=(coal_position[0]-1, coal_position[1]-1))
# Craft a stone-furnace since we don't have it in the inventory
craft_item('stone-furnace', quantity=1)
# Let's mine some stone to craft a stone-furnace
