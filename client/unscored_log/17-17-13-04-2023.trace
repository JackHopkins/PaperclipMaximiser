# Lets start by checking my inventory.
# Setup mining for each resource, starting with coal
coal_position = nearest('coal')
place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', position=(coal_position[0]-1, coal_position[1]-1))
# I don't have a burner-mining-drill in my inventory, so let's use an electric-mining-drill instead
coal_position = nearest('coal')
place_entity('electric-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', position=(coal_position[0]-1, coal_position[1]-1))
# Since we don't have any mining drills, let's craft a burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
