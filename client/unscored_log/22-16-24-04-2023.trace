comment("Inspect the resources around me")
resources = inspect_resources()
comment("Locate coal, iron ore, copper ore, and nearest tree positions")
coal_position = nearest('coal')
iron_ore_position = nearest('iron-ore')
copper_ore_position = nearest('copper-ore')
tree_position = nearest('tree')

comment("Build a burner-mining-drill at the closest coal position")
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))

comment("Build a burner-mining-drill at the closest iron ore position")
move_to(iron_ore_position)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_ore_position[0]-2, iron_ore_position[1]))

comment("Build a burner-mining-drill at the closest copper ore position")
move_to(copper_ore_position)
place_entity('burner-mining-drill', direction=LEFT, position=(copper_ore_position[0]-2, copper_ore_position[1]))

comment("Cut down nearest tree for wood")
move_to(tree_position)
harvest_resource(tree_position, quantity=5)

comment("Check the inventory after performing these actions")
inspect
comment("Craft burner-mining-drills for placing on resources")
craft_item('burner-mining-drill', quantity=3)
comment("Locate stone position")
stone_position = nearest('stone')
comment("Mine some stone to craft the burner-mining-drills")
move_to(stone_position)
harvest_resource(stone_position, quantity=10)
