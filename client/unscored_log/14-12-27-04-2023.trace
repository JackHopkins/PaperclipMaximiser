if stone_furnace['fuel'] == 0:
    comment("Stone furnace is out of fuel. Inserting 1 coal into the furnace for fuel")
    if 'coal' in inventory and inventory['coal'] > 0:
        insert_item('coal', target_position=stone_furnace_position, quantity=1)
        inventory['coal'] -= 1
    else:
        comment("No coal in inventory. Moving to the nearest coal position to mine some")
