comment("Inspect resources to find coal, iron, copper, and stone")
resources = inspect_resources()
comment("Find the nearest coal resource and move to it")
coal_position = nearest("coal")
move_to(coal_position)
comment("Place a burner-mining-drill on coal deposit")
place_entity("burner-mining-drill", direction=LEFT, position=(coal_position[0] - 2, coal_position[1]))
comment("Find the nearest stone resource and move to it")
stone_position = nearest("stone")
move_to(stone_position)
comment("Place a burner-mining-drill on stone deposit")
place_entity("burner-mining-drill", direction=LEFT, position=(stone_position[0] - 2, stone_position[1]))
comment("Harvest 5 stone from the stone deposit manually")
harvest_resource(stone_position, quantity=5)
comment("Craft a burner mining drill")
craft_item("burner-mining-drill", quantity=1)
comment("Place the crafted burner-mining-drill on stone deposit")
place_entity("burner-mining-drill", direction=LEFT, position=(stone_position[0] - 2, stone_position[1]))
comment("Find the nearest coal resource and move to it")
coal_position = nearest("coal")
move_to(coal_position)
