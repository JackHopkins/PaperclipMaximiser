# Now we need to connect the burner-mining-drill to our furnace using the transport belts
# Let's connect the miner drill to the furnace using transport belts
mining_position = (coal_position[0]-1, coal_position[1])
entity_to = (furnace_position[0], furnace_position[1]+1)
insert_entity = 'transport-belt'
while mining_position[1] < furnace_position[1]:
    place_entity(insert_entity, direction=UP, position=entity_to)
    entity_to = (entity_to[0], entity_to[1]-1)
    pickup_entity(insert_entity, mining_position)
