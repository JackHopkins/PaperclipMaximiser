# Let's find a location with coal and place a burner-mining-drill there
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# This coal resource may already have a mining drill. Let's check and move to another coal resource
entities = inspect_entities(20)
for entity in entities['entities']:
    if 'burner-mining-drill' in entity['type']:
        print("There is already a drill at this coal resource. Looking for another one...")
        coal_position = nearest('coal', exclude=[entity['position']])
if coal_position:
    move_to(coal_position)
    place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
else:
    print("No coal resources found.")
