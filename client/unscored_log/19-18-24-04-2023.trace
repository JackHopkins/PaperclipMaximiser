comment("Inspect the natural resources around me")
resources = inspect_resources()
comment("Find the nearest coal resource and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill at the nearest coal resource")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Find the nearest stone resource and move to it")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill at the nearest stone resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(stone_position[0]+2, stone_position[1]))
comment("Harvest some stone to craft a burner-mining-drill")
harvest_resource(stone_position, quantity=5)
craft_item('burner-mining-drill', quantity=1)
comment("Find the nearest iron resource and move to it")
iron_position = nearest('iron-ore')
move_to(iron_position)
comment("Harvest some iron to create a small electric pole")
harvest_resource(iron_position, quantity=5)
craft_item('small-electric-pole', quantity=1)
inspect_resources()
comment("Moving closer to the coal resource")
move_to(nearest('coal'))
