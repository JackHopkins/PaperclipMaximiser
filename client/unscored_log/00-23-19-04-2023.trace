# Let's start by observing our surroundings and available resources
inspect_resources()
inspect_entities(20)
# I see that there is coal nearby, so I will move to it and place a burner mining drill to extract it
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1])) 
# The burner mining drill has been placed and is mining coal. I will add a burner furnace and a transport belt to smelt the coal into iron plates.
move_to(coal_position, laying='transport-belt')
place_entity('stone-furnace', direction=LEFT, position=(coal_position[0]-4, coal_position[1]))
connect_entities(source_position=(coal_position[0]-2, coal_position[1]), target_position=(coal_position[0]-4, coal_position[1]), connection_type='transport-belt')
# I forgot that the transport belt has to be placed before connecting the entities. Let me try that again.
move_to(coal_position, laying='transport-belt')
place_entity('stone-furnace', direction=LEFT, position=(coal_position[0]-4, coal_position[1]))
place_entity('transport-belt', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
connect_entities(source_position=(coal_position[0]-2, coal_position[1]), target_position=(coal_position[0]-4, coal_position[1]), connection_type='transport-belt')
# I forgot to craft a stone furnace before I tried to place it. I will do that first.
craft_item('stone-furnace', quantity=1)
move_to(coal_position, laying='transport-belt')
place_entity('stone-furnace', direction=LEFT, position=(coal_position[0]-4, coal_position[1]))
place_entity('transport-belt', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
connect_entities(source_position=(coal_position[0]-2, coal_position[1]), target_position=(coal_position[0]-4, coal_position[1]), connection_type='transport-belt')
# I don't have enough resources to craft a stone furnace. I will look for stones in the vicinity and mine them.
stones_position = nearest('stone')
move_to(stones_position)
harvest_resource(stones_position, quantity=10)
# I don't see any stones nearby to harvest. Let me look for a new location.
new_position = (0, -20)
move_to(new_position)
stones_position = nearest('stone')
move_to(stones_position)
harvest_resource(stones_position, quantity=10)
# There are no stones to harvest here too. Let me look for a new location to find stones.
new_position = (15, 5)
move_to(new_position)
stones_position = nearest('stone')
move_to(stones_position)
harvest_resource(stones_position, quantity=10)
# I need to find a place where I can extract some stones. I will look for some cliffs nearby.
cliff_position = nearest('cliff')
move_to(cliff_position)
place_entity('stone-furnace', direction=LEFT, position=(cliff_position[0]+2, cliff_position[1]))
place_entity('transport-belt', direction=LEFT, position=(cliff_position[0], cliff_position[1]-1))
connect_entities(source_position=(cliff_position[0], cliff_position[1]-1), target_position=(cliff_position[0]+2, cliff_position[1]), connection_type='transport-belt')
# I may have timed out previously because the current location was too far from the nearest cliff. I will search for cliffs again, closer to me.
cliff_position = nearest('cliff')
move_to(cliff_position)
place_entity('stone-furnace', direction=LEFT, position=(cliff_position[0]+2, cliff_position[1]))
place_entity('transport-belt', direction=LEFT, position=(cliff_position[0], cliff_position[1]-1))
connect_entities(source_position=(cliff_position[0], cliff_position[1]-1), target_position=(cliff_position[0]+2, cliff_position[1]), connection_type='transport-belt')
