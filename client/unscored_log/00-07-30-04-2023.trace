comment("Step 1: Find nearest coal deposit and place a burner mining drill")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal_position)
comment("Check inventory for necessary ingredients to craft a burner-mining-drill")
inventory = inspect_inventory()
comment("Step 1.1: Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Step 1.2: Find nearest coal deposit and place a burner mining drill")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal_position)
comment("Step 2: Place a stone-furnace to the right of the burner-mining-drill to smelt the iron ore")
burner_drill_position = (-9, -6)
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=RIGHT, gap=1)
