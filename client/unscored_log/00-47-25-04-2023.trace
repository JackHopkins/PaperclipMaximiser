comment("Check the available natural resources and landscape around")
resources = inspect_resources()
print(resources)
comment("Find the nearest coal deposit and move to it")
coal_position = nearest("coal")
move_to(coal_position)
comment("Place a burner-mining-drill near the coal deposit")
place_entity("burner-mining-drill", direction=LEFT, position=nearest_buildable("burner-mining-drill"))
comment("Find the nearest stone deposit and move to it")
stone_position = nearest("stone")
move_to(stone_position)
comment("Place a burner-mining-drill near the stone deposit")
place_entity("burner-mining-drill", direction=LEFT, position=nearest_buildable("burner-mining-drill"))
comment("Check the inventory for required items")
inventory = inspect_inventory()
comment("Craft a burner-mining-drill")
craft_item("burner-mining-drill", quantity=1)
comment("Move to the stone deposit again")
move_to(stone_position)
comment("Place the burner-mining-drill near the stone deposit")
place_entity("burner-mining-drill", direction=LEFT, position=nearest_buildable("burner-mining-drill"))
comment("Find a valid buildable position for the burner-mining-drill near the stone deposit")
valid_position = nearest_buildable("burner-mining-drill", minable=True)
move_to(valid_position)
comment("Place the burner-mining-drill near the stone deposit")
place_entity("burner-mining-drill", direction=LEFT, position=valid_position)
comment("Make sure we are at the stone position before trying to place the mining drill")
move_to(stone_position)
comment("Find a valid buildable position for the burner-mining-drill on the same tile as the stone deposit")
valid_position = nearest_buildable("burner-mining-drill", minable=True)
comment("Move to the valid position")
move_to(valid_position)
comment("Place the burner-mining-drill at the valid position")
place_entity("burner-mining-drill", direction=LEFT, position=valid_position)
comment("Change the approach by placing the burner-mining-drill on the nearest buildable tile within 5 meters of the stone deposit")
valid_position = nearest_buildable("burner-mining-drill", minable=True, radius=5)
move_to(valid_position)
comment("Place the burner-mining-drill at the valid position")
place_entity("burner-mining-drill", direction=LEFT, position=valid_position)
