comment("First, let's inspect the resources available to us")
inspect_resources()
comment("Now let's gather some ores")
ore = nearest('iron-ore')
move_to(ore)
harvest_resource(ore, quantity=10)
comment("We can only harvest what is available on the ground right now, let's look into processing the ores we've gathered.")
ore_qty = inspect_inventory()['iron-ore']
comment(f"We have {ore_qty} iron ores in our inventory.")
comment("It looks like one of our burner mining drills is out of fuel and cannot output its contents. We'll need to find a solution to alleviate the blockage.")
comment("Let's start by picking up and inserting fuel directly into the burner mining drill at (-5, -7):")
pickup_entity('coal', nearest('coal', position=(-5,-7)))
insert_item('coal', target_position=(-5,-7), quantity=1)
comment("It looks like there are no coal entities that we can pickup, let's try inserting fuel from our inventory:") 
insert_item('coal', nearest('burner-mining-drill', position=(-5,-7)))
comment("This did not work, so let's place a transport belt next to the burner mining drill. That should allow the items in the output to be transported away and clear the space for fuel to be inserted.") 
place_entity_next_to('transport-belt', reference_position=(-5,-7), gap=1)
comment("Let's place a belt and connect it to the drill at (-5,-7):")
place_entity_next_to('transport-belt',reference_position=(-5,-7),direction=LEFT,gap=1)
source_pos = nearest('burner-mining-drill', position=(-5,-7))
target_pos = entity_position
connect_entities(source_pos, target_pos, connection_type='transport-belt', side=False, method='smart')
comment("Let's connect the burner mining drill at (-5,-7) to the transport belt: ")
connect_entities(source_position=nearest('burner-mining-drill', position=(-5,-7), entity_type='burner-mining-drill'),
                 target_position=nearest('transport-belt', position=(-5,-7)))
connect_entities(source_position=(-5,-8), target_position=(-6,-8), connection_type='transport-belt')
comment("Let's move to the output of burner mining drill and try that again:") 
move_to(nearest('burner-mining-drill', position=(-5,-7))) 
connect_entities(source_position=(0,-1), target_position=(-1,-1), connection_type='transport-belt')
comment("Let's inspect entities and check if burner inserters need fuel") 
inspect_entities() 
insert_item('coal', target_position=nearest('burner-inserter', position=(-5.5,-5.5))) 
insert_item('coal', target_position=nearest('burner-inserter', position=(-4.5,-5.5))) 
inspect_inventory()
comment("Let's try connecting again:") 
connect_entities(source_position=(-5,-8), target_position=(-6,-8), connection_type='transport-belt')
comment("Let's check our inventory and insert some coal into the burner inserters:") 
inventory = inspect_inventory()
if inventory['coal'] < 2:
    harvest_resource((-2,0), 2)
insert_item('coal', target_position=nearest('burner-inserter'), quantity=2)
comment("Now that we've fueled our inserter, let's inspect to check that the burner mining drill is working:") 
inspect_entities()
comment("Ok, it seems like the output of the burner mining drill is full. We need to place a transport belt to take the output into a nearby furnace.") 
place_entity_next_to('transport-belt', nearest('burner-mining-drill'), direction=LEFT, gap=1)
place_entity('stone-furnace', nearest('transport-belt', position=(-8.5,-4.5)), direction=UP)
comment("Let's make sure to specify the correct parameter for `place_entity_next_to`") 
place_entity_next_to('transport-belt', nearest('burner-mining-drill'), direction=LEFT, gap=1)
