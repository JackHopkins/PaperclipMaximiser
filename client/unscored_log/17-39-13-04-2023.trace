# Lets start by checking my inventory.
# Let's start by placing mining drills and furnaces for coal, iron, stone, and copper and set up belt routes
coal_position = nearest('coal')
iron_position = nearest('iron_ore')
stone_position = nearest('stone')
copper_position = nearest('copper_ore')
place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', direction=2, position=(coal_position[0]+2, coal_position[1]))
move_to((coal_position[0]-1, coal_position[1]), laying='transport-belt')
move_to((stone_position[0]+1, stone_position[1]), laying='transport-belt')
# Let's continue with placing mining drills and furnaces for iron, stone, and copper
