comment("Observe and describe the natural resources and landscape around you")
resources = inspect_resources()
resources
comment("Find the nearest coal and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill at the nearest buildable position")
place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill'))
comment("Find the nearest stone and move to it")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill at the nearest buildable position")
place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill'))
comment("Move to the nearest water source")
water_position = nearest('water')
move_to(water_position)
comment("Craft an offshore pump")
craft_item('offshore-pump', quantity=1)
comment("Check item inventory")
inspect_inventory()
comment("Place the offshore pump in the water")
place_entity('offshore-pump', direction=SOUTH, position=nearest_buildable('offshore-pump', target_type='water'))
comment("Craft 1 boiler and 1 steam engine")
craft_item('boiler', quantity=1)
craft_item('steam-engine', quantity=1)
comment("Place the boiler close to the offshore pump")
boiler_position = place_entity('boiler', direction=EAST, position=nearest_buildable('boiler'))
comment("Place the steam engine next to the boiler")
place_entity('steam-engine', direction=EAST, position=nearest_buildable('steam-engine', reference_position=boiler_position, direction=EAST, gap=0))
comment("Craft 1 small electric pole")
craft_item('small-electric-pole', quantity=1)
comment("Place the small electric pole between the boiler and steam engine")
pole_position = place_entity('small-electric-pole', direction=EAST, position=nearest_buildable('small-electric-pole', reference_position=boiler_position, direction=EAST, gap=0))
comment("Connect the small electric pole to the boiler and steam engine")
connect_entities(source_position=boiler_position, target_position=pole_position, connection_type='PowerLine')
connect_entities(source_position=steam_engine_position, target_position=pole_position, connection_type='PowerLine')
comment("Gather coal to fuel the boiler and mining operations")
move_to(nearest('coal'))
harvest_resource(nearest('coal'), quantity=10)
comment("Insert coal into the boiler")
insert_item('coal', target_position=boiler_position, quantity=5)
comment("Setup burner mining drill to extract coal")
coal_mining_position = place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill', ore=coal_position))
comment("Insert coal into the burner mining drill")
insert_item('coal', target_position=coal_mining_position, quantity=5)
comment("Setup a stone furnace for iron smelting")
move_to(nearest('iron_ore'))
iron_mining_position = place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill', ore=stone_position))
stone_furnace_position = place_entity('stone-furnace', direction=RIGHT, position=nearest_buildable('stone-furnace', reference_position=iron_mining_position, direction=RIGHT, gap=1))
comment("Insert coal into the burner mining drill for iron ore")
insert_item('coal', target_position=iron_mining_position, quantity=5)
comment("Connect the iron ore mining drill's output to the stone furnace's input using an inserter")
inserter_position = connect_entities(source_position=iron_mining_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Insert coal into the stone furnace")
insert_item('coal', target_position=stone_furnace_position, quantity=5)
comment("Setup a stone furnace and burner mining drill near copper_ore for smelting")
move_to(nearest('copper_ore'))
copper_ore_position = nearest('copper_ore')
copper_mining_position = place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill', ore=copper_ore_position))
copper_furnace_position = place_entity('stone-furnace', direction=RIGHT, position=nearest_buildable('stone-furnace', reference_position=copper_mining_position, direction=RIGHT, gap=1))
comment("Insert coal into the burner mining drill for copper ore")
insert_item('coal', target_position=copper_mining_position, quantity=5)
