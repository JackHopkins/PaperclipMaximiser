comment("Find coal deposit and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill near the coal deposit")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Move to the coordinates (-10, -5)")
move_to((-10, -5))
