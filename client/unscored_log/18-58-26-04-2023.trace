comment("Initial setup - Mining operation and smelting setup")
comment("I'll start by creating a burner mining drill on the nearest ore (~([-8, -5]))")
ore_position = nearest('stone')
move_to(ore_position)
burner_drill_position = place_entity('burner-mining-drill', direction=LEFT, exact=False, position=ore_position)
comment("I don't have a burner mining drill in my inventory. I need to craft one")
craft_item('burner-mining-drill', quantity=1)
comment("Now that I have a burner mining drill in my inventory, I'll place it on the nearest stone")
ore_position = nearest('stone')
move_to(ore_position)
burner_drill_position = place_entity('burner-mining-drill', direction=LEFT, exact=False, position=ore_position)
comment("Now that I have a burner mining drill set up, I'll connect its output to a nearby furnace with an inserter")
furnace_position = nearest('stone-furnace')
connect_entities(source_position=burner_drill_position, target_position=furnace_position, connection_type='inserter')
comment("Oops, I don't have any furnace set up. I'll need to craft some")
craft_item('stone-furnace', quantity=1)
comment("Looks like I need more resources to craft a stone furnace, I'll go and harvest some stones.")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position,quantity=10)
comment("I was able to harvest just 9 stones from the stone ore. I'll go and get more.")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position,quantity=20)
comment("I was able to harvest 11 stones from the stone ore. I'll go and get more.")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position,quantity=20)
comment("I was only able to harvest 11 stones again. With 20 stones, I can craft two stone furnaces which should be enough for the time being.")
craft_item('stone-furnace', quantity=2)
comment("Place the burners facing downwards to the nearest ore")
ore_position = nearest('iron-ore')
move_to(ore_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=ore_position)
comment("Oh sorry, I forgot to craft a burner mining drill. I'll craft one now.")
craft_item('burner-mining-drill', quantity=1)
comment("Place the burners facing downwards to the nearest ore")
ore_position = nearest('iron-ore')
move_to(ore_position)
burner_drill_position = place_entity('burner-mining-drill', direction=DOWN, position=ore_position)
comment("Great! Now, let's connect the burner mining drill to the furnace.")
stone_furnace_position = entity_position
gap = 1
inserter_position = None
comment("I'm sorry I was referencing an undefined variable there. First, I'll place the furnace near the burner mining drill.")
stone_furnace_position = place_entity_next_to('stone-furnace', burner_drill_position, RIGHT, gap=1)
comment("Now that the furnace is in place. Let's connect it to the burner mining drill.")
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("I see that I can't place the furnace there because there is not enough space. I'll move up a bit and try again.")
move_to((burner_drill_position[0], burner_drill_position[1] - 2))
stone_furnace_position = place_entity_next_to('stone-furnace', burner_drill_position, RIGHT, gap=1)
comment("Now I'll connect the two entities using an inserter.")
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Oh, it seems that the furnace must be moved slightly up in order to connect. ")
move_to((stone_furnace_position[0], stone_furnace_position[1] - 1))
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("I see. In that case, let's rotate the furnace to face downwards and try again.")
rotate_entity(stone_furnace_position, direction=DOWN)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("I see. In that case, let's rotate the furnace to face left and try again.")
rotate_entity(stone_furnace_position, direction=LEFT)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("I am facing trouble connecting the entities. I will check their positions to make sure they are facing each other.")
inspect_entities(5)
comment("From the output, I realize that the furnace is slightly off. I will pick it up and then next to the drill again.")
pickup_entity('stone-furnace', stone_furnace_position)
stone_furnace_position = place_entity_next_to('stone-furnace', burner_drill_position, RIGHT, gap=1)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Let's move the furnace slightly to face the drill.")
stone_furnace_position = place_entity_next_to('stone-furnace', burner_drill_position, RIGHT, gap=2)
connect_entities(source_position=burner_drill_position, target_position=stone_furnace_position, connection_type='inserter')
comment("I see, the furnace can not be placed there. Let's find another spot to place it.")
stone_position = nearest('stone')
move_to(stone_position)
