comment("First, let's inspect our surroundings and available resources")
inspect_resources()
comment("Next, let's move to the location of our ore deposit")
move_to(ore)
comment("Once we've arrived at the ore deposit, let's place a burner-mining-drill on it and connect it with a transport belt.")
drill_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore)
belt_position = place_entity_next_to('transport-belt', drill_position, direction=RIGHT, gap=1)
connect_entities(source_position=drill_position, target_position=belt_position, connection_type='transport-belt')
comment("It looks like we don't have a burner mining drill in our inventory. Let's craft one first.")
craft_item('burner-mining-drill', quantity=1)
comment("Now, let's place the burner-mining-drill on the ore deposit and connect it with a transport belt.")
drill_position = place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore)
comment("Now, let's connect the burner-mining-drill with a transport belt.")
belts = ['transport-belt'] * 5
for i in range(5):
    insert_item(belts[i], target_position=drill_position, quantity=1)
