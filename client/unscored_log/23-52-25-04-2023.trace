comment("Place a steam engine next to the boiler")
craft_item('steam-engine', quantity=1)
place_entity('boiler', direction=UP, position=(offshore_pump_position[0] + 2, offshore_pump_position[1]))
boiler_position = (offshore_pump_position[0] + 2, offshore_pump_position[1])
place_entity('steam-engine', direction=UP, position=(boiler_position[0] + 3, boiler_position[1]))
steam_engine_position = (boiler_position[0] + 3, boiler_position[1])
comment("Place an offshore pump and connect it to the boiler with pipes")
craft_item('offshore-pump', quantity=1)
place_entity('offshore-pump', direction=UP, position=offshore_pump_position)
craft_item('pipe', quantity=1)
connect_entities(offshore_pump_position, boiler_position, connection_type='pipe')
