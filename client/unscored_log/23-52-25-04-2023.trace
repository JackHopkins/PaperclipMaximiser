comment("Inspect the water resource and select a location near water")
water_resource = resources['water'][0]
min_coordinates = water_resource['min_coordinates']
max_coordinates = water_resource['max_coordinates']
water_edge = (max_coordinates[0], (min_coordinates[1] + max_coordinates[1]) // 2)
move_to(water_edge)
comment("Set up a steam engine and boiler system for power generation")
inventory = inspect_inventory()
comment("Craft and place the necessary items for a steam engine and boiler system")
if 'offshore-pump' not in inventory or inventory['offshore-pump'] < 1:
    craft_item('offshore-pump', quantity=1)
comment("Place an offshore pump near the selected water location")
place_entity('offshore-pump', direction=UP, position=water_edge)
offshore_pump_position = (water_edge[0], water_edge[1] + 1)
comment("Craft and place the necessary items for a steam engine and boiler system")
if 'boiler' not in inventory or inventory['boiler'] < 1:
    craft_item('boiler', quantity=1)
if 'steam-engine' not in inventory or inventory['steam-engine'] < 1:
    craft_item('steam-engine', quantity=1)
