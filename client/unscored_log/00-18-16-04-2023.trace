    move_to(assembling_machine_pos)
    place_entity('assembling-machine-1', direction=DOWN, position=assembling_machine_pos)
    insert_item('iron-plate', target_position=assembling_machine_pos, quantity=check_inventory()['iron-plate'])
    craft_item('iron-gear-wheel', quantity=check_inventory()['iron-plate'])
