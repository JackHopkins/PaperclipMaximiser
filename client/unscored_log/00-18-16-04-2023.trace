extract_item('iron-ore', source_position=iron_ore_pos, quantity=iron_ore_count)
# Command 3: Check if an entity that can be extracted from is in the vicinity of the iron ore
iron_ore_pos = nearest('iron-ore')
mining_drills = [entity for entity in inspect_entities(10).keys() if 'mining' in entity and 'drill' in entity and 'burner' in entity]
if mining_drills:
    move_to(iron_ore_pos)
    place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_pos[0], iron_ore_pos[1]))
    extract_item('iron-ore', source_position=iron_ore_pos, quantity=check_inventory()['iron-ore'])
else:
    print("We need a burner mining drill in our surroundings to proceed.")
# Command 4: Place a furnace, power it using a coal-fired boiler and insert the mined iron ore into the furnace
power_sources = [entity for entity in inspect_entities(10).keys() if 'boiler' in entity and 'coal' in inspect_entities(10)[entity]]
if power_sources:
    iron_ore_pos = nearest('iron-ore')
    iron_plate_pos = nearest('stone-furnace', position=iron_ore_pos)
    move_to(iron_plate_pos)
    place_entity('stone-furnace', direction=DOWN, position=iron_plate_pos)
    insert_item('iron-ore', target_position=iron_plate_pos, quantity=check_inventory()['iron-ore'])
else:
    print("We need a coal-fired boiler in our surroundings to proceed.")
# Command 5: Place an assembling machine and craft iron-gear-wheels 
