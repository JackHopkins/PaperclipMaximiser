# With this inventory, it is possible to create a simple factory that will produce iron-gear-wheels
# Command 4: Set up a simple factory and craft iron-gear-wheels
power_sources = [entity for entity in inspect_entities(10).keys() if 'boiler' in entity and 'coal' in inspect_entities(10)[entity]]
if power_sources:
    iron_ore_pos = nearest('iron-ore', position=(0, 0))
    coal_pos = nearest('coal', position=iron_ore_pos)
    furnace_pos = (iron_ore_pos[0] + 2, iron_ore_pos[1])
    assembler_pos = (furnace_pos[0] + 2, furnace_pos[1])
    chest_pos = (assembler_pos[0] + 2, assembler_pos[1])
    move_to(coal_pos)
    place_entity('burner-mining-drill', direction=DOWN, position=(coal_pos[0], coal_pos[1] - 2))
    move_to(iron_ore_pos)
    place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_pos[0], iron_ore_pos[1] - 2))
    move_to(furnace_pos)
    place_entity('stone-furnace', direction=DOWN, position=furnace_pos)
    move_to(assembler_pos)
    place_entity('assembling-machine-1', direction=DOWN, position=assembler_pos)
    set_entity_recipe(assembler_pos, recipe='iron-gear-wheel')
    while check_inventory()['coal'] > 0 and check_inventory()['iron-ore'] > 0:
        craft_item('iron-gear-wheel', quantity=1)
        insert_item('iron-gear-wheel', target_position=chest_pos, quantity=check_inventory()['iron-gear-wheel'])
else:
    print("We need a coal-fired boiler in our surroundings to proceed.")
# Command 5: Create a belt to transport the iron-gear-wheels
if check_inventory()['transport-belt'] > 0 and check_inventory()['iron-gear-wheel'] > 0:
    gear_wheel_pos = (chest_pos[0] + 2, chest_pos[1])
    belt_pos = nearest('transport-belt', position=chest_pos)
    move_to(belt_pos)
    place_entity('transport-belt', direction=RIGHT, position=belt_pos)
    move_to(gear_wheel_pos)
    insert_item('iron-gear-wheel', target_position=belt_pos, quantity=check_inventory()['iron-gear-wheel'])
else:
    print("We need more transport belts or iron gear wheels to proceed.")
# Command 6: Let's add one more command to connect the coal resource to the boilers, thus resolving our energy problem 
# Command 6: Connect the coal resource to the boilers to keep our system running
power_sources = [entity for entity in inspect_entities(10).keys() if 'boiler' in entity and 'coal' in inspect_entities(10)[entity]]
if power_sources:
    boilers = power_sources
    coal_pos = nearest('coal', position=boilers[0])
    move_to(coal_pos)
    place_entity('inserter', direction=RIGHT, position=coal_pos)
    move_to(boilers[0])
    insert_item('coal', target_position=boilers[0], quantity=check_inventory()['coal'])
else:
    print("We need a coal-fired boiler in our surroundings to proceed.")
# Let's make a better use of our resources, we can now optimize the process by crafting iron plates in a more efficient way
# Command 4: Craft iron plates
power_sources = [entity for entity in inspect_entities(10).keys() if 'boiler' in entity and 'coal' in inspect_entities(10)[entity]]
if power_sources:
    iron_ore_pos = nearest('iron-ore', position=(0, 0))
    coal_pos = nearest('coal', position=iron_ore_pos)
    furnace_pos = (iron_ore_pos[0] + 2, iron_ore_pos[1])
    iron_furnace_pos = (furnace_pos[0] + 2, furnace_pos[1])
    assembler_pos = (iron_furnace_pos[0] + 2, iron_furnace_pos[1])
    chest_pos = (assembler_pos[0] + 2, assembler_pos[1])
    move_to(coal_pos)
    place_entity('burner-mining-drill', direction=DOWN, position=(coal_pos[0], coal_pos[1] - 2))
    move_to(iron_ore_pos)
    place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_pos[0], iron_ore_pos[1] - 2))
    move_to(furnace_pos)
    place_entity('stone-furnace', direction=DOWN, position=furnace_pos)
    move_to(iron_furnace_pos)
    place_entity('stone-furnace', direction=DOWN, position=iron_furnace_pos)
    set_entity_recipe(iron_furnace_pos, recipe='iron-plate')
    move_to(assembler_pos)
    place_entity('assembling-machine-1', direction=DOWN, position=assembler_pos)
    set_entity_recipe(assembler_pos, recipe='iron-gear-wheel')
    while check_inventory()['coal'] > 0 and check_inventory()['iron-ore'] > 0:
        craft_item('iron-gear-wheel', quantity=1)
        insert_item('iron-gear-wheel', target_position=chest_pos, quantity=check_inventory()['iron-gear-wheel'])
        craft_item('iron-plate', quantity=1)
        insert_item('iron-plate', target_position=chest_pos, quantity=check_inventory()['iron-plate'])
else:
