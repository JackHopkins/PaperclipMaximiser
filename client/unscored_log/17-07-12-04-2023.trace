# Lets start by checking my inventory.
# First, I will create a basic mining setup for coal, iron, copper, and stone resources.
# Then, I will move to the nearest tree and start placing the production facilities.
# Setting up coal mining
move_to(nearest('coal'))
place_entity('burner-drill', direction=2, position=nearest('coal'))
place_entity('stone-furnace', direction=2, position=(1, 0))
insert_item('coal', target_position=(0, 0), quantity=1)
