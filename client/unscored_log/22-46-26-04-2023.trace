comment("Check available resources and landscape around")
resources = inspect_resources()
comment("Find nearest coal deposit")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal deposit")
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
comment("Pick up coal from the ground")
pickup_entity('coal', (-5, -7))
comment("Harvest 5 coal from the coal deposit")
harvest_resource(coal_position, quantity=5)
comment("Fuel the burner-mining-drill with coal")
insert_item('coal', target_position=(-5, -7), quantity=1)
comment("Insert 1 coal into the burner-mining-drill to provide fuel")
insert_item('coal', target_position=(-5, -7), quantity=1)
comment("Check inventory for coal")
inspect_inventory()
comment("Move to the iron ore deposit")
iron_ore_position = (22, -14)
move_to(iron_ore_position)
comment("Place a chest next to the burner-mining-drill to collect output")
place_entity('iron-chest', direction=RIGHT, exact=False, position=(-5, -7))
comment("Move to the iron ore deposit")
move_to(iron_ore_position)
comment("Check if the iron chest was not placed correctly")
inspect_entities(radius=5)
comment("Retry placing the iron chest next to the burner-mining-drill")
place_entity('iron-chest', direction=LEFT, exact=False, position=(-5, -7))
comment("Craft an iron chest before placing it")
craft_item('iron-chest', quantity=1)
comment("Place the iron chest next to the burner-mining-drill")
place_entity('iron-chest', direction=LEFT, exact=False, position=(-5, -7))
place_entity('iron-chest', direction=LEFT, exact=False, position=(-5, -7))
comment("Check the inventory for available resources")
inspect_inventory()
comment("Craft iron chest with available iron plate")
craft_item('iron-chest', quantity=1)
comment("Make sure there are enough iron plates to craft an iron chest in the inventory")
number_of_iron_plates_needed = 8
