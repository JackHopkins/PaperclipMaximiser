comment("Inspect resources around me")
resources = inspect_resources()
comment("Find the nearest coal patch")
coal_position = nearest('coal')
comment("Move to the coal patch")
move_to(coal_position)
comment("Place a burner-mining-drill on the coal patch")
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1] + 2))
comment("Find the nearest iron patch")
iron_position = nearest('iron-ore')
comment("Move to the iron patch")
move_to(iron_position)
comment("Place a burner-mining-drill on the iron patch")
place_entity('burner-mining-drill', direction=DOWN, position=(iron_position[0], iron_position[1] + 2))
comment("Harvest 5 coal to craft a burner-mining-drill")
harvest_resource(coal_position, quantity=5)
comment("Pick up some coal from the placed burner-mining-drill")
pickup_entity('coal', source_position=nearest('burner-mining-drill'))
comment("Fix the syntax error and pick up some coal from the placed burner-mining-drill")
pickup_entity('coal', position=nearest('burner-mining-drill'))
comment("Move to the nearest coal burner-mining-drill")
move_to(nearest('burner-mining-drill'))
comment("Harvest coal directly from the burner-mining-drill")
harvest_resource(nearest('burner-mining-drill'), quantity=5)
comment("Craft stone furnace to smelt resources")
craft_item('stone-furnace', quantity=1)
comment("Harvest stones needed to craft stone furnace")
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=10)
comment("Craft stone furnace to smelt resources")
craft_item('stone-furnace', quantity=1)
comment("Place the stone furnace near the coal burner-mining-drill")
coal_position = nearest('burner-mining-drill')
move_to(coal_position)
furnace_position = (coal_position[0] - 3, coal_position[1])
place_entity('stone-furnace', position=furnace_position)
comment("Craft an inserter to transfer coal from the mining drill to the stone furnace")
craft_item('inserter', quantity=1)
comment("Harvest iron to craft inserter and some additional iron for later use")
iron_position = nearest('iron-ore')
move_to(iron_position)
harvest_resource(iron_position, quantity=15)
comment("Craft the inserter now that we have the required resources")
craft_item('inserter', quantity=1)
comment("Place the inserter to transfer coal from the mining drill to the stone furnace")
move_to(coal_position)
inserter_position = (coal_position[0]-2, coal_position[1])
place_entity('inserter', position=inserter_position, direction=LEFT)
comment("Craft an electric mining drill for iron and copper extraction")
craft_item('electric-mining-drill', quantity=2)
comment("Setup power generation using coal-fired boilers and steam engines")
comment("Craft 1 offshore pump, 2 boilers, and 4 steam engines")
craft_item('offshore-pump', quantity=1)
craft_item('boiler', quantity=2)
craft_item('steam-engine', quantity=4)
comment("Find nearest iron ore deposit and place an electric mining drill to extract it")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
place_entity('electric-mining-drill', direction=DOWN, position=(iron_ore_position[0]-2, iron_ore_position[1]))
comment("Find another iron ore deposit and place an electric mining drill")
iron_ore_position = nearest('iron-ore', exclude_position=iron_ore_position)
move_to(iron_ore_position)
place_entity('electric-mining-drill', direction=DOWN, position=(iron_ore_position[0]-2, iron_ore_position[1]))
comment("Find the correct position on the iron ore deposit to place the electric mining drill")
iron_ore_deposit = inspect_resources()
iron_ore_position = (iron_ore_deposit['iron-ore'][0][0], iron_ore_deposit['iron-ore'][0][1])
move_to(iron_ore_position)
place_entity('electric-mining-drill', direction=DOWN, position=(iron_ore_position[0], iron_ore_position[1]))
comment("Inspect iron ore deposit coordinates and adjust position to place electric mining drill")
iron_ore_deposit = inspect_resources()
iron_ore_position = iron_ore_deposit['iron-ore'][0]
move_to(iron_ore_position)
place_entity('electric-mining-drill', direction=DOWN, position=(iron_ore_position[0], iron_ore_position[1]))
comment("Inspect entities and fix position to place the electric mining drill on the iron ore deposit")
entities = inspect_entities(20)
for entity in entities:
    if entity['name'] == 'iron-ore':
        iron_ore_position = (entity['position'][0], entity['position'][1])
        break
