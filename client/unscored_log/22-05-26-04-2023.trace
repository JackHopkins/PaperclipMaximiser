comment("First, let's inspect the resources around us")
inspect_resources()
comment("Let's assign a variable for the ore location")
ore = (-8, -5)
comment("Next, let's move to the ore location and mine it using a burner-mining-drill")
move_to(ore)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore)
comment("It looks like we need to craft a burner mining drill first, let's check our inventory and see if we have the necessary items for crafting")
inventory = inspect_inventory()
comment("It looks like the burner mining drill I placed earlier is out of fuel, let's refuel it with the coal we have in our inventory") 
comment("Refuel the burner mining drill with coal")
insert_item('coal', target_position=(ore[0]+2, ore[1]), quantity=20)
comment("Now, let's place a stone furnace and smelt the ore into iron plates using coal as a fuel source") 
furnace_position = (ore[0]+5, ore[1])
place_entity('stone-furnace', direction=RIGHT, exact=False, position=furnace_position )
connect_entities(source_position=(ore[0]+2, ore[1]), target_position=furnace_position, connection_type='inserter')
insert_item('coal', target_position=furnace_position, quantity=20)
set_entity_recipe(furnace_position, recipe='iron-plate')
