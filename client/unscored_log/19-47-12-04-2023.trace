# Let's try another approach to place the electric-mining-drill
move_to((27, -9))
place_entity('electric-mining-drill', direction=1, position=(26, -10))
# Let's inspect the area within a 20-meter radius to find a suitable location to place the electric-mining-drill
inspect_radius(20)
# It seems there are no entities in the inspected radius. Let's try placing the electric-mining-drill on the closest iron ore location.
move_to((23, -14))
place_entity('electric-mining-drill', direction=1, position=(23, -14))
# Let's move to the center of the iron_ore patch and try again.
move_to((26, -9))
