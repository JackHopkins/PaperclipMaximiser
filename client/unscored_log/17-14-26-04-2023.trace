comment("Initial setup")
comment("Let's start by placing a burner mining drill on the iron ore patch")
ore_position = (-8, -5)
move_to(ore_position)
miner_position = place_entity('burner-mining-drill', direction=DOWN, exact=True, position=ore_position)
coal_position = nearest('coal')
move_to(coal_position)
comment("We need to craft a burner mining drill first and then place it on the iron ore patch")
comment("To do that, we will start by inspecting our inventory to see what resources we have")
inventory = inspect_inventory()
print(inventory)  comment("Let's see what we have in our inventory")
