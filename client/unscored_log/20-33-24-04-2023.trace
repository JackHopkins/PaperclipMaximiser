comment("Inspect the resources and landscape around me")
resources = inspect_resources()
comment("Find the nearest coal resource and place a burner-mining-drill")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Pick up coal near the burner-mining-drill and insert it into the drill for fuel")
pickup_entity('coal', (coal_position[0]-2, coal_position[1]))
insert_item('coal', target_position=(coal_position[0]-2, coal_position[1]), quantity=1)
comment("Let's start by inspecting resources around us")
resources = inspect_resources()
comment("Initial resources inspection")
print(resources)
