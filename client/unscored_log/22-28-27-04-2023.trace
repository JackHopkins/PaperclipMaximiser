comment("First, let's observe the resources and landscape around me")
resources = inspect_resources()
comment("Next, I'll find the nearest coal patch and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Now, I'll place a burner-mining-drill on the coal patch")
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal_position)
comment("I'll check the entities around me to make sure the burner-mining-drill has been placed")
inspect_entities(5)
comment("Now, I'll set up a stone furnace for smelting")
furnace_position = (coal_position[0] + 3, coal_position[1])
move_to(furnace_position)
place_entity('stone-furnace', position=furnace_position)
comment("I need to refuel the burner-mining-drill and add ingredients to smelt")
comment("First, I'll pick up coal from the coal patch")
pickup_entity('coal', coal_position)
comment("Oops, I meant to harvest coal from the coal patch")
harvest_resource(coal_position, quantity=5)
comment("I need to move closer to harvest the coal")
move_to(coal_position)
