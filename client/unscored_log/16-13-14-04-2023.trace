# Lets start by checking my inventory.
# Place burner-mining-drills on coal, iron_ore, and copper_ore
coal_position = (-12, -9)
iron_position = (26, -9)
copper_position = (26, 10)
place_entity('burner-mining-drill', direction=RIGHT, position=coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=iron_position)
place_entity('burner-mining-drill', direction=LEFT, position=copper_position)
# My apologies for the error. We can only place one burner-mining-drill. Let's just focus on the iron_ore.
pickup_entity(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=iron_position)
# Great, let's place a stone-furnace next to the burner-mining-drill on iron_ore
furnace_position = (iron_position[0] - 1, iron_position[1])
place_entity('stone-furnace', position=furnace_position)
# My apologies for the error. Let's correct the furnace_position and try again.
furnace_position = (iron_position[0] - 2, iron_position[1])
place_entity('stone-furnace', position=furnace_position)
# Now that we have a stone-furnace in place, let's fuel the burner-mining-drill and stone-furnace with coal.
insert_item('coal', target_position=iron_position, quantity=5)
insert_item('coal', target_position=furnace_position, quantity=5)
# Now we'll set up an assembling-machine-1 to automate the production of iron-gear-wheels
assembling_position = (iron_position[0] - 4, iron_position[1])
place_entity('assembling-machine-1', direction=UP, position=assembling_position)
set_entity_recipe(assembling_position, recipe='iron-gear-wheel')
