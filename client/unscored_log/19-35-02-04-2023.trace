# First, I need to gather some resources to start building our factory
inventory();
# Check what we already have in our inventory
goto(nearest('iron_ore'));
# Go to the nearest iron ore deposit
harvest((-2, 0), count=40);
# Harvest 40 iron ores
goto(nearest('copper_ore'));
# Go to the nearest copper ore deposit
harvest((-2, 0), count=40);
# Harvest 40 copper ores
# Let's start smelting the ores now
goto((0, -5));
# Place ourselves in a clear area
place('stone-furnace', 0, (1, 0));
# Place a stone furnace facing east
insert('coal', (1, 0), count=10);
# Insert 10 coal into the stone furnace
insert('iron_ore', (1, 0), count=40);
# Insert 40 iron ores into the stone furnace
wait(30);
# Wait 30 seconds to allow the furnace to smelt 20 iron plates
extract('iron-
# plate', (1, 0), count=20);
insert('copper_ore', (1, 0), count=40);
# Insert 40 copper ores into the stone furnace
wait(30);
# Wait 30 seconds to allow the furnace to smelt 20 copper plates
extract('copper_plate', (1, 0), count=20);
# Extract 20 copper plates from the furnace
wait(3);
# Let's wait a few more seconds for more copper and iron to smelt
extract('copper_plate', (1, 0), count=5);
# Extract 5 more copper plates from the furnace
extract('iron_plate', (1, 0), count=5);
# Extract 5 more iron plates from the furnace
# You see:
- An stone_furnace facing north at (1, 0) containing 7x coal. No input material.
- +5 copper_plate(in prev error)
- +5 iron_plate
# Now, let's start building the factory
goto((3, 3));
# Head to an open area to the east-northeast
place('assembling-machine-1', 0, (1, 0));
# Place an assembling machine-1 to the east, facing east
set_recipe((1, 0), 'transport-belt');
# Set the recipe of the assembling machine to 'transport-belt'
insert('iron_plate', (1, 0), count=20);
# Insert 20 iron plates into the assembling machine
