# First I'll define a function to get the resource entities 
def get_resource_entities(name):
    resource_entities = []
    resource_entities += (inspect_radius(23000, entity=name, position=(-23, -23)))
    resource_entities += (inspect_radius(17000, entity=name, position=(-17, -17)))
    resource_entities += (inspect_radius(16000, entity=name, position=(-16, -16)))
    resource_entities += (inspect_radius(16000, entity=name, position=(-16, 0)))
    resource_entities += (inspect_radius(21000, entity=name, position=(0, 0)))
    resource_entities += (inspect_radius(1000, entity=name, position=(1, 1)))
    resource_entities += (inspect_radius(3000, entity=name, position=(-3, -3)))
    resource_entities += (inspect_radius(760, entity=name, position=(-1, -1)))
    resource_entities += (inspect_radius(32, entity=name, position=(0, 0)))
    resource_entities += (inspect_radius(4000, entity=name, position=(-4, -4)))
    resource_entities += (inspect_radius(720, entity=name, position=(1, -1)))
    resource_entities += (inspect_radius(17000, entity=name, position=(17, -17)))
    resource_entities += (inspect_radius(17000, entity=name, position=(17, 17)))
    resource_entities += (inspect_radius(13000, entity=name, position=(-13, -13)))
    resource_entities += (inspect_radius(13000, entity=name, position=(-13, 13)))
    resource_entities += (inspect_radius(11000, entity=name, position=(11, 11)))
    return resource_entities
# Next, I'll use the function above to get the positions of all the resources and then start mining them. 
# Also, I'll pick up all the coal ore and put them in a crate.
# It might take a while to mine all the resources so I'll use wait_duration at times.
coal_resources = get_resource_entities("coal")
for coal_pos in coal_resources:
    move_to(coal_pos, laying='transport-belt')
    mount_pos = (coal_pos[0], coal_pos[1]-1)
    place_entity("burner-mining-drill", position=mount_pos, direction=3)
    move_to(coal_pos, laying='transport-belt')
    wait_duration(3)
    pickup_entity(mount_pos)
    place_entity("iron-chest", position=mount_pos, direction=0)
    insert_item('coal', (coal_pos[0], coal_pos[1]-1), quantity=100)
# Sorry about that. I forgot to define the 'nearest' function that I used in the previous example. Here's the definition of the 'nearest' function.
def nearest(entity_name, position=(0, 0)):
    entities = inspect_radius(23000, entity=entity_name, position=position)
    if len(entities) == 0:
        entities = inspect_radius(100000, entity=entity_name, position=position)
    return min(entities, key=lambda e: (position[0] - e['position'][0])**2 + (position[1] - e['position'][1])**2)['position']
