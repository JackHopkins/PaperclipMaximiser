comment("Observe the natural resources around and check for entities within a 20-meter radius")
resources = inspect_resources()
entities = inspect_entities(20)
inventory = inspect_inventory()
comment("Move to the nearest coal deposit")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on nearest buildable position")
place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("Insert coal into the burner-mining-drill")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Move to the nearest iron ore deposit")
iron_ore_position = nearest('iron_ore')
move_to(iron_ore_position)
comment("Place a burner-mining-drill on nearest buildable position for iron ore")
place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("Check the inventory")
inspect_inventory()
inventory = {'iron-chest': 1, 'transport-belt': 50, 'burner-mining-drill': 0, 'stone-furnace': 1, 'assembling-machine-1': 1, 'coal': 49, 'iron-plate': 50, 'copper-plate': 50}
