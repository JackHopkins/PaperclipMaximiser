# Command 1 - Move to nearest coal resource and place a burner-mining-drill
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Command 2 - Set up a smelting operation to produce iron plates
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('burner-mining-drill', direction=DOWN, position=(iron_position[0], iron_position[1]+2))
move_to((iron_position[0]+2, iron_position[1]))
place_entity('stone-furnace', direction=UP, position=(iron_position[0]+2, iron_position[1]-1))
# Command 1 - Craft and place a burner-mining-drill on coal
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 1:
    craft_item('burner-mining-drill', quantity=1)
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Command 1 - Craft and place a burner-mining-drill on coal
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 1:
    # Check if we have the necessary ingredients to craft a burner-mining-drill
    ingredients = {'iron-plate': 3, 'stone-furnace': 1}
    for ingredient, count in ingredients.items():
        if check_inventory().get(ingredient, 0) < count:
            # If we are lacking resources, we move to the required resource to harvest it
            required_resource = nearest(ingredient)
            move_to(required_resource)
            # We harvest the necessary resource and move back to the coal
            harvest_resource(required_resource, quantity=count)
            move_to(coal_position)
            break
    # Now we can craft burner-mining-drill
    craft_item('burner-mining-drill', quantity=1)
