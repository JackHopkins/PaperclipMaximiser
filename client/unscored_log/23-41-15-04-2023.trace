    ingredients = {'iron-plate': 3, 'stone-furnace': 1}
    for ingredient, count in ingredients.items():
        if check_inventory().get(ingredient, 0) < count:
            # If we are lacking resources, we move to the required resource to harvest it
            required_resource = nearest(ingredient)
            move_to(required_resource)
            # We harvest the necessary resource and move back to the coal
            if inspect_resources().find(f"{ingredient.replace('-', '_')}_resource") != -1:
                harvest_resource(required_resource, quantity=count)
                move_to(coal_position)
            else:
                break
    # Now we can craft burner-mining-drill
    if check_inventory().get('iron-plate', 0) >= 3 and check_inventory().get('stone-furnace', 0) >= 1:
        craft_item('burner-mining-drill', quantity=1)
