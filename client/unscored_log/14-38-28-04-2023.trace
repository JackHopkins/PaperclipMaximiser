comment("Inspect resources and landscape around me")
resources_landscape = inspect_resources()
comment("Locate coal deposit and move to nearest coal")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal deposit")
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=coal_position)
comment("Mine 5 coal from the deposit")
harvest_resource(coal_position, quantity=5)
comment("Harvest the remaining 2 coal")
harvest_resource(coal_position, quantity=2)
comment("Check inventory for coal to fuel the mining drill")
inventory = inspect_inventory()
comment("Refuel the burner-mining-drill with one coal")
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
comment("Set up smelting for iron ore")
comment("Locate iron ore deposit and move to nearest iron ore")
iron_ore_position = nearest('iron_ore')
move_to(iron_ore_position)
comment("Place a burner-mining-drill on the iron ore deposit")
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=iron_ore_position)
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Place the crafted burner-mining-drill on the iron ore deposit")
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=iron_ore_position)
comment("Refuel the burner-mining-drill with coal")
insert_item('coal', target_position=iron_ore_position, quantity=1)
comment("Place a stone-furnace next to the burner-mining-drill to smelt iron ore")
furnace_position = place_entity_next_to('stone-furnace', reference_position=iron_ore_position, direction=RIGHT, gap=1)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(iron_ore_position[0]+2, iron_ore_position[1]), target_position=furnace_position, connection_type='inserter')
comment("Craft an inserter")
craft_item('inserter', quantity=1)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using the crafted inserter")
connect_entities(source_position=(iron_ore_position[0]+2, iron_ore_position[1]), target_position=furnace_position, connection_type='inserter')
comment("Check the positions of the burner-mining-drill and stone-furnace")
inspect_entities(radius=5)
comment("Adjusting positions and trying again")
comment("Adjusting the position of the inserter and trying to connect the burner-mining-drill to the stone-furnace")
connect_entities(source_position=(iron_ore_position[0]+1, iron_ore_position[1]), target_position=(furnace_position[0]-1, furnace_position[1]), connection_type='inserter')
comment("Inspecting the entities around the player's position")
entities_around = inspect_entities(radius=20)
print(entities_around)
comment("Repositioning the player to the iron ore position")
move_to(iron_ore_position)
comment("Adjusting the position of the inserter and trying to connect the burner-mining-drill to the stone-furnace again")
connect_entities(source_position=(iron_ore_position[0]+1, iron_ore_position[1]), target_position=(furnace_position[0]-1, furnace_position[1]), connection_type='inserter')
