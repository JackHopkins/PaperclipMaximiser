comment("Starting with mining, move to the nearest iron ore deposit")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
comment("Inspecting the resources near the iron ore deposit")
inspect_resources()
comment("Placing a burner mining drill to extract iron ore")
place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill'), direction=DOWN)
comment("Inspecting the resources around the character")
inspect_entities(20)
comment("Placing a stone furnace to process iron ore near mining area and smelting iron ore")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
place_entity('stone-furnace', direction=UP, position=nearest_buildable('stone-furnace'))
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
harvest_resource(iron_ore_position, quantity=5)
move_to(entity_position('stone-furnace'))
insert_item('iron-ore', target_position=entity_position('stone-furnace'), quantity=5)
set_entity_recipe(entity_position('stone-furnace'), 'iron-plate')
wait(5) comment("wait for smelting to finish")
pickup_entity('iron-plate', entity_position('stone-furnace'))
