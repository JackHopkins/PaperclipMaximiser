# Lets start by checking my inventory.
# First, let me set up coal and iron mining.
move_to(nearest('coal'))
place_entity('burner-drill', direction=2, position=nearest('coal'))
insert_item('coal', target_position=nearest('burner-drill'), quantity=1)
place_entity('iron-chest', direction=0, position=(nearest('burner-drill')[0], nearest('burner-drill')[1]+1))

move_to(nearest('iron_ore'))
place_entity('burner-drill', direction=2, position=nearest('iron_ore'))
insert_item('coal', target_position=nearest('burner-drill', 'iron_ore'), quantity=1)
place_entity('stone-furnace', direction=0, position=(nearest('burner-drill', 'iron_ore')[0], nearest('burner-drill', 'iron_ore')[1]+1))
