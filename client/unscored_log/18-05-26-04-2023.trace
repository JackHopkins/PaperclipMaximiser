comment("Let's fix the error with a function to drop items in our inventory")
def drop_items(inventory, items):
    for item in items:
        if inventory.get(item):
            quantity = inventory.get(item)
            insert_item(item, nearest(item_dropoff), quantity=quantity)
            inventory[item] = 0
    inspect_inventory()
