comment("First, let's check the resources around us")
map_resources = inspect_resources()
comment("Check for nearby coal deposits")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place the burner-mining-drill on the coal deposit")
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0]-2, coal_position[1]))
comment("Now let's find a nearby Iron ore deposit and mine it")
iron_position = nearest('iron-ore')
move_to(iron_position)
comment("Place the burner-mining-drill on the iron ore deposit")
place_entity('burner-mining-drill', direction=DOWN, position=(iron_position[0]-2, iron_position[1]))
comment("Oops! I need a burner-mining-drill in my inventory. Let's craft one first.")
craft_item('burner-mining-drill', quantity=1)
