while rocky_train:
    move_to(rocky_train)
    distance = math.sqrt((player_character['position'][0] - rocky_train[0])**2 + (player_character['position'][1] - rocky_train[1])**2)
    if distance <= 20: # only shoot if the enemy is within 20-meter radius of player
        shoot_at(rocky_train)
    rocky_train = find_nearest("enemy") 
