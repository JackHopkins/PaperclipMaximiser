set_entity_recipe((iron_furnace_pos[0], ore_pos[1]), recipe='automation-science-pack') # setting lab recipe
comment("Once we've got the science packs, we'll use them to unlock the iron smelting technology.")
comment("Oh, I forgot that I need to first craft the lab")  
