inventory();
# My goal is to start processing resources to create a more efficient factory.
goto((10, 5), trailing='transport-belt');
place('stone-furnace', 0, (1,1));
insert('coal', (1, 1), count=1);
insert('iron-ore', (1, 1), count=5);
rotate((1,1), 1);
# Going to the nearest iron ore to collect resources
goto(nearest('iron_ore'));
harvest((0, 0), count=10);
inventory();
# Now I have enough iron ore to insert, let's go back to the furnace and smelt some iron plates
goto((10, 5), trailing='transport-belt');
insert('coal', (1, 1), count=1);
insert('iron-ore', (1, 1), count=5);
wait(15);
extract('iron-plate', (1, 1), count=5);
# Now I want to set up an Assembling Machine for more production
place('assembling-machine-1', 0, (3, 1));
set_recipe((3, 1), 'iron-chest');
insert('iron-plate', (3, 1), count=8);
# Place the assembling machine facing north and set the recipe
place('assembling-machine-1', 0, (1, 3), direction='north');
