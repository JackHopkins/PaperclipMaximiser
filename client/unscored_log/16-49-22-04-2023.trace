comment("Check for available resources in the area")
resource_data = inspect_resources()
comment("Inspect entities within a 20-meter radius")
entities_nearby = inspect_entities(20)
comment("Check the items in the inventory")
inventory_data = inspect_inventory()
comment("Move to the nearest coal deposit and place a burner-mining-drill")
coal_position = nearest('coal')
move_to(coal_position)
burner_drill_position = (coal_position[0]-2, coal_position[1])
place_entity('burner-mining-drill', direction=DOWN, position=burner_drill_position)
comment("Move to the nearest stone deposit and place a burner-mining-drill")
stone_position = nearest('stone')
move_to(stone_position)
burner_drill_position_stone = (stone_position[0]-2, stone_position[1])
place_entity('burner-mining-drill', direction=DOWN, position=burner_drill_position_stone)
comment("Craft a burner-mining-drill and place it at the nearest stone deposit")
craft_item('burner-mining-drill', quantity=1)
stone_position = nearest('stone')
move_to(stone_position)
burner_drill_position_stone = (stone_position[0]-2, stone_position[1])
place_entity('burner-mining-drill', direction=DOWN, position=burner_drill_position_stone)
comment("Pick up coal and insert it into the burner-mining-drill at the stone deposit")
pickup_entity('coal', coal_position)
insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
comment("Harvest coal and insert it into the burner-mining-drill at the stone deposit")
harvest_resource(coal_position, quantity=1)
insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
comment("Move to coal_position, harvest coal and insert it into the burner-mining-drill at the stone deposit")
move_to(coal_position)
harvest_resource(coal_position, quantity=1)
insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
comment("Find the nearest coal deposit with coal available, harvest it and insert it into the burner-mining-drill at the stone deposit")
available_coal_deposits = [r for r in inspect_resources() if r['name'] == 'coal' and r['amount'] > 0]
if available_coal_deposits:
    nearest_coal_deposit_position = available_coal_deposits[0]['position']
    move_to(nearest_coal_deposit_position)
    harvest_resource(nearest_coal_deposit_position, quantity=1)
    insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
else:
    comment("No coal deposits with coal available found")
comment("Extract 1 coal from the burner-mining-drill at coal_position and insert it into the one at the stone deposit")
extract_item('coal', source_position=coal_position, quantity=1)
insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
comment("Check the status of the burner-mining-drill at coal_position and extract 1 coal if there is any")
entities_around_coal_position = inspect_entities(2, position=coal_position)
burner_drill = next((e for e in entities_around_coal_position if e['name'] == 'burner-mining-drill'), None)
if burner_drill is not None and burner_drill['inventory']['coal'] > 0:
    extract_item('coal', source_position=coal_position, quantity=1)
    insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
else:
    comment("No coal to extract from burner-mining-drill at coal_position")
comment("Check the status of the burner-mining-drill at coal_position and extract 1 coal if there is any")
entities_around_coal_position = inspect_entities(2, pos=coal_position)
burner_drill = next((e for e in entities_around_coal_position if e['name'] == 'burner-mining-drill'), None)
if burner_drill is not None and burner_drill['inventory']['coal'] > 0:
    extract_item('coal', source_position=coal_position, quantity=1)
    insert_item('coal', target_position=burner_drill_position_stone, quantity=1)
else:
    comment("No coal to extract from burner-mining-drill at coal_position")
comment("Check the status of the burner-mining-drill at coal_position and extract 1 coal if there is any")
entities_around_coal_position = inspect_entities(2, position_filter=coal_position)
burner_drill = next((e for e in entities_around_coal_position if e['name'] == 'burner-mining-drill'), None)
