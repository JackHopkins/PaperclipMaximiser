entities_around_coal_position = inspect_entities(2)
burner_drill = next((e for e in entities_around_coal_position if e['entity.name'] == 'burner-mining-drill' and e['entity.position'] == coal_position), None)
if burner_drill is not None and burner_drill['inventory']['coal'] > 0:
