# Connect iron ore mining drill and furnace
move_to((iron_ore_position[0] + 1, iron_ore_position[1]), laying='transport-belt')
# Connect copper ore mining drill and furnace
move_to((copper_ore_position[0] + 1, copper_ore_position[1]), laying='transport-belt')
# Connect stone mining drill and furnace
move_to((stone_position[0] + 1, stone_position[1]), laying='transport-belt')
# Place inserters we crafted next to furnaces to move materials
place_entity('inserter', direction=RIGHT, position=(coal_position[0] + 1, coal_position[1]))
place_entity('inserter', direction=RIGHT, position=(iron_ore_position[0] + 1, iron_ore_position[1]))
place_entity('inserter', direction=RIGHT, position=(copper_ore_position[0] + 1, copper_ore_position[1]))
place_entity('inserter', direction=RIGHT, position=(stone_position[0] + 1, stone_position[1]))
# Move away from the location before placing the inserter
move_to((0, -3))
place_entity('inserter', direction=RIGHT, position=(stone_position[0] + 1, stone_position[1]))
# Create basic assembling machines and place them in the production line
