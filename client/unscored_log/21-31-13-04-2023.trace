# Lets start by checking my inventory.
# Let's set up the mining drills and furnaces for the coal, iron ore, copper ore, and stone resources.
# Place burner-drill and furnaces for each resource
coal_position = nearest('coal')
place_entity('burner-mining-drill', direction=RIGHT, position=coal_position)
place_entity('stone-furnace', position=(coal_position[0] + 2, coal_position[1]))
iron_ore_position = nearest('iron_ore')
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position)
place_entity('stone-furnace', position=(iron_ore_position[0] + 2, iron_ore_position[1]))
# Craft more burner-mining-drills and stone-furnaces
craft_item('burner-mining-drill', quantity=3)
craft_item('stone-furnace', quantity=3)
# Harvest stone to craft more burner-mining-drills and stone-furnaces
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=40)
# Craft burner-mining-drills and stone-furnaces with the harvested stone
craft_item('burner-mining-drill', quantity=3)
craft_item('stone-furnace', quantity=3)
# Place burner-drill and furnaces for the iron ore resource again
place_entity('burner-mining-drill', direction=RIGHT, position=iron_ore_position)
place_entity('stone-furnace', position=(iron_ore_position[0] + 2, iron_ore_position[1]))
copper_ore_position = nearest('copper_ore')
place_entity('burner-mining-drill', direction=RIGHT, position=copper_ore_position)
place_entity('stone-furnace', position=(copper_ore_position[0] + 2, copper_ore_position[1]))
stone_position = nearest('stone')
place_entity('burner-mining-drill', direction=RIGHT, position=stone_position)
place_entity('stone-furnace', position=(stone_position[0] + 2, stone_position[1]))
# Now place transport-belts, inserters, and connect power poles between the mining drills, furnaces, and assembling machines to create automation wherever possible.
