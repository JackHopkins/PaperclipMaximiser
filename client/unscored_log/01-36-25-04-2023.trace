comment("Observe and describe the natural resources and landscape around me")
resources = inspect_resources()
comment("Start with a simple mining operation")
comment("Locate coal and move to it")
coal_position = resources['coal']['min_coordinates']
move_to(coal_position)
comment("Locate coal and move to it")
coal_position = resources['coal']['max_coordinates']
move_to(coal_position)
comment("Find the nearest coal and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill facing left")
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Place a stone furnace to the right of the burner mining drill")
burner_drill_position = nearest('burner-mining-drill')
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=burner_drill_position, direction=RIGHT, gap=1)
comment("Find a suitable location to place the stone furnace")
suitable_location = nearest_buildable('stone-furnace', reference_position=burner_drill_position, direction=RIGHT)
move_to(suitable_location)
comment("Place a stone furnace at the suitable location")
place_entity('stone-furnace', position=suitable_location)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(burner_drill_position[0]-2, burner_drill_position[1]), target_position=suitable_location, connection_type='inserter')
comment("Place an inserter between the burner-mining-drill's output and the stone-furnace's input")
inserter_position = (burner_drill_position[0]-1, burner_drill_position[1])
place_entity('inserter', position=inserter_position, direction=UP)
comment("Check inventory for available items")
inspect_inventory()
