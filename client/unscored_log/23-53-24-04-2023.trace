comment("Inspect available resources")
resources = inspect_resources()
comment("Check and move to the coal resource location")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill next to the coal")
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Move to coordinates (-10, -5)")
move_to((-10, -5))
comment("Observe resources at the (-10, -5) location")
resources_at_location = inspect_resources((-10, -5))
comment("Observe the nearby entities")
nearby_entities = inspect_entities(20)
comment("Retry previous commands")
comment("Move to coordinates (-10, -5)")
move_to((-10, -5))
comment("Observe resources at the (-10, -5) location")
resources_at_location = inspect_resources((-10, -5))
comment("Observe the nearby entities")
nearby_entities = inspect_entities(20)
