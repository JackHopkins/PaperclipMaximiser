comment("Inspect resources in the area")
resources = inspect_resources()
comment("Find the nearest coal deposit and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Check for any entities nearby")
entities = inspect_entities(20)
comment("Place a burner-mining-drill at a buildable position near coal deposit")
buildable_position = nearest_buildable('burner-mining-drill')
place_entity('burner-mining-drill', direction=DOWN, position=buildable_position)
comment("Place a stone furnace near the burner-mining-drill")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=buildable_position, direction=RIGHT, gap=1)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Place a stone furnace near the burner-mining-drill")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=buildable_position, direction=RIGHT, gap=1)
comment("Find another suitable position for the stone furnace")
suitable_position = nearest_buildable('stone-furnace')
move_to(suitable_position)
comment("Place stone furnace at the suitable position")
stone_furnace_position = place_entity('stone-furnace', direction=UP, position=suitable_position)
comment("Move back to the burner-mining-drill")
move_to(buildable_position)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Check the inventory for necessary materials")
inventory = inspect_inventory()
comment("Craft a stone-furnace using the available materials in inventory")
craft_item('stone-furnace', quantity=1)
comment("Find nearest stone deposit and move to it")
stone_position = nearest('stone')
move_to(stone_position)
comment("Mine the required stone to craft a stone furnace")
harvest_resource(stone_position, quantity=5)
comment("Craft a stone furnace now that we have enough stone")
craft_item('stone-furnace', quantity=1)
comment("Place stone furnace at the suitable position")
stone_furnace_position = place_entity('stone-furnace', direction=UP, position=suitable_position)
comment("Move back to the burner-mining-drill")
move_to(buildable_position)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Find a position closer to the stone furnace")
closer_position = place_entity_next_to('burner-mining-drill', reference_position=stone_furnace_position, direction=LEFT, gap=1)
comment("Move to the closer position")
move_to(closer_position)
comment("Update the burner-mining-drill position")
buildable_position = place_entity('burner-mining-drill', direction=LEFT, position=closer_position)
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Check the inventory for necessary materials to craft a burner-mining-drill")
inventory = inspect_inventory()
comment("Craft a burner-mining-drill using the available materials in inventory")
craft_item('burner-mining-drill', quantity=1)
comment("Place the burner-mining-drill at the closer position")
buildable_position = place_entity('burner-mining-drill', direction=LEFT, position=closer_position)
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Mine more stone to craft the burner-mining-drill")
harvest_resource(stone_position, quantity=5)
comment("Craft the burner-mining-drill using the available materials in inventory")
craft_item('burner-mining-drill', quantity=1)
comment("Place the burner-mining-drill at the closer position")
buildable_position = place_entity('burner-mining-drill', direction=LEFT, position=closer_position)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
comment("Find another stone deposit and move to it")
another_stone_position = nearest('stone', exclude_position=[stone_position])
move_to(another_stone_position)
comment("Mine more stone to craft the burner-mining-drill")
harvest_resource(another_stone_position, quantity=5)
comment("Craft the burner-mining-drill using the available materials in inventory")
craft_item('burner-mining-drill', quantity=1)
comment("Move back to the closer position")
move_to(closer_position)
comment("Place the burner-mining-drill at the closer position")
buildable_position = place_entity('burner-mining-drill', direction=LEFT, position=closer_position)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=buildable_position, target_position=stone_furnace_position, connection_type='inserter')
