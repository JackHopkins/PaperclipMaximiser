# Lets start by checking my inventory.
# I'll start by placing the burner-mining-drill on the coal resource, a stone-furnace to smelt iron, and connecting them with a transport-belt.
coal_position = nearest('coal')
iron_ore_position = nearest('iron_ore')
place_entity('burner-mining-drill', direction=2, position=coal_position)
place_entity('stone-furnace', direction=2, position=(iron_ore_position[0], iron_ore_position[1] + 1))
move_to(coal_position, laying='transport-belt')
move_to((iron_ore_position[0], iron_ore_position[1] + 1), laying='transport-belt')
