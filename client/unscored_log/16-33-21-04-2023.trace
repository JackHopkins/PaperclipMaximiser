# First, I need to inspect my resources and surroundings to see what is available to me.
inspect_resources()
inspect_entities()
# I need to inspect entities around me, to see what machines have been built or are available
inspect_entities(distance=10)
# I need to move to a coal resource, pick it up, and place it in a burner mining drill to extract more coal
move_to(nearest('coal'))
pickup_entity('coal', nearest('coal'))
entity_position = place_entity('burner-mining-drill', direction='down', position=nearest('coal'))
# My mistake, I need to harvest the coal resource instead of picking it up
move_to(nearest('coal'))
harvest_resource(nearest('coal'), quantity=1)
entity_position = place_entity('burner-mining-drill', direction='down', position=nearest('coal'))
