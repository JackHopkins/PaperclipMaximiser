comment("Inspect resources and landscape around me")
resources = inspect_resources()
comment("Set up a basic mining operation for coal")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Inspect surroundings and entities")
entities = inspect_entities(20)
comment("Set up a basic mining operation for coal")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill near the coal")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Craft an iron-chest")
craft_item('iron-chest', quantity=1)
comment("Place the iron-chest near the burner-mining-drill for storing the coal")
chest_position = (coal_position[0]+4, coal_position[1])
place_entity('iron-chest', position=chest_position)
comment("Create a coal supply chain from the burner-mining-drill to the iron chest")
connect_entities(source_position=(coal_position[0]+2, coal_position[1]), target_position=(chest_position[0], chest_position[1]), connection_type='inserter')
comment("Find the positions of the burner-mining-drill and the iron chest")
entities = inspect_entities(5)
burner_drill_position = None
iron_chest_position = None
for entity in entities:
    if entity['type'] == 'burner-mining-drill':
        burner_drill_position = entity['position']
    elif entity['type'] == 'iron-chest':
        iron_chest_position = entity['position']
comment("Connect the burner-mining-drill to the iron chest with an inserter")
connect_entities(source_position=(burner_drill_position[0]+2, burner_drill_position[1]), target_position=iron_chest_position, connection_type='inserter')
comment("My apologies for the error, let's re-inspect the entities within a larger radius")
entities = inspect_entities(10)
for entity in entities:
    if entity['type'] == 'burner-mining-drill':
        burner_drill_position = entity['position']
    elif entity['type'] == 'iron-chest':
        iron_chest_position = entity['position']
comment("Connect the burner-mining-drill to the iron chest with an inserter")
connect_entities(source_position=(burner_drill_position[0]+2, burner_drill_position[1]), target_position=iron_chest_position, connection_type='inserter')
comment("Apologies for the confusion, let's place a burner-mining-drill and an iron chest")
