comment("First, let's inspect our starting resources and entities")
inspect_resources()
inspect_entities(20)
comment("Next, let's set up a basic mining operation to extract iron and coal resources.")
comment("We'll move to the nearest iron resource and place a burner mining drill to extract it.")
iron_position = nearest('iron-ore')
move_to(iron_position)
burner_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("I see, we don't have any iron ore within range of the burner mining drill, let me look for another resource node.")
iron_position = nearest('iron-ore', radius=50)
move_to(iron_position)
burner_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment(f"Position of the mining drill is {burner_drill_pos}")
comment("It seems we don't have any iron ore nearby. Let's move to the starting area which has some basic resources.")
move_to((0, 0))
inspect_resources()
comment("We can see that there's some iron ore, stone and coal nearby. Let's go to the iron ore deposit and start building our mining operation.")
iron_position = nearest('iron-ore', radius=50)
move_to(iron_position)
burner_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
inventory = inspect_inventory()
while inventory['iron-ore'] < 10:
    harvest_resource(iron_position, quantity=5)
    inventory = inspect_inventory()
comment("It seems that there is no iron ore in the vicinity. Let's try finding a copper ore deposit.")
copper_position = nearest('copper-ore', radius=50)
move_to(copper_position)
burner_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
comment("It looks like we don't have any copper ore nearby either. Let's search for another resource.")
coal_pos = nearest('coal', radius=50)
move_to(coal_pos)
burner_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
