# Lets start by checking my inventory.
# Great, I have some basic resources that I need. Now, let's create a loop to mine some coal from the resource located at (-17, -14).
# We will harvest 80 coal units.
coal_location = (-17, -14)
coal_owned = 0
while coal_owned < 80:
    harvest_resource(coal_location, quantity=5)
    coal_owned += 5
check_inventory() # Let's check our inventory after harvesting coal.
# Oops, there's no resource within reach to harvest. Let's move to coal_location first.
coal_location = (-17, -14)
move_to(coal_location) # Moving to (-17, -14)
# Let's move to coal_location first and then harvest coal.
coal_location = (-17, -14)
move_to(coal_location) # Moving to (-17, -14)
coal_owned = 0
while coal_owned < 80:
    harvest_resource(coal_location, quantity=5)
    coal_owned += 5
check_inventory() # Let's check our inventory after harvesting coal.
# Let's see where we are with observe_nature() method.
observe_nature() # Describe the natural environment and resources around us.
# It seems like the coal we were trying to harvest is no longer within our reach.
# Let's move to the closest coal deposit and harvest coal.
coal_location = nearest('coal')
move_to(coal_location) # Moving to the nearest coal deposit
coal_owned = 0
while coal_owned < 80:
    harvest_resource(coal_location, quantity=5)
    coal_owned += 5
check_inventory() # Let's check our inventory after harvesting coal.
# Hmm, looks like we are unable to harvest coal even from the nearest deposit. It might be out of reach, so let's try moving a bit closer.
coal_location = nearest('coal')
distance_to_coal = ((coal_location[0])**2 + (coal_location[1])**2)**0.5
while distance_to_coal > 5:
    move_to(coal_location)
    distance_to_coal = ((coal_location[0])**2 + (coal_location[1])**2)**0.5
coal_owned = 0
while coal_owned < 80:
    harvest_resource(coal_location, quantity=5)
    coal_owned += 5
check_inventory() # Let's check our inventory after harvesting coal.
