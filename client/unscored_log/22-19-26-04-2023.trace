comment("First, let's inspect our surroundings and available resources")
print(inspect_resources())
comment("We then need to move towards the location of the ore")
move_to((-8, -5))
print("Arrived at ore location")
comment("Now that we're at the ore location, we need to place a mining drill to extract the ore")
ore_position = nearest('stone')
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=ore_position)
print("Mining drill placed successfully")
