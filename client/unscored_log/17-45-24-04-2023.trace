comment("Check available natural resources")
resources = inspect_resources()
print(resources)
comment("Find the nearest coal resource and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal resource")
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0] - 2, coal_position[1]))
comment("Find the nearest iron resource")
iron_position = nearest('iron')
move_to(iron_position)
comment("Find the nearest copper resource")
copper_position = nearest('copper')
move_to(copper_position)
comment("Find the nearest stone resource")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill on the stone resource")
place_entity('burner-mining-drill', direction=DOWN, position=(stone_position[0] - 2, stone_position[1]))
comment("Check the inventory to see available items")
inspect_inventory()
comment("Find the nearest coal resource")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill on the coal resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0] + 2, coal_position[1]))
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Place a burner-mining-drill on the coal resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0] + 2, coal_position[1]))
comment("Add coal from inventory to the burner-mining-drill for fuel")
insert_item('coal', target_position=(-7, -5), quantity=1)
comment("Find the nearest stone resource to build stone furnaces")
stone_position = nearest('stone')
move_to(stone_position)
comment("Place a burner-mining-drill on the stone resource")
place_entity('burner-mining-drill', direction=RIGHT, position=(stone_position[0] + 2, stone_position[1]))
comment("Craft a burner-mining-drill")
craft_item('burner-mining-drill', quantity=1)
comment("Mine stone to craft the burner-mining-drill")
harvest_resource(stone_position, quantity=5)
