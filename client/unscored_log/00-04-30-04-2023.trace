comment("Inspect the natural resources around me")
resources = inspect_resources()
print(resources)
comment("Find the nearest coal and set up a mining operation")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=RIGHT, exact=False, position=coal_position)
comment("Check to ensure that burner-mining-drill has been placed")
inspect_entities(5)
comment("Place a stone furnace next to the burner-mining-drill for smelting")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=coal_position, direction=RIGHT, gap=1)
