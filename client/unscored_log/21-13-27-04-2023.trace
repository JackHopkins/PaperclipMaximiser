comment("First, let's inspect our surroundings and available resources")
inspect_resources()
inspect_entities()
comment("Next, let's move to the location of the ore we want to extract and place a burner-mining-drill to extract it.")
move_to((-8, -5))
place_entity('burner-mining-drill')
comment("Now, let's inspect the nearby entities to see the progress of the burner-mining-drill's extraction.")
inspect_entities()
comment("We need to add a chest to store our extracted ore. We'll place an iron chest near the mining drill.")
move_to((-8, -4))
place_entity('iron-chest')
comment("Let's check our inventory and see if we have any ore. If we do, we'll insert it into the chest.")
inventory = inspect_inventory()
if 'iron-ore' in inventory:
    insert_item('iron-ore', target_position=nearest('iron-chest'), quantity=inventory['iron-ore'])
