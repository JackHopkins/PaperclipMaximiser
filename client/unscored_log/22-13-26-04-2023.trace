comment("Start by inspecting the resources around me")
inspect_resources()
comment("I see that there is an ore deposit at (-8, -5). I will move to that location and mine the ore.")
ore = (-8, -5)
move_to(ore)
harvest_resource(ore, quantity=5)
comment("Now that I have some ore, I will smelt it into iron plates. I will need to find a suitable location first.")
inspect_entities()
comment("I see some open space at (10, 0) that looks suitable. I will move there and begin building my furnace.")
furnace_position = (10, 0)
move_to(furnace_position)
place_entity('stone-furnace', direction=UP, position=furnace_position)
inspect_entities()
comment("Now that the furnace is built, I will add fuel and the ore to it.")
insert_item('coal', target_position=furnace_position, quantity=2)
insert_item('iron-ore', target_position=furnace_position, quantity=5)
