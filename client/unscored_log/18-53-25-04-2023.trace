comment("First, let's start by inspecting our surroundings and available resources")
inspect_resources()
comment("Now let's place a burner-mining-drill on the nearest coal deposit and start mining coal")
coal_position = nearest('coal')
move_to(coal_position)
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
harvest_resource(coal_position, quantity=20)
comment("Great, we have coal mining automated. Let's move to the nearest iron deposit now.")
iron_position = nearest('iron-ore')
move_to(iron_position)
comment("Let's place another burner-mining-drill for iron")
entity_position = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
harvest_resource(iron_position, quantity=20)
comment("Now that we have some resources, let's work on power generation")
