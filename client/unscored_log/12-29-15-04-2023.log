def get_inventory_items():
    # Return a dictionary of items in the inventory
    return {"iron-ore": 50, "copper-ore": 25, "coal": 100}
    
def observe_nature():
    # Return a string representation of natural resources and entities
    return "..P........\n............\n............\nC.I.........\n............\n............\n...T........\n............\n............\n............\n............"
    
def get_nearest_entity(entity_type):
    entities = observe_nature().split("\n")
    entities_coord = []
    for i, row in enumerate(entities):
        for j, col in enumerate(row):
            if col == entity_type:
                entities_coord.append((i,j))
    if entities_coord == []:
        return None
    return min(entities_coord, key=lambda x: (abs(x[0]-get_player_position()[0]),abs(x[1]-get_player_position()[1])))
    
