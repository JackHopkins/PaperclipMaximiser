comment("Find the nearest coal resource")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner-mining-drill")
burner_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("Find the nearest buildable position for the burner-mining-drill on coal")
burner_drill_position = nearest_buildable('burner-mining-drill', resource='coal')
move_to(burner_drill_position)
comment("Place burner-mining-drill on nearest buildable position")
burner_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=burner_drill_position)
comment("Pick up 3 coal")
pickup_entity('coal', coal_position, quantity=3)
comment("Correctly pick up 3 coal")
pickup_item('coal', source_position=coal_position, quantity=3)
comment("Insert 1 coal into the mining drill for fuel")
insert_item('coal', target_position=burner_drill_position, quantity=1)
