comment("First, let's inspect the natural resources and landscape around us")
inspect_resources()
comment("Let's also inspect nearby entities to see what resources we have available")
inspect_entities(20)
comment("Looks like we have coal nearby, let's move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Now that we're at the coal, let's setup our first mining operation")
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Great, we have a coal mine now. Let's inspect our inventory to see what we have so far")
inspect_inventory()
comment("We need to start turning this coal into electricity. Let's setup a small power generation system")
comment("First, let's find a water source nearby")
water_position = nearest('water')
move_to(water_position)
comment("Now that we're at the water, let's setup a offshore pump and boiler to generate steam to power our factory")
entity_position = place_entity('offshore-pump', position=nearest_buildable('offshore-pump'))
entity_position = place_entity_next_to('boiler', reference_position=entity_position, direction=DOWN, gap=1)
