comment("Start by inspecting the resources and landscape")
inspect_resources()
comment("Looks like we have some iron and coal nearby. We should start mining those resources")
iron_position = nearest('iron-ore')
coal_position = nearest('coal')
comment("Let's move to the position of the nearest coal")
move_to(coal_position)
comment("Now let's place a burner-mining-drill to start mining coal")
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Great, now let's move to the position of the nearest iron")
move_to(iron_position)
comment("And place a burner-mining-drill to start mining iron")
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
