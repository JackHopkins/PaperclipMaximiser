# Command 1: Move to nearest iron ore resource and set up a mining operation
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
place_entity('stone-furnace', direction=LEFT, position=(iron_position[0]-4, iron_position[1]))
insert_item('coal', target_position=(iron_position[0]-4, iron_position[1]), quantity=10)
set_entity_recipe((iron_position[0]-4, iron_position[1]), recipe='iron-plate')
# Automated resource extraction, processing and manufacturing
# First, let's check our surroundings using inspect_entities() to make sure we have enough space to place our entities
inspect_entities(10)
# Automated resource extraction, processing and manufacturing
# It looks like there's a furnace already there, so let's check to see if we have enough resources to start processing iron
if check_inventory()['stone-furnace'] > 0 and check_inventory()['burner-mining-drill'] > 0 and check_inventory()['coal'] > 10:
    
    # Start mining some iron from the nearest iron-ore resource
    iron_position = nearest('iron-ore')
    move_to(iron_position)
    place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
    insert_item('coal', target_position=(iron_position[0]-2, iron_position[1]), quantity=5)
# Automated resource extraction, processing and manufacturing
# Now let's check if we have started mining iron and have enough iron-ore for smelting
if check_inventory()['iron-ore'] > 0:
    
    # Place stone-furnace for smelting iron
    iron_position = nearest('iron-ore')
    move_to(iron_position)
    place_entity('stone-furnace', direction=LEFT, position=(iron_position[0]-4, iron_position[1]))
    insert_item('coal', target_position=(iron_position[0]-4, iron_position[1]), quantity=10)
    set_entity_recipe((iron_position[0]-4, iron_position[1]), recipe='iron-plate') 
    
    # Start manufacturing iron gears
    while check_inventory()['iron-plate'] >= 2:
        craft_item('iron-gear-wheel', quantity=1)
        
# Automated resource extraction, processing and manufacturing
# Now let's check if we have started mining iron and have enough iron-ore for smelting
if check_inventory()['iron-ore'] > 0:
    
    # Place stone-furnace for smelting iron
    iron_position = nearest('iron-ore')
    move_to(iron_position)
    if check_inventory()['stone-furnace'] > 0:
        place_entity('stone-furnace', direction=LEFT, position=(iron_position[0]-4, iron_position[1]))
