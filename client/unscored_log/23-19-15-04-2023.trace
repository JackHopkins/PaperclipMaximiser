# Automated resource extraction, processing and manufacturing
# Command 1: Move to nearest iron ore resource and set up a mining operation
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
place_entity('stone-furnace', direction=LEFT, position=(iron_position[0]-4, iron_position[1]))
insert_item('coal', target_position=(iron_position[0]-4, iron_position[1]), quantity=10)
set_entity_recipe((iron_position[0]-4, iron_position[1]), recipe='iron-plate')
