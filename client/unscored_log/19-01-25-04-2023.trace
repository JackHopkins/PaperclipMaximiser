comment("First, let's inspect our resources and surrounding entities.")
inspect_resources()
inspect_entities(20)
comment("Let's start by mining some coal.") 
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Now, let's smelt the coal into solid fuel.")
iron_position = nearest('iron-ore')
move_to(iron_position)
place_entity('stone-furnace', UP, position=nearest_buildable('stone-furnace'))
set_entity_recipe(nearest('stone-furnace'), 'solid-fuel')
harvest_resource(coal_position, quantity=5)
extract_item('solid-fuel', source_position=(iron_position[0] + 1, iron_position[1]), quantity=5)
