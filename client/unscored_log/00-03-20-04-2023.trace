# My apologies, I forgot to create the nearest() function. Let me define it first.
def nearest(resource):
    resources = inspect_resources()
    closest_resource = None
    closest_distance = float('inf')
    for r in resources:
        if r == resource:
            distance = (resources[r]['direction']['offset'])**2
            if distance < closest_distance:
                closest_resource = resources[r]['direction']['min_coordinates']
                closest_distance = distance
    return closest_resource
