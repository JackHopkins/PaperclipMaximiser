# Inspect the resources and entities around me
inspect_resources()
inspect_entities(20)
# Let's start by creating a burner mining drill to extract coal
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Oops, it looks like 'move_to' didn't work properly. Let's inspect the entities again to see where I am.
inspect_entities(20)
# It seems there are no entities nearby, let's check the resources again.
inspect_resources()
# Let's try moving to the nearest coal resource again, this time with a larger search radius
coal_position = nearest('coal', search_radius=200)
move_to(coal_position)
# It seems I encountered another error. Let's check if the coal resources are within my search radius.
inspect_resources()
# It looks like the coal is still within range. Let's try moving to a different location and then back to the coal.
move_to((5,5)) # Moving away to (5, 5)
coal_position = nearest('coal', search_radius=200)
move_to(coal_position) # Moving to coal again
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1])) # Place the burner mining drill at coal position
inspect_entities(20) # Check to ensure that burner-mining-drill has been placed
# Looks like the error is still there. Let's check the entities and resources to figure out what's happening
inspect_entities(20) 
inspect_resources()
