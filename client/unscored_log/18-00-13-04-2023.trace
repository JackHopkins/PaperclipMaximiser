# Lets start by checking my inventory.
# Let's start with collecting resources.
# Place a burner-mining-drill facing north on coal, iron, stone, and copper resources
resource_positions = {'coal': (-12, -10), 'iron': (26, -10), 'stone': (-12, 10), 'copper': (26, 10)}
for resource, position in resource_positions.items():
    place_entity('burner-mining-drill', direction=2, position=position)
# My mistake, let's craft burner-mining-drills and then place them.
# Craft 3 additional burner-mining-drills
craft_item('burner-mining-drill', quantity=3)
# Let's collect some stone manually and craft the remaining burner-mining-drills
# Harvest 10 stone from the nearest stone resource
harvest_resource(nearest('stone'), quantity=10)
# Locate the closest stone patch and then harvest from it
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=10)
# Now that we have the stone, let's craft the remaining 2 burner-mining-drills
craft_item('burner-mining-drill', quantity=2)
# Place the remaining burner-mining-drills on iron, stone, and copper resources
resource_positions = {'iron': (26, -10), 'stone': (-12, 10), 'copper': (26, 10)}
for resource, position in resource_positions.items():
    place_entity('burner-mining-drill', direction=2, position=position)
# Now that we have placed the burner-mining-drills, let's fuel them with coal.
for position in resource_positions.values():
    insert_item('coal', target_position=position, quantity=10)
# After waiting for the burner-mining-drills to collect resources, let's place stone-furnaces for smelting
# Craft additional stone furnaces
craft_item('stone-furnace', quantity=3)
# Place stone furnaces next to the coal, iron, and copper mining drills
furnace_positions = {'coal': (-12, -11), 'iron': (26, -11), 'copper': (26, 11)}
for resource, position in furnace_positions.items():
    place_entity('stone-furnace', position=position)
# I apologize for the mistake, let's calculate the correct positions for the stone furnaces.
furnace_positions = {'iron': (26, -9), 'copper': (26, 9)}
# Place stone furnaces next to the iron and copper mining drills
for resource, position in furnace_positions.items():
    place_entity('stone-furnace', position=position)
# Fuel the furnaces with the coal from the coal mining drill
coal_furnace_position = (-12, -9)
extract_item('coal', source_position=(-12, -10), quantity=20)
insert_item('coal', target_position=coal_furnace_position, quantity=10)
insert_item('coal', target_position=furnace_positions['iron'], quantity=5)
insert_item('coal', target_position=furnace_positions['copper'], quantity=5)
# My apologies again, let's correct the furnace_positions coordinates.
furnace_positions = {'iron': (27, -10), 'copper': (27, 10)}
# Place stone furnaces next to the iron and copper mining drills
for resource, position in furnace_positions.items():
    place_entity('stone-furnace', position=position)
# My mistake, let's change the coordinates of the furnace_positions.
furnace_positions = {'iron': (24, -10), 'copper': (24, 10)}
# Place stone furnaces next to the iron and copper mining drills
for resource, position in furnace_positions.items():
    place_entity('stone-furnace', position=position)
# Fuel the furnaces with the coal from the coal mining drill
coal_furnace_position = (-13, -10)
extract_item('coal', source_position=(-12, -10), quantity=20)
insert_item('coal', target_position=coal_furnace_position, quantity=10)
insert_item('coal', target_position=furnace_positions['iron'], quantity=5)
insert_item('coal', target_position=furnace_positions['copper'], quantity=5)
# Let's wait for the coal mining drill to produce some coal before extracting it.
wait_duration(30)
# Now that we have waited, let's try extracting coal again.
extract_item('coal', source_position=(-12, -10), quantity=20)
# Let's try extracting less coal.
extract_item('coal', source_position=(-12, -10), quantity=10)
# Locate the nearest coal mining drill and try to extract coal from it
