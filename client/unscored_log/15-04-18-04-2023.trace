# Start by inspecting the resources and entities around.
inspect_resources()
inspect_entities(10)
# It looks like we have access to coal, iron ore, stone, copper ore and uranium ore.
# Let's start by placing a few mining drills on the coal and the iron ore.
# First, let's place a burner mining drill on the nearest coal resource.
move_to(nearest('coal'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
# Oops! Looks like there might not be enough space or the ground is uneven to place the burner mining drill.
# Let's check our surroundings to see if we can find a better spot to place the mining drill.
inspect_entities(10)
# It looks like we are close to the power generation setup. 
# Let's move a bit further away from the existing entities and inspect our surroundings again.
move_to((5, -5))
inspect_entities(10)
# This looks like a good spot. Let's try to place the burner mining drill again.
move_to(nearest('coal'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
# It looks like there still might not be enough space. We could try adding some transport belts to move the coal to a different spot for the mining drill.
# Let's try moving further away from the existing entities to get a better view of the terrain.
move_to((-20, 0))
inspect_entities(20)
inspect_resources()
# It looks like we have quite a few resources around. Let's try to place the burner mining drill on a different coal resource.
# First, let's move to the closest coal resources.
coal_positions = [resource['position'] for resource in inspect_resources().values() if 'coal' in resource['name']]
nearest_resource = min(coal_positions, key=lambda p: distance(p, player_position()))
move_to(nearest_resource)
# That's because we forgot to use `inspect_resources()` to get the dictionary, instead of just the string.
# Let's make that correction and try again.
resources = inspect_resources()
coal_positions = [resource['position'] for resource in resources.values() if 'coal' in resource['name']]
nearest_resource = min(coal_positions, key=lambda p: distance(p, player_position()))
move_to(nearest_resource)
# It looks like we forgot to assign the output of `inspect_resources()` to resources variable. Let's fix that.
resources = inspect_resources()
coal_positions = [resource['position'] for resource in resources.values() if 'coal' in resource['name']]
nearest_resource = min(coal_positions, key=lambda p: distance(p, player_position()))
move_to(nearest_resource)
