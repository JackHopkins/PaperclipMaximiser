# First, let's assess the resources and entities around us
inspect_resources()
inspect_entities(20)
# From the inspection, we can see that there are abundant natural resources around us. We have coal, iron ore, copper ore, stone, and even uranium ore. Our first objective should be to set up a mining operation to extract these resources efficiently. We can start by placing a burner mining drill on the nearest coal patch.
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=DOWN, position=(coal_position[0], coal_position[1]+1))
# Now that we have a coal mining operation set up, let's move on to the next objective of smelting the mined resources. We can start by placing a stone furnace adjacent to the mining drill we just placed
move_to(coal_position, laying='transport-belt')
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]+1, coal_position[1]))
# Oh no! It seems like we have placed the burner mining drill too close to where we wanted to place the stone furnace. Let's destroy the burner mining drill and try again.
extract_item('burner-mining-drill', source_position=(coal_position[0], coal_position[1]+1))
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]+1, coal_position[1]))
# It seems like there was no burner mining drill to extract. We'll just have to place the furnace somewhere else.
coal_position = nearest('coal')
move_to(coal_position, laying='transport-belt')
place_entity('stone-furnace', direction=DOWN, position=(coal_position[0]-1, coal_position[1]))
# Now, let's automate the fueling of the stone furnace using the coal that we are mining. We can do this by inserting coal from our inventory into the furnace.
check_inventory()
insert_item('coal', target_position=(coal_position[0]-1, coal_position[1]), quantity=10)  # Insert 10 coal from inventory
check_inventory()  # Check inventory again to ensure coal was removed
inspect_entities(5)  # Check that coal was inserted into furnace
# Great, now we have the fueling process automated. Next, let's move on to smelting iron ore into iron plates. We'll need to set up another mining operation for iron ore, get transport belts to move the ore to the furnace, and then get a chest to store the produced iron plates.
# First, let's find a location to set up the mining operation for iron ore
iron_position = nearest('iron-ore')
# Now that we have identified the location for the mining operation, let's set up the mining drill there.
place_entity('burner-mining-drill', direction=DOWN, position=iron_position)
# Oops, it looks like we don't have any coal mining drills left. Let's craft one.
craft_item('burner-mining-drill', quantity=1)  # Craft one burner mining drill
check_inventory()  # Check inventory to ensure we have a burner mining drill
iron_position = nearest('iron-ore')
place_entity('burner-mining-drill', direction=DOWN, position=iron_position)  # Place burner mining drill at iron ore position.
# It looks like we don't have any stone to craft the burner mining drill. Let's set up a mining operation for stone first.
stone_position = nearest('stone')
place_entity('burner-mining-drill', direction=DOWN, position=stone_position)  # Place a burner mining drill at the stone position
move_to(stone_position, laying='transport-belt')  # Move to the stone position while laying transport belts
move_to(iron_position)  # Move to the iron ore position while laying transport belts
place_entity('stone-furnace', direction=DOWN, position=(iron_position[0]-1, iron_position[1]))  # Place stone furnace next to mining drill
check_inventory()  # Check inventory to ensure we have enough resources to fuel and smelt the iron
insert_item('coal', target_position=(iron_position[0]-1, iron_position[1]), quantity=10)  # Insert coal into furnace
harvest_resource(iron_position, quantity=10)  # Harvest 10 iron ore
insert_item('iron-ore', target_position=(iron_position[0]-2, iron_position[1]), quantity=5)  # Insert iron ore into furnace
rotate_entity((iron_position[0]-1, iron_position[1]), direction=UP)  # Rotate furnace so that iron plates get inserted into the iron chest
move_to(nearest('tree'))  # Move to the nearest tree to get wood for a wooden chest
harvest_resource(nearest('tree'), quantity=5)  # Harvest 5 wood from the tree
craft_item('wooden-chest', quantity=1)  # Craft a wooden chest
check_inventory()  # Check inventory to ensure we have a wooden chest
place_entity('wooden-chest', position=(iron_position[0]+1, iron_position[1]))  # Place wooden chest to store iron plates
extract_item('iron-plate', source_position=(iron_position[0]-1, iron_position[1]))  # Extract iron plates from furnace into wooden chest
check_inventory()  # Check inventory to ensure we have enough iron plates
score = check_inventory()['iron-gear-wheel'] * 5  # Calculate score based on number of iron gear wheels made from iron plates
print(score)  # Print score to screen
# Let's continue optimizing our setup to try and increase our score. We will try to minimize time spent moving and automate more of the manufacturing process.
# We've set up our basic iron plate production, but let's improve this process by automating it a bit more. We'll start by setting up more drills for both coal and iron, and we'll connect them to the furnace and storage chest using transport belts.
# First, let's add more burner mining drills for coal and iron.
craft_item('burner-mining-drill', quantity=2) # Craft two additional drills
iron_position2 = nearest('iron-ore', excluded_positions=[iron_position])  # Get position for second iron drill
place_entity('burner-mining-drill', direction=DOWN, position=iron_position2)  # Place second iron drill
move_to(iron_position2, laying='transport-belt')  # Move to the drill while laying transport belt
coal_position2 = nearest('coal', excluded_positions=[coal_position]) # Get position for second coal drill
place_entity('burner-mining-drill', direction=DOWN, position=coal_position2)  # Place second coal drill
move_to(coal_position2, laying='transport-belt')  # Move to the drill while laying transport belt
move_to((iron_position[0]-1, iron_position[1]), laying='transport-belt')  # Move to the furnace while laying transport belt
move_to((iron_position[0]+2, iron_position[1]), laying='transport-belt')  # Move to the storage chest while laying transport belt
# Let's continue the optimization. Now that we've set up additional drills, let's connect them to the furnace and chest using inserter arms instead of transport belts.
# First, we need to craft a new entity - an inserter arm - to automate moving items from one entity to another.
craft_item('inserter', quantity=2)  # Craft two inserter arms
place_entity('inserter', direction=RIGHT, position=(iron_position[0]-1, iron_position[1]))  # Put the first inserter to move the iron ore to the furnace
place_entity('inserter', direction=LEFT, position=(iron_position[0]+2, iron_position[1]))  # Put the second inserter to move the iron plates from the furnace to the chest
place_entity('inserter', direction=LEFT, position=(coal_position[0]-1, coal_position[1]))  # Put the third inserter arm to move coal from the drill to the furnace
place_entity('inserter', direction=RIGHT, position=(coal_position2[0]+1, coal_position2[1]))  # Put the fourth inserter arm to move coal from the drill to the furnace
check_inventory()  # Check inventory to make sure everything is okay so far
insert_item('coal', target_position=(iron_position[0]-1, iron_position[1]), quantity=10)  # Insert some coal into the furnace
move_to(iron_position2)  # Move to the second iron drill position
harvest_resource(iron_position2, quantity=10)  # Harvest some iron ore
insert_item('iron-ore', target_position=(iron_position2[0]-2, iron_position2[1]), quantity=5)  # Insert iron ore to the furnace through the connected inserter
move_to(coal_position)  # Move to the first coal drill position
harvest_resource(coal_position, quantity=10)  # Harvest some coal
move_to(coal_position2)  # Move to the second coal drill position
harvest_resource(coal_position2, quantity=10)  # Harvest some coal
check_inventory()  # Check inventory to ensure we have enough resources to fuel and smelt the iron
extract_item('iron-plate', source_position=(iron_position[0]-1, iron_position[1]))  # Extract the iron plates from the furnace through the connected inserter
score = check_inventory()['iron-gear-wheel'] * 5  # Calculate score based on number of iron gear wheels made from iron plates
print(score)  # Print the score to the screen.
