import math
    
def distance(position1, position2):
    """
    calculates euclidean distance between position 1 and position 2
    
    :param position1: tuple, position of the first entity, e.g (x1, y1)
    :param position2: tuple, position of the second entity, e.g (x2, y2)
    
    :return: float, euclidean distance between the two positions
    """
    x1, y1 = position1
    x2, y2 = position2
    return math.sqrt((x2-x1)**2 + (y2-y1)**2)
