place_entity("burner-mining-drill", direction=UP, position=(iron_position[0], iron_position[1]))
place_entity("burner-mining-drill", direction=UP, position=(stone_position[0], stone_position[1]))
place_entity("burner-mining-drill", direction=UP, position=(copper_position[0], copper_position[1]))
