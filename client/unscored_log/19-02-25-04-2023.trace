comment("First, let's set up a mining operation at the nearest resource, coal")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place a burner mining drill facing right at the coal patch")
place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill')) 
comment("Set up a smelting operation next to burner mining drill")
