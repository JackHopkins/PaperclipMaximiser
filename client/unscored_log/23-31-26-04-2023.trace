comment("Plan:")
comment("We will move to the ore location and harvest it using a burner mining drill.")
move_to(ore)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=ore)
harvest_resource(ore, quantity=10)

comment("Plan:")  
comment("We will move to the burner-mining-drill location and insert coal to fuel it.")
comment("Find the position of the nearest burner mining drill")
burner_position = nearest('burner-mining-drill')
comment("Move to the burner mining drill position and insert 5 coal to fuel it")
move_to(burner_position)
insert_item('coal', target_position=burner_position, quantity=5)
comment("Plan:")  
comment("We will move to the burner-mining-drill location and insert coal to fuel it.")
comment("Find the position of the nearest burner mining drill")
burner_position = nearest('burner-mining-drill')
comment("Move to the burner mining drill position and insert 5 coal to fuel it")
move_to(burner_position)
insert_item('coal', target_position=burner_position, quantity=5)
comment("Plan:")
comment("We will now set up a smelting operation using stone furnaces and automated transport belt.")
comment("Find the position of the nearest stone furnace.") 
stone_furnace_position = nearest('stone-furnace')
comment("Place a stone furnace at the ore location") 
place_entity('stone-furnace', direction=DOWN, exact=False, position=ore) 
comment("Rotate the furnace to face left") 
rotate_entity(ore, direction=LEFT)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
inserter_position = place_entity_next_to('inserter', burner_position, direction=DOWN, gap=1)
connect_entities(source_position=burner_position, target_position=stone_furnace_position, connection_type='inserter') 
output_position = (ore[0], ore[1]+1) 
