# Check available resources and landscape
resources = inspect_resources()
# Find the nearest coal resource
coal_position = nearest('coal')
# Move to the nearest coal resource
move_to(coal_position)
# Place a burner-mining-drill near the coal resource
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Find the nearest stone resource
stone_position = nearest('stone')
# Move to the nearest stone resource
move_to(stone_position)
# Place a burner-mining-drill near the stone resource
place_entity('burner-mining-drill', direction=LEFT, position=(stone_position[0]-2, stone_position[1]))
# Inspect the inventory and check the number of burner-mining-drills available
inspect_inventory()
# Craft a burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
# Place a burner-mining-drill near the stone resource
place_entity('burner-mining-drill', direction=LEFT, position=(stone_position[0]-2, stone_position[1]))
# Move to the nearest coal resource
move_to(coal_position)
# Place a burner-mining-drill near the coal resource
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Craft another burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
# Mine stone resource to gather ingredients
harvest_resource(stone_position, quantity=5)
# Craft another burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
# Find the nearest stone resource
stone_position = nearest('stone')
# Move to the nearest stone resource and mine 5 of it
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
# Craft another burner-mining-drill
craft_item('burner-mining-drill', quantity=1)
# Finding the nearest iron ore resource
iron_position = nearest('iron-ore')
# Move to the nearest iron ore resource
move_to(iron_position)
# Place a burner-mining-drill to extract iron ore
place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
# Inspect surroundings to ensure proper placement
inspect_entities(5)
# Pick up coal from the nearest burner-mining-drill
pickup_entity('coal', (-32, 0))
# Harvest coal from the nearest burner-mining-drill
harvest_resource((-32, 0), quantity=5)
# Move to the iron ore extracting burner-mining-drill
move_to((-33, 11))
# Insert coal into the iron ore extracting burner-mining-drill
insert_item('coal', target_position=(-33, 11), quantity=1)
# Inspect entities and resources around the area
inspect_entities(20)
inspect_resources()
# Move to the iron ore deposit and place a burner_mining_drill
iron_ore_position = (22, -14)
move_to(iron_ore_position)
place_entity('burner-mining-drill', direction=RIGHT, position=(iron_ore_position[0]+2, iron_ore_position[1]))
# Insert coal into the iron ore extracting burner-mining-drill
insert_item('coal', target_position=(24, -14), quantity=1)
# Inspect entities around my current position
inspect_entities(5)
# Move to the iron ore deposit and place a new burner_mining_drill
move_to((22, -14))
place_entity('burner-mining-drill', direction=RIGHT, position=(26, -14))
# Move to the nearest coal deposit and mine some coal
nearest_coal = nearest('coal')
move_to(nearest_coal)
harvest_resource(nearest_coal, quantity=10)
# Move back to the iron ore deposit and place a new burner-mining-drill
move_to((22, -14))
craft_item('burner-mining-drill', quantity=1)
place_entity('burner-mining-drill', direction=RIGHT, position=(26, -14))
# Insert coal into the newly placed iron ore extracting burner-mining-drill
insert_item('coal', target_position=(26, -14), quantity=1)
# Check the nearest entities around the burner-mining-drill
inspect_entities(2, position=(26, -14))
# Inspect the entities around the iron ore extraction point
inspect_entities(2, reference_position=(26, -14))
# Check the nearest entities around my position
inspect_entities(2)
# Move to the newly placed burner-mining-drill and check entities around my position
move_to((26, -14))
inspect_entities(2)
# It seems I couldn't move to the target position. I will try again.
# Move to the new burner-mining-drill
move_to((26, -14))
# It seems I can't move to that position. Instead, I'll place a stone furnace near the existing burner-mining-drill
current_burner_drill_position = (2, 0)
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=current_burner_drill_position, direction='left', gap=1)
