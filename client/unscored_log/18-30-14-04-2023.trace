move_to(assembling_machine_location)
place_entity('assembling-machine-1', direction=DOWN, position=(assembling_machine_location[0], assembling_machine_location[1]+1))
set_entity_recipe(assembling_machine_location, recipe='iron-gear-wheel')
# The recipe for the entity placement failed. Let's first pickup some resources
