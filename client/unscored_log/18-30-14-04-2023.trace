print(f"Nearest Iron Ore location: {iron_ore_location}")
# Let's try again to get the nearest iron-ore location
iron_ore_location = nearest('iron-ore')
print(f"Nearest Iron Ore location: {iron_ore_location}")
# Now that we have the location, let's move to it and try to place the burner mining drill again.
