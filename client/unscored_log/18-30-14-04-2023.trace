place_entity('burner-mining-drill', direction=DOWN, position=(iron_ore_location[0], iron_ore_location[1]+1))
# Now, let's check if the burner mining drill has been placed successfully
inspect_radius(3)
# Great! The burner mining drill has been successfully placed. 
# Now, let's move the character to the (0, 0) position and place an assembling machine there
move_to((0, 0))
place_entity('assembling-machine-1', direction=DOWN, position=(0,1))
