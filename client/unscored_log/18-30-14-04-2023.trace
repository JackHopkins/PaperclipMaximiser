iron_ore_location = nearest('iron-ore')
print(iron_ore_location) # Expected output: (18, 0)
# I'm going to move to the nearest iron ore location and lay down a burner mining drill to start mining
move_to(iron_ore_location)
place_entity('burner-mining-drill', direction=DOWN, position=iron_ore_location)
# Trying again since the last action timed out
move_to(iron_ore_location)
place_entity('burner-mining-drill', direction=DOWN, position=iron_ore_location)
# The entity placement failed, so let's try to move a bit further away from the nearest iron-ore and place the entity again.
