comment("Inspect the available resources around")
resources = inspect_resources()
comment("Find the nearest coal deposit")
coal_position = nearest('coal')
comment("Move to the coal deposit and place a burner-mining-drill")
move_to(coal_position)
burner_mining_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
comment("Harvest 5 coal to provide initial fuel for the mining drills and furnaces")
harvest_resource(coal_position, quantity=5)
comment("Insert 1 coal into the burner-mining-drill to start mining")
insert_item('coal', target_position=burner_mining_drill_position, quantity=1)
comment("Find the nearest iron ore deposit")
iron_position = nearest('iron-ore')
comment("Move to the iron ore deposit and place a burner-mining-drill")
move_to(iron_position)
iron_burner_mining_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
comment("Place a stone-furnace next to the iron ore burner-mining-drill")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=iron_burner_mining_drill_position, direction=RIGHT, gap=1)
comment("Connect the iron burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=(iron_burner_mining_drill_position[0]+2, iron_burner_mining_drill_position[1]), target_position=stone_furnace_position,
