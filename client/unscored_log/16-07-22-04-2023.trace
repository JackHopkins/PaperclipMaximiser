# Inspect available resources and my current inventory
resources = inspect_resources()
inventory = inspect_inventory()
# Locate coal, iron ore, and copper ore resources
coal_position = nearest('coal')
iron_position = nearest('iron-ore')
copper_position = nearest('copper-ore')
# Place a burner-mining-drill on coal resource
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
# Place a stone furnace near the iron ore resource
move_to(iron_position)
stone_furnace_position = (iron_position[0]+2, iron_position[1])
place_entity('stone-furnace', position=stone_furnace_position)
# Place a burner-mining-drill near the iron ore resource to feed the stone furnace
iron_drill_position = (iron_position[0]-2, iron_position[1])
place_entity('burner-mining-drill', direction=LEFT, position=iron_drill_position)
# Craft a burner-mining-drill for the iron ore resource
craft_item('burner-mining-drill', quantity=1)
# Find a stone resource to mine for crafting the burner-mining-drill
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=5)
