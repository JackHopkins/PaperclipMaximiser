comment("First, let's check the surroundings and resources available")
resources = inspect_resources()
entities = inspect_entities(20)
inventory = inspect_inventory()

inventory = inspect_inventory()
comment("Looking for coal deposits")
find_coal = nearest('coal')
move_to(find_coal)
comment("Placing a burner-mining-drill near the coal deposit")
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=nearest_buildable('burner-mining-drill'))
comment("Now it's time to set up stone furnace for fuel, and smelting ore")
find_stone = nearest('stone')
move_to(find_stone)
harvest_resource(find_stone, quantity=5)
comment("Craft a stone furnace")
craft_item('stone-furnace', quantity=1)
comment("Place the stone furnace near the coal burner mining drill")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=coal_drill_position, direction=RIGHT, gap=1)
comment("Adjust the gap for the stone furnace and try again.")
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=coal_drill_position, direction=RIGHT, gap=2)
comment("Connect the burner-mining-drill output to the stone-furnace input using an inserter")
connect_entities(source_position=(coal_drill_position[0]+2, coal_drill_position[1]), target_position=stone_furnace_position, connection_type='inserter')
comment("It seems we need to place an inserter before connecting the entities. Craft an inserter first.")
craft_item('inserter', quantity=1)

comment("Place the inserter between the coal drill and stone furnace")
inserter_position = place_entity('inserter', direction=RIGHT, position=(coal_drill_position[0]+1, coal_drill_position[1]))

comment("Now connect the burner-mining-drill output to the stone-furnace input using the inserter")
connect_entities(source_position=coal_drill_position, target_position=stone_furnace_position, connection_type='inserter')
