comment("Inspect available resources on the map")
resources = inspect_resources()
comment("Find the nearest coal and iron ore deposits")
coal_position = nearest("coal")
iron_position = nearest("iron-ore")
comment("Move to the coal deposit")
move_to(coal_position)
comment("Place a burner-mining-drill on the coal deposit to extract coal, facing down")
place_entity("burner-mining-drill", direction=DOWN, position=(coal_position[0], coal_position[1]-2))
comment("Check to ensure that the burner-mining-drill has been placed")
entities = inspect_entities(5)
comment("Insert one unit of coal from the burner-mining-drill into the player's inventory")
extract_item("coal", source_position=(-8, -7), quantity=1)
comment("Manually pick up coal to use as fuel for the burner-mining-drill")
pickup_entity("coal", (coal_position[0]-1, coal_position[1]))
comment("Harvest 1 coal from the coal deposit to use as fuel")
harvest_resource((coal_position[0]-1, coal_position[1]), quantity=1)
comment("Insert 1 coal from player's inventory into the burner-mining-drill to fuel it")
insert_item("coal", target_position=(-8, -7), quantity=1)
comment("Find the nearest iron deposit")
iron_position = nearest("iron-ore")
comment("Move to the nearest iron deposit")
move_to(iron_position)
comment("Place a burner-mining-drill at the iron deposit")
place_entity("burner-mining-drill", direction=RIGHT, position=(iron_position[0]+2, iron_position[1]))
comment("Find the nearest stone deposit")
stone_position = nearest("stone")
comment("Move to the nearest stone deposit")
move_to(stone_position)
comment("Place a burner-mining-drill at the stone deposit")
place_entity("burner-mining-drill", direction=RIGHT, position=(stone_position[0]+2, stone_position[1]))
comment("Harvest 5 stone resources from the stone deposit")
harvest_resource(stone_position, quantity=5)
comment("Craft a burner-mining-drill using harvested stone")
craft_item("burner-mining-drill", quantity=1)
comment("Place the crafted burner-mining-drill at the stone deposit")
place_entity("burner-mining-drill", direction=RIGHT, position=(stone_position[0]+2, stone_position[1]))
comment("Find a new valid stone deposit")
stone_position = nearest("stone")
move_to(stone_position)
comment("Place the burner-mining-drill at the new stone deposit")
place_entity("burner-mining-drill", direction=RIGHT, position=(stone_position[0]+2, stone_position[1]))
comment("Harvest some coal to fuel the burner-mining-drill at the stone deposit")
coal_position = nearest("coal")
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
comment("Insert coal into the burner-mining-drill at the stone deposit")
insert_item("coal", target_position=(stone_position[0]+2, stone_position[1]), quantity=1)
comment("Find a new valid iron deposit")
iron_position = nearest("iron")
move_to(iron_position)
comment("Place the burner-mining-drill at the new iron deposit")
place_entity("burner-mining-drill", direction=DOWN, position=(iron_position[0], iron_position[1]-2))
comment("Craft a burner-mining-drill to place at the new iron deposit")
craft_item("burner-mining-drill", quantity=1)
comment("Place the new burner-mining-drill at the iron deposit")
place_entity("burner-mining-drill", direction=DOWN, position=(iron_position[0], iron_position[1]-2))
comment("Insert coal into the burner-mining-drill at the iron deposit")
insert_item("coal", target_position=(iron_position[0], iron_position[1]-2), quantity=1)
comment("Find a new valid stone deposit")
stone_position = nearest("stone")
move_to(stone_position)
comment("Place the burner-mining-drill at the new stone deposit")
craft_item("burner-mining-drill", quantity=1)
place_entity("burner-mining-drill", direction=LEFT, position=(stone_position[0]-2, stone_position[1]))
comment("Harvest 5 of the stone resource at the new stone deposit")
harvest_resource(stone_position, quantity=5)
comment("Craft and place the burner-mining-drill at the new stone deposit")
craft_item("burner-mining-drill", quantity=1)
place_entity("burner-mining-drill", direction=LEFT, position=(stone_position[0]-2, stone_position[1]))
comment("Insert coal into the burner-mining-drill at the new stone deposit")
insert_item("coal", target_position=(stone_position[0]-2, stone_position[1]), quantity=1)
comment("Find a valid iron deposit")
iron_position = nearest('iron-ore')
move_to(iron_position)
comment("Place a burner-mining-drill at the iron deposit")
craft_item("burner-mining-drill", quantity=1)
place_entity('burner-mining-drill', direction=LEFT, position=(iron_position[0]-2, iron_position[1]))
comment("We need more stone to craft another burner-mining-drill. Mine 5 more stone")
harvest_resource(stone_position, quantity=5)
comment("Extract stone from the placed burner-mining-drill")
extract_item("stone", source_position=(stone_position[0]-2, stone_position[1]), quantity=5)
comment("Pick up more coal to fuel the burner-mining-drill at the stone deposit")
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
comment("Insert coal into the burner-mining-drill at the stone deposit")
move_to((stone_position[0]-2, stone_position[1]))
insert_item("coal", target_position=(stone_position[0]-2, stone_position[1]), quantity=2)
comment("Wait for the burner-mining-drill to output stone")
wait(5)
comment("My bad, there is no 'wait' function. Extract stone from the burner-mining-drill")
move_to((stone_position[0]-2, stone_position[1]))
extract_item("stone", source_position=(stone_position[0]-2, stone_position[1]), quantity=5)
comment("Inspect the burner-mining-drill to determine how many stones it has produced")
inspect_entities(2)
comment("The 'status' field is still empty. Let's harvest the coal deposit for more coal to fuel the mining drill at the stone deposit")
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
comment("Insert additional coal into the burner-mining-drill at the stone deposit")
move_to((stone_position[0]-2, stone_position[1]))
insert_item("coal", target_position=(stone_position[0]-2, stone_position[1]), quantity=5)
comment("Wait a while for the stone to accumulate and then harvest it")
stone_output_position = (stone_position[0]-2, stone_position[1])
move_to(stone_output_position)
inspect_entities(2)
extract_item("stone", source_position=stone_output_position, quantity=5)
comment("Inspect the stone burner-mining-drill again")
wait_until_status_not_empty = True
while wait_until_status_not_empty:
    move_to(stone_output_position)
    entity_data = inspect_entities(2)
    for entity in entity_data:
        if entity["type"] == "burner_mining_drill" and entity["position"] == stone_output_position:
            if "stone" in entity["contents"]:
                wait_until_status_not_empty = False
            else:
                move_to(coal_position)
                harvest_resource(coal_position, quantity=5)
                move_to(stone_output_position)
                insert_item("coal", target_position=stone_output_position, quantity=5)
