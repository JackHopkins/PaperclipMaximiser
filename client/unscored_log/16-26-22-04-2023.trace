print(furnace_position)
comment("We'll also need to add a conveyor belt to transport the coal from the burner mining drill to the furnace")
move_to(coal_position, laying='transport-belt')
entity_position = place_entity_next_to('transport-belt', reference_position=entity_position, direction=UP, gap=1) 
print(entity_position)
comment("Seems like there is an obstacle in the way. Let's inspect the surroundings again") 
