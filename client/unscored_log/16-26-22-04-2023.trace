comment("First, let's create our mining setup")
comment("We'll need to find some coal and iron resources to start with") 
resources = inspect_resources()
print(resources)
comment("Let's check our current inventory") 
inventory = inspect_inventory()
print(inventory)
comment("Next, we'll move to the nearest coal resource and set up a burner mining drill there") 
coal_position = nearest('coal')
move_to(coal_position)
entity_position = place_entity('burner-mining-drill', direction=LEFT, position=(coal_position[0]-2, coal_position[1]))
print(entity_position) 
  
comment("We'll also need to set up a stone furnace to smelt the iron ore we'll mine later") 
furnace_position = nearest('stone-furnace')
print(furnace_position)
move_to(furnace_position)
place_entity('stone-furnace', direction=UP, position=(furnace_position[0], furnace_position[1]-2)) 
comment("Oops, looks like there are no stone furnaces on the map yet. Let's craft and place one near our mining setup") 
craft_item('stone-furnace', quantity=1)
move_to(coal_position)
furnace_position = place_entity_next_to('stone-furnace', reference_position=entity_position, direction=UP, gap=1)
print(furnace_position)
comment("Oh, we seem to be missing the required stone to craft the furnace. We'll need to harvest some first.") 
stone_position = nearest('stone')
move_to(stone_position)
harvest_resource(stone_position, quantity=20)
print(inventory)
comment("Looks like there are no more stones to harvest nearby. Let's go back to the coal resource and start mining.") 
