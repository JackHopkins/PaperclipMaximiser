comment("Sorry about that. I forgot to define the function get_item_recipe(). Here is the function to retrieve a recipe")
def get_item_recipe(item):
    recipes = get_game_recipes()
    for recipe in recipes:
        if recipe['result'] == item:
            return recipe['name']
