# First, let's inspect our surroundings and resources
inspect_resources()
inspect_entities(20)
# We have access to coal, iron ore, stone, copper ore and uranium ore. We also have some trees around. 
# Let's start by placing a few burner mining drills on the nearby coal deposit.
move_to(nearest('coal'))
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 5:
    craft_item('burner-mining-drill', quantity=5-count_drills)
# It looks like we're missing ingredients necessary for burner mining drills. 
# Let's start by placing a few burner mining drills on the nearby coal deposit.
move_to(nearest('coal'))
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 5:
    craft_item('stone-furnace', quantity=1)
    craft_item('burner-mining-drill', quantity=5-count_drills)
else:
    craft_item('transport-belt', quantity=50)
    
# It seems we're missing stone. Let's go search for one near us.
# Let's start by placing a few burner mining drills on the nearby coal deposit.
move_to(nearest('coal'))
count_drills = check_inventory().get('burner-mining-drill', 0)
if count_drills < 5:
    stone_position = nearest('stone')
    if stone_position:
        move_to(stone_position)
        craft_item('stone-furnace', quantity=1)
        move_to(nearest('coal'))
        craft_item('burner-mining-drill', quantity=5-count_drills)
    else:
        print("No stone found. Can't craft burner mining drills or stone furnaces.")
else:
    craft_item('transport-belt', quantity=50)
# It seems there's no stone nearby. Let's look for some manually.
move_to(nearest('tree'))
harvest_resource(nearest('rock'), quantity=5)
move_to((0, 0)) taux de production par minute
