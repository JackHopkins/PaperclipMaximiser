comment("Start by inspecting the resources around you")
inspect_resources()
comment("Move to the nearest coal patch and place a burner-mining-drill")
coal_position = nearest('coal')
comment(f"Moving to {coal_position}")
move_to(coal_position)
comment("Placing a burner-mining-drill")
drill_position = place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Check if mining drill has been placed")
inspect_entities(5) 
comment("Now, we need to connect the mining drill to a stone furnace, we would move to the nearest stone patch and place a stone furnace")
stone_position = nearest('stone')
comment(f"Moving to {stone_position}")
move_to(nearest('stone'))
comment("Placing a stone-furnace")
furnace_position = place_entity('stone-furnace', direction=LEFT, position=nearest_buildable('stone-furnace'))
comment("We will also be placing a chest adjacent to the stone-furnace for it to output to")
chest_position = place_entity_next_to('iron-chest', reference_position=furnace_position, direction=UP, gap=1)
comment("Connect the burner-mining-drill's output to the stone-furnace's input using an inserter")
connect_entities(source_position=drill_position, target_position=furnace_position, connection_type='inserter')
comment("We will craft a burner mining drill and two stone furnaces using the resources already available in the inventory")
inspect_inventory()
comment("Crafting a burner mining drill using already available iron plates and gears")
craft_item('burner-mining-drill', quantity=1)
inspect_inventory()
