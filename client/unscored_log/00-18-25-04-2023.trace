comment("Check available resources around me")
resources = inspect_resources()
comment("Find coal and move to it")
coal_position = nearest('coal')
move_to(coal_position)
comment("Place burner-mining-drill for coal extraction")
drill_position = place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Inspect entities around me to make sure the drill is placed")
inspect_entities(5)
comment("Pick up 5 coal from coal_position")
harvest_resource(coal_position, quantity=5)
