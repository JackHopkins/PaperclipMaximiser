comment("Inspect the natural resources and landscape around me")
resources = inspect_resources()
comment("Find the nearest coal position and move to it")
coal_position = nearest("coal")
move_to(coal_position)
comment("Place a burner-mining-drill near the coal and fuel it with coal")
burner_drill_position = place_entity("burner-mining-drill", direction=DOWN, position=(coal_position[0], coal_position[1]-2))
pickup_entity("coal", coal_position)
insert_item("coal", target_position=burner_drill_position, quantity=1)
comment("Harvest coal instead of picking up")
harvest_resource(coal_position, quantity=5)
insert_item("coal", target_position=burner_drill_position, quantity=1)
comment("Find the nearest iron ore position and move to it")
iron_ore_position = nearest("iron-ore")
move_to(iron_ore_position)
comment("Place a burner-mining-drill near the iron ore and fuel it with coal")
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Craft a burner-mining-drill and place it near the iron ore")
craft_item("burner-mining-drill", quantity=1)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect the surroundings before placing the burner-mining-drill near the iron ore")
inspect_resources()
craft_item("burner-mining-drill", quantity=1)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Find the nearest stone position and move to it")
stone_position = nearest("stone")
move_to(stone_position)
comment("Mine 5 stone to craft a burner-mining-drill")
harvest_resource(stone_position, quantity=5)
comment("Craft the burner-mining-drill and place it near the iron ore")
craft_item("burner-mining-drill", quantity=1)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect the surroundings and ensure that there is space for the burner-mining-drill near the iron ore")
inspect_resources()
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Move to the iron ore position and try placing the burner-mining-drill again")
move_to(iron_ore_position)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect entities around the iron ore position")
inspect_entities(5)
comment("Remove the existing burner-mining-drill and place a new one facing north")
pickup_entity("burner-mining-drill", (-9, -7))
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Try placing the burner-mining-drill facing north one tile away from the initial position")
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0] + 1, iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect entities in a larger radius around the iron ore position")
inspect_entities(10)
comment("Ensure there are no obstacles before placing the burner-mining-drill")
move_to(iron_ore_position)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect resources and find a suitable location for placing the burner-mining-drill")
resources = inspect_resources()
iron_ore_position_new = resources['iron-ore']
move_to(iron_ore_position_new)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position_new[0], iron_ore_position_new[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Retrieving iron ore positions from the dictionary response")
iron_ore_position_new = resources['iron-ore']['position']
move_to(iron_ore_position_new)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position_new[0], iron_ore_position_new[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect resources again and extract iron ore positions correctly")
resources = inspect_resources()
iron_ore_positions = resources['iron-ore']['positions']
iron_ore_position_new = iron_ore_positions[0]
move_to(iron_ore_position_new)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position_new[0], iron_ore_position_new[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect entities around the current iron ore position")
inspect_entities(10)
comment("Inspect resources again and try a different iron ore position")
resources = inspect_resources()
iron_ore_positions = resources['iron-ore']['positions']
iron_ore_position_new = iron_ore_positions[1] if len(iron_ore_positions) > 1 else iron_ore_positions[0]
move_to(iron_ore_position_new)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position_new[0], iron_ore_position_new[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Manually set the iron ore position and place the burner-mining-drill")
iron_ore_position_new = (20, -5)
move_to(iron_ore_position_new)
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position_new[0], iron_ore_position_new[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect entities around the manually set iron ore position")
move_to(iron_ore_position_new)
inspect_entities(10)
comment("Inspect resources and iron ore positions once more")
resources = inspect_resources()
iron_ore_positions = resources['iron-ore']['positions']
print(iron_ore_positions)
comment("Move to a different iron ore position")
move_to(iron_ore_position, laying='transport-belt')
comment("Place the burner-mining-drill again")
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect entities around the current position")
inspect_entities(10)
comment("Clear the transport belt obstructing the placement of the burner-mining-drill")
pickup_entity('transport_belt', (20.5, -4.5))
comment("Move away from transport belt and try placing burner-mining-drill again")
move_to((iron_ore_position[0]-1, iron_ore_position[1]+2))
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect the surroundings again")
inspect_entities(5)
comment("Move further away from transport belt and try placing burner-mining-drill again")
move_to((iron_ore_position[0]-2, iron_ore_position[1]+4))
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] + 2))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect the surroundings further away from the transport belt")
inspect_entities(10)
comment("Move further up and away from transport belt")
move_to((iron_ore_position[0]+20, iron_ore_position[1]))
comment("Attempt to place the burner-mining-drill again in a new position")
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1]))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Inspect the surroundings and check for any obstacles")
inspect_entities(5)
comment("Try a different area to place the burner-mining-drill for iron ore extraction")
move_to((iron_ore_position[0], iron_ore_position[1] - 10))
iron_drill_position = place_entity("burner-mining-drill", direction=UP, position=(iron_ore_position[0], iron_ore_position[1] - 8))
insert_item("coal", target_position=iron_drill_position, quantity=1)
comment("Place a stone furnace next to the burner-mining-drill for iron ore smelting")
furnace_position = place_entity("stone_furnace", direction=UP, position=(iron_drill_position[0] + 2, iron_drill_position[1]))
insert_item("coal", target_position=furnace_position, quantity=1)
comment("Check for stone resource position and inventory")
stone_position = nearest("stone")
inspect_inventory()
comment("Harvest more stone to craft a stone_furnace")
move_to(stone_position)
harvest_resource(stone_position, quantity=10)
craft_item("stone_furnace", quantity=1)
furnace_position = place_entity("stone_furnace", direction=UP, position=(iron_drill_position[0] + 2, iron_drill_position[1]))
insert_item("coal", target_position=furnace_position, quantity=1)
comment("As we could not get enough stones, we will find more stones and harvest them.")
stones_positions = find_resources("stone")
stones_positions.remove(stone_position) comment("Exclude the already checked stone position")
new_stone_position = stones_positions[0]
move_to(new_stone_position)
harvest_resource(new_stone_position, quantity=1)
craft_item("stone_furnace", quantity=1)
furnace_position = place_entity("stone_furnace", direction=UP, position=(iron_drill_position[0] + 2, iron_drill_position[1]))
insert_item("coal", target_position=furnace_position, quantity=1)
