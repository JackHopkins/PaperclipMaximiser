def find_offshore_pump_placement(radius):
    for i in range(1, radius+1):
        total_tiles = 2* (i * (i + 1))
        index = 0
        while index < total_tiles:
            resources = inspect_resources(radius=i)
            if 'water' in resources:
                water_tiles = resources['water']
                for water_tile in water_tiles:
                    return move_to(water_tile) and place_entity('offshore-pump', direction=UP, position=(water_tile[0], water_tile[1]-1))
            index += 1
    return None

find_offshore_pump_placement(5)
