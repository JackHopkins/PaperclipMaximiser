comment("Find and harvest some coal to power early game equipment")
coal_position = nearest('coal')
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
comment("Place a burner-mining-drill to extract coal")
coal_drill_position = place_entity('burner-mining-drill', direction=RIGHT, position=(coal_position[0]+2, coal_position[1]))
comment("I made an error placing the burner-mining-drill, I will correct it now")
comment("Find the nearest buildable position for the burner-mining-drill")
drill_position = nearest_buildable('burner-mining-drill')
move_to(drill_position)
comment("Place the burner-mining-drill on the buildable position")
place_entity('burner-mining-drill', direction=RIGHT, position=drill_position)
comment("Now that the burner-mining-drill is placed, insert some coal from the inventory to fuel it")
insert_item('coal', target_position=drill_position, quantity=1)
comment("Find and move to nearest iron ore patch")
iron_ore_position = nearest("iron-ore")
move_to(iron_ore_position)
comment("Harvest some iron ore from the patch")
harvest_resource(iron_ore_position, quantity=5)

comment("Place a stone furnace to smelt the iron ore into iron plates")
furnace_position = place_entity('stone-furnace', direction=UP, position=(iron_ore_position[0], iron_ore_position[1]+2))
comment("Insert iron ore into the stone furnace")
insert_item('iron-ore', target_position=furnace_position, quantity=5)
comment("Fuel the stone furnace with coal from the inventory")
insert_item('coal', target_position=furnace_position, quantity=1)
comment("Wait for the furnace to smelt the iron ore into iron plates")
wait(10)
comment("Extract the iron plates from the furnace")
extract_item('iron-plate', source_position=furnace_position, quantity=5)
comment("Apologies for the mistake, I will omit the wait step")
comment("Insert the iron ore into the stone furnace")
insert_item('iron-ore', target_position=furnace_position, quantity=5)
comment("Fuel the stone furnace with coal from the inventory")
insert_item('coal', target_position=furnace_position, quantity=1)
comment("Check how much coal we have in our inventory")
inspect_inventory()
comment("We have enough coal, let's try to fuel the stone furnace again")
insert_item('coal', target_position=furnace_position, quantity=1)

comment("Monitor the production of iron plates in the stone furnace")
monitor_furnace_production = True
while monitor_furnace_production:
    inspect_entities(5)
    iron_in_furnace = entity_item_count(furnace_position, 'iron-plate')
    if iron_in_furnace >= 5:
        comment("Extract the iron plates from the furnace")
        extract_item('iron-plate', source_position=furnace_position, quantity=5)
        monitor_furnace_production = False

