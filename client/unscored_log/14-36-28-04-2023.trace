comment("Find the nearest coal and setup a burner-mining-drill")
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal_position)
comment("Inspect entities within 5 meters to check if the burner-mining-drill has been placed")
inspect_entities(5)
comment("Setup a stone-furnace next to the burner-mining-drill for smelting")
move_to(coal_position)
stone_furnace_position = place_entity_next_to('stone-furnace', reference_position=coal_position, direction=RIGHT, gap=1)
