# First, let's check our surroundings and available resources
inspect_resources()
inspect_entities(10)
# It looks like we have a decent amount of resources nearby, let's start by mining some coal and iron ore
move_to(nearest('coal'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
move_to(nearest('iron_ore'))
place_entity('burner-mining-drill', direction=DOWN, position=nearest('iron_ore'))
# Oops, looks like we need to check our surroundings again
inspect_entities(20)
# It seems like there's nothing around us. Let's move a bit further to look for resources
move_to((10, 0))
inspect_resources()
