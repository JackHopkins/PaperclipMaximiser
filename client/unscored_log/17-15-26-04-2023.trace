    move_to(nearest('iron-ore'))
comment("Now we have enough iron ore. Let's craft one burner-mining-drill using the following code.")
craft_item('burner-mining-drill', quantity=1)
comment("We still don't have enough iron ore. Let's harvest some more.")
harvest_resource(nearest('iron-ore'), quantity=5)
comment("Now we have enough iron ore. Let's craft one burner-mining-drill using the following code.")
craft_item('burner-mining-drill', quantity=1)
comment("Now that we have crafted the mining drill, let's place it near the iron ore and connect it to a transport belt.")
ore_position = nearest('iron-ore')
belt_position = (ore_position[0], ore_position[1]-2)
comment("Let's place the burner-mining-drill and connect it to the transport belt.")
drill_position = place_entity('burner-mining-drill', position=ore_position)
connect_entities(source_position=drill_position, target_position=belt_position, connection_type='transport-belt')
comment("Looks like we need to place the transport belt first. Let's place the transport belt and then connect it to the mining drill.")
belt_position = place_entity('transport-belt', position=belt_position)
connect_entities(source_position=drill_position, target_position=belt_position, connection_type='transport-belt')
comment("Looks like we passed an unsupported connection type. Let's try with 'inserter'.")
connect_entities(source_position=drill_position, target_position=belt_position, connection_type='inserter')
comment("Let's place the rest of the necessary entities.")
comment("Placing a stone furnace")
furnace_position = place_entity('stone_furnace', position=(-1, 1))
comment("Oh, we need to craft a stone furnace in order to place it.")
craft_item('stone-furnace', quantity=1)
comment("Seems like we need stones to craft a stone furnace, let's extract some stones and then try to craft.")
harvest_resource(stones_position, quantity=10)
craft_item('stone-furnace', quantity=1)
comment("It looks like the stones are out of our reach. Let's move to a closer location.")
new_stones_position = nearest('stone-rock')
move_to(new_stones_position)
harvest_resource(new_stones_position, quantity=10)
comment("It seems like there are no stone rocks on the map. Let's try smelting iron ore instead.")
iron_position = nearest('iron-ore')
move_to(iron_position)
extract_item('iron-ore', source_position=iron_position, quantity=10)
furnace_position = place_entity('stone-furnace', position=(-1, 1), direction=RIGHT)
connect_entities(source_position=furnace_position, target_position=belt_position, connection_type='inserter')
comment("Looks like there is no iron ore in the surroundings. Let's try mining coal instead.")
coal_position = nearest('coal')
move_to(coal_position)
harvest_resource(coal_position, quantity=20)
comment("We got some coal, Let's craft a burner mining drill to extract more coal.")
craft_item('burner-mining-drill', quantity=1)
comment("We need iron ore to craft a burner mining drill, Let's extract iron ore from the earth first.")
iron_position = nearest('iron-ore')
move_to(iron_position)
extract_item('iron-ore', source_position=iron_position, quantity=10)
comment("Looks like there is no iron ore in the surroundings. Let's try mining stone instead.")
stone_position = nearest('stone-rock')
move_to(stone_position)
harvest_resource(stone_position,quantity=20)
comment("We need a burner mining drill to extract coal, which requires an iron plate. Let's craft one.")
craft_item('iron-plate', quantity=2)
comment("Let's try finding some iron ore to craft iron plates.")
iron_position = nearest('iron-ore')
move_to(iron_position)
extract_item('iron-ore', source_position=iron_position, quantity=20)
comment("Looks like there is not enough iron ore here. Let's expand our search.")
iron_resources = inspect_resources()
for pos in iron_resources:
    if iron_resources[pos] == 'iron-ore':
        new_pos = (int(pos[0]), int(pos[1]))
        move_to(new_pos)
        extract_item('iron-ore', source_position=new_pos, quantity=20)
        break
comment("Great, now we have enough iron ore to craft an iron plate")
craft_item('iron-plate', quantity=2)
comment("Seems like we don't have enough iron ore despite the previous successful extraction. Let's try once more to ensure it's not a temporary issue.")
iron_position = nearest('iron-ore')
move_to(iron_position)
extract_item('iron-ore', source_position=iron_position, quantity=20)
