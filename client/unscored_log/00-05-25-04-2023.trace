comment("Place the burner-mining-drill on coal to generate needed fuel")
coal_position = nearest('coal')
move_to(coal_position)
burner_drill_position = place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill', resource='coal'))
