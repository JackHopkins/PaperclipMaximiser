comment("Plan:")
comment("We have located an ore deposit at position (-8, -5). We will move to this position and harvest all available resources.")
comment("Move to ore deposit")
move_to(ore)
comment("Harvest ore")
harvest_resource(ore)

comment("After harvesting the ore, we should inspect our inventory to see what items we have collected.") 
inspect_inventory()

comment("Now we'll need to smelt the ore to produce metal plates.") 
comment("Place an electric furnace.")
furnace_position = nearest('stone-furnace')
move_to(furnace_position)
entity_position = place_entity('electric-furnace', direction=UP, position=furnace_position)
comment("Plan:")
comment("As there is no stone-furnace nearby, we will start by crafting and placing a basic furnace.")
comment("We will then need to gather fuel to power the furnace to smelt our collected ore.")
comment("After smelting, we will inspect our inventory to verify that we have produced metal plates successfully.")
comment("Craft and place a basic furnace.")
craft_item('stone-furnace', quantity=1)
furnace_position = nearest('player_character', 'stone-furnace')
place_entity('stone-furnace', position=furnace_position)
comment("Plan:")
comment("We will need to gather stone to craft the stone-furnace that we need.")
comment("To power the furnace, we can use some coal we already have in our inventory") 
comment("After smelting, we will inspect our inventory to verify that we have produced metal plates successfully.")
comment("Gather stone by mining it using a burner-mining-drill.")
stone_position = nearest('stone')
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=stone_position)
comment("Oh, it looks like we don't have a burner mining drill. Let's craft it first before we mine the stone.")
comment("Craft and place a burner mining drill at the nearest coal patch.")
craft_item('burner-mining-drill', quantity=1)
coal_position = nearest('coal')
move_to(coal_position)
place_entity('burner-mining-drill', direction=LEFT, exact=False, position=coal_position)
comment("Now let's mine for stone.")
stone_position = nearest('stone')
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=stone_position)
comment("Looks like we got the position of the stone wrong. Let's try to find the nearest stone patch again.")
stone_position = nearest('stone')
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=stone_position)
comment("We seem to be running out of fuel for the mining drill. Let's insert coal from the inventory using an inserter to keep the mining drill running.")
inventory = inspect_inventory()
if 'coal' in inventory.keys():
    insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
else:
    coal_position = nearest('coal')
    move_to(coal_position)
    pickup_entity('coal', coal_position)
    insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)   
    
stone_position = nearest('stone')
move_to(stone_position)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=stone_position)
comment("Looks like we need more resources. Let's move to the nearest coal patch and start mining for coal.")
coal_position = nearest('coal')
move_to(coal_position)
harvest_resource(coal_position, quantity=5)
place_entity('burner-mining-drill', direction=DOWN, exact=False, position=coal_position)
insert_item('coal', target_position=nearest('burner-mining-drill'), quantity=1)
