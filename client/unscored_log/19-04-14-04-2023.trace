# Lets start by checking my inventory.
# I have some resources to get started, but I need more iron for making gears. 
# Let's check out the resources around us
observe_nature()
# There are a lot of trees, copper ore to the east, uranium ore to the southeast, coal to the northwest, iron ore to the east-northeast, and stone to the southwest. We can use the nearest() function to locate these resources. 
# First, let's move to some iron ore.
iron_position = nearest('iron-ore')
move_to(iron_position)
# Now that we are here, let's mine the iron ore
harvest_resource(iron_position, quantity = 50)
# We should now have 50 iron ore in our inventory. We can check this with check_inventory().
# Let's check our inventory to see if we have 50 iron ore.
check_inventory()
# If we have 50 iron ore, we can craft 50 iron plates in the stone furnace. 
# Once we have the iron plates, we can use them to make gears in the assembling machine.
craft_item('iron-plate', quantity=50)
# Check our inventory again to see the iron plates
check_inventory()
# Now we can make 50 gears from the iron plates.
set_entity_recipe(nearest('assembling-machine-1'), recipe='iron-gear-wheel')
insert_item('iron-plate', target_position=(0, 0), quantity=50)
extract_item('iron-gear-wheel', source_position=(0, 1), quantity=50)
# Check to see if we have 50 gears in the inventory.
check_inventory()
# Great! We have 50 gears now. Let's craft chests to use them.
craft_item('iron-chest', quantity=5)
# Check our inventory again to see the chests.
check_inventory()
# I think I made a mistake earlier. I should have used place_entity instead of set_entity_recipe. Let's fix it.
# We can make 50 gears from the iron plates.
place_entity('assembling-machine-1', direction=UP, position=(0, -1))
craft_item('iron-gear-wheel', quantity=50)
# Check to see if we have 50 gears in the inventory.
check_inventory()
# Great! We have 50 gears now. Let's craft chests to use them.
craft_item('iron-chest', quantity=5)
# Check our inventory again to see the chests.
check_inventory()
