# Great! The chest was placed correctly. Now let's place the boilers and steam engines to generate power.
# To keep things simple, we'll place them in series, with one boiler connected to one steam engine, then the second boiler connected to the second steam engine. This maximizes the power output while using a minimum number of resources.
# We'll place them in a line, starting 3 tiles to the right of the chest, and 1 tile apart.
place_entity('boiler', position=(3, -2))
place_entity('steam-engine', position=(5, -2))
place_entity('boiler', position=(7, -2))
place_entity('steam-engine', position=(9, -2))
