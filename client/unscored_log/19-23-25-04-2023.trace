comment("Start by inspecting the resources and entities around the player character")
inspect_resources()
inspect_entities(20)
comment("Move to the nearest iron ore deposit")
iron_ore_position = nearest('iron-ore')
move_to(iron_ore_position)
comment("Place a burner-mining-drill on the iron ore deposit")
place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', iron_ore_position), direction=DOWN)
comment("Oops, no available iron. Let's try copper instead")
copper_ore_position = nearest('copper-ore')
move_to(copper_ore_position)
place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', copper_ore_position), direction=DOWN)
comment("Hmm, no copper ore either. Let's inspect our surrounding resources")
inspect_resources()
"{'iron-ore': [(22, -5)], 'stone': [(15, -177), (11, -189), (194, -128), (120, -164)], 'coal': [(12, 7)], 'copper-ore': [(22, 6)]}"
comment("Great, we have some iron at (22, -5) and copper next to it at (22,6). Let's set up our mining operation there!")
iron_ore_position = (22, -5)
copper_ore_position = (22, 6)
comment("Let's start by placing our mining drills on the resources")
move_to(iron_ore_position)
iron_drill_position = place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', iron_ore_position), direction=DOWN)
move_to(copper_ore_position)
copper_drill_position = place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', copper_ore_position), direction=DOWN)
comment("Wait, that's odd. We can't place the mining drill on top of the resource. Let's try to get a closer look.")
inspect_entities(5)
"[(22, -4.5), (22, -5.5), (21.5, -5), (22.5, -5), (22, -5)]"
comment("Ah, it seems like there are actually multiple entities on top of the resource, including some trees. We need to remove those first before we can mine the resource.")
move_to(iron_ore_position)
remove_entities([nearest("tree"), nearest("rock")])  comment("Depending on what else is on top of the resource")
iron_drill_position = place_entity('burner-mining-drill', position=nearest_buildable('burner-mining-drill', iron_ore_position), direction=DOWN)  comment("Place the mining drill once the area is clear")
comment("Let's use the 'remove_entity' function to remove all the trees in the area.")<br>
entities = inspect_entities(5)<br>
for entity in entities:<br>
    if entity['name'] == 'tree':<br>
        remove_entity(entity['position'])<br> 
comment("Now, let's try to place the mining drill again.")<br>
place_entity('burner-mining-drill', direction=LEFT, position=nearest_buildable('burner-mining-drill'))
comment("Let's use the 'remove_entity' function to remove all the trees in the area.")
comment("Remove trees in the area of iron ore and copper ore")
tree_positions = [entity["position"] for entity in inspect_entities(10) if entity["name"] == "tree"]
for tree in tree_positions:
    remove_entity(tree)
comment("Remove trees in the area of iron ore and copper ore")
tree_positions = [entity["position"] for entity in inspect_entities(10) if entity["name"] == "tree"]
for tree_position in tree_positions:
    remove_entity(tree_position)
comment("Remove trees in the area of iron ore and copper ore")
tree_positions = [entity["position"] for entity in inspect_entities(10) if entity["name"] == "tree"]
for tree_position in tree_positions:
    remove_entity(tree_position)
