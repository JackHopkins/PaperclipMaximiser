# My apologies, I forgot to define the function at the beginning. Let's define the function now
def set_move_time(time: int):
    """
    Sets the time allowed to move the character to a new position
    :param time: time allowed in seconds
    """
    global MOVE_TIME
    MOVE_TIME = time
