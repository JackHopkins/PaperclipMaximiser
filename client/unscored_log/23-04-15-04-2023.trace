# Begin by inspecting the resources around us
inspect_resources()
# Next, let's check our inventory
check_inventory()
# Let's start by setting up a basic mining operation
# First we'll place the burner mining drill on the nearest coal resource
place_entity('burner-mining-drill', direction=DOWN, position=nearest('coal'))
# It looks like there is already a mining drill nearby, let's try to find another location
# Let's start by setting up a basic mining operation
# We can try to find a different coal resource and place the burner mining drill there
coal_position = nearest('coal',radius=20, omit_entities = ["burner-mining-drill"])
# We can now place the mining drill at the new location
place_entity('burner-mining-drill', direction=DOWN, position=coal_position)
# It looks like we are out of luck finding coal. Let's move on to a different resource instead.
# Let's try setting up our mining operation for iron this time
# First, we'll place the burner mining drill on the nearest iron resource
place_entity('burner-mining-drill', direction=DOWN, position=nearest('iron-ore')) 
# Now that we have a mining drill for iron ore, let's set up a smelting setup
# We'll start by placing a stone furnace near the mining drill to smelt the iron ore
place_entity('stone-furnace', direction=DOWN, position=(2,0))
# Next, we'll place a chest to store coal, which is used as fuel for the furnace
place_entity('iron-chest', direction=DOWN, position=(3,1))
# Now, we'll insert coal from our inventory into the chest
insert_item('coal', target_position=(3,1), quantity=10)
# We can now start smelting the iron ore by setting the recipe of the furnace to 'iron-plate'
set_entity_recipe((2,0), recipe='iron-plate')
