comment("First, let's inspect our surroundings")
inspect_resources() 
inspect_entities(20)
comment("Let's start by placing a burner-mining-drill on the nearest coal and inserting coal into it for fuel")
coal_pos = nearest('coal')
move_to(coal_pos)
bm_drill_pos = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
insert_item('coal', target_position=bm_drill_pos, quantity=1)
comment("Now, let's move to the nearest iron ore and place another burner-mining-drill ")
iron_ore_pos = nearest('iron-ore')
move_to(iron_ore_pos)
bm_drill_pos2 = place_entity('burner-mining-drill', direction=DOWN, position=nearest_buildable('burner-mining-drill'))
insert_item('coal', target_position=bm_drill_pos2, quantity=1)
