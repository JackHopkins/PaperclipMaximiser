import time
comment("Create a loop to keep checking the contents of the stone furnace for iron plates")
iron_plates_available = False
while not iron_plates_available:
    comment("Inspect the contents of the stone furnace")
    furnace_contents = inspect_entity_contents(furnace_position)
    if 'iron-plate' in furnace_contents and furnace_contents['iron-plate'] >= 5:
        iron_plates_available = True
    else:
        time.sleep(5)  comment("wait for 5 seconds before checking again")

comment("Extract iron plates from the stone furnace")
extract_item('iron-plate', source_position=furnace_position, quantity=5)
